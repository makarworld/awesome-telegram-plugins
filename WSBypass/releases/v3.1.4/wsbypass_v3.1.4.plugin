def _is_ru_token(v):
    try:
        s = str(v or "").strip().lower()
    except Exception:
        return False
    if not s:
        return False
    if s.startswith("ru") or s.startswith("рус"):
        return True
    if " ru" in (" " + s) or "ru_" in s or "ru-" in s:
        return True
    if "рус" in s:
        return True
    return False
def _is_ru_language():
    try:
        lc = LocaleController.getInstance()
        if lc is not None:
            for method_name in ("getCurrentLocaleInfo", "getCurrentLocale", "getCurrentLangCode", "getCurrentLanguageName"):
                try:
                    member = getattr(lc, method_name, None)
                    val = member() if callable(member) else member
                    if _is_ru_token(val):
                        return True
                    for attr in ("shortName", "pluralLangCode", "langCode", "name", "nameEnglish"):
                        try:
                            if _is_ru_token(getattr(val, attr, None)):
                                return True
                        except Exception:
                            pass
                except Exception:
                    pass
            for attr in ("currentLocaleInfo", "currentLocale", "currentLangCode"):
                try:
                    val = getattr(lc, attr, None)
                    if _is_ru_token(val):
                        return True
                    for subattr in ("shortName", "pluralLangCode", "langCode", "name", "nameEnglish"):
                        try:
                            if _is_ru_token(getattr(val, subattr, None)):
                                return True
                        except Exception:
                            pass
                except Exception:
                    pass
    except Exception:
        pass
    try:
        if _is_ru_token(Locale.getDefault().getLanguage()):
            return True
        if _is_ru_token(Locale.getDefault().toString()):
            return True
    except Exception:
        pass
    return False
def Z(key):
    idx = 0 if _is_ru_language() else 1
    try: return str(TRANSLATIONS.get(key, (key, key))[idx])
    except Exception: return str(key)
def _log(message):
    try:
        log(str(message))
    except Exception:
        pass
def _apply_tg_proxy(port, enable, socks_user="", socks_pass="", secret=""):
    try:
        ProxyInfoClass = find_class("org.telegram.messenger.SharedConfig$ProxyInfo")
        try:
            SharedConfig.loadProxyList()
        except Exception:
            pass
        local_proxy = None
        try:
            try:
                with _TGWS_PROXYLIST_LOCK:
                    pl = SharedConfig.proxyList if hasattr(SharedConfig, "proxyList") else None
                    proxy_snapshot = list(pl) if pl else []
            except Exception:
                proxy_snapshot = []
            duplicates = []
            for p in proxy_snapshot:
                try:
                    if str(p.address) == LOCAL_PROXY_HOST:
                        if local_proxy is None:
                            local_proxy = p
                        else:
                            duplicates.append(p)
                except Exception:
                    continue
            for p in duplicates:
                try:
                    with _TGWS_PROXYLIST_LOCK:
                        SharedConfig.deleteProxy(p)
                except Exception:
                    pass
        except Exception:
            pass
        ed = MessagesController.getGlobalMainSettings().edit()
        try:
            proxy_list = SharedConfig.proxyList
            if proxy_list:
                to_remove = []
                for i in range(proxy_list.size()):
                    p = proxy_list.get(i)
                    if str(p.address) == LOCAL_PROXY_HOST:
                        to_remove.append(p)
                for p in to_remove:
                    SharedConfig.deleteProxy(p)
        except Exception:
            pass
        try:
            curr = SharedConfig.currentProxy
            if curr and str(curr.address) == LOCAL_PROXY_HOST:
                SharedConfig.currentProxy = None
        except Exception:
            pass
        if enable:
            _secret = str(secret or "").strip()
            _su = "" if _secret else str(socks_user or "")
            _sp = "" if _secret else str(socks_pass or "")
            if local_proxy is not None:
                try:
                    local_proxy.port = int(port)
                    local_proxy.username = _su
                    local_proxy.password = _sp
                    local_proxy.secret = _secret
                except Exception:
                    pass
                proxy_obj = local_proxy
                try:
                    with _TGWS_PROXYLIST_LOCK:
                        SharedConfig.addProxy(proxy_obj)
                except Exception:
                    pass
            else:
                proxy_obj = None
                try:
                    proxy_obj = SharedConfig.addProxy(LOCAL_PROXY_HOST, int(port), _su, _sp, _secret)
                except Exception:
                    proxy_obj = None
                if not proxy_obj:
                    try:
                        proxy_obj = ProxyInfoClass(LOCAL_PROXY_HOST, int(port), _su, _sp, _secret)
                        try:
                            SharedConfig.addProxy(proxy_obj)
                        except Exception:
                            pass
                    except Exception:
                        proxy_obj = None
            try:
                if proxy_obj:
                    SharedConfig.currentProxy = proxy_obj
                    try:
                        sc_cls = find_class("org.telegram.messenger.SharedConfig")
                        for _fname, _fval in (("currentProxyInfo", proxy_obj), ("currentProxy", proxy_obj), ("useProxySettings", True), ("proxyEnabled", True)):
                            try:
                                _f = _tgws_cached_field(sc_cls, str(_fname))
                                _f.set(None, _fval)
                            except Exception:
                                pass
                    except Exception:
                        pass
            except Exception:
                pass
            try:
                SharedConfig.proxyEnabled = True
            except Exception:
                pass
            ed.putString("proxy_ip", LOCAL_PROXY_HOST)
            ed.putInt("proxy_port", int(port))
            try:
                ed.putString("proxy_user", _su)
                ed.putString("proxy_pass", _sp)
            except Exception:
                pass
            ed.putString("proxy_secret", _secret)
            ed.putBoolean("proxy_enabled", True)
            _calls_enabled = False if _secret else True
            for key in ("proxy_enabled_calls", "proxy_calls_enabled", "calls_use_proxy"):
                try:
                    ed.putBoolean(key, bool(_calls_enabled))
                except Exception:
                    pass
            try:
                for attr in ("proxyEnabledCalls", "proxyCallsEnabled", "callsEnabled", "useProxyForCalls"):
                    try:
                        setattr(SharedConfig, attr, bool(_calls_enabled))
                    except Exception:
                        pass
            except Exception:
                pass
            if proxy_obj:
                try:
                    for attr in ("enabledForCalls", "useForCalls"):
                        try:
                            setattr(proxy_obj, attr, bool(_calls_enabled))
                        except Exception:
                            pass
                except Exception:
                    pass
            if _calls_enabled:
                try:
                    for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                        try:
                            prefs = MessagesController.getInstance(ac).getSharedPreferences("mainconfig", 0)
                            if prefs:
                                p2p_prev_key = "tgws_proxy_p2p_backup_" + str(ac)
                                current_p2p = prefs.getInt("calls_p2p", -1)
                                if current_p2p != 2:
                                    prefs.edit().putInt(p2p_prev_key, current_p2p).putInt("calls_p2p", 2).commit()
                        except Exception:
                            pass
                except Exception:
                    pass
        else:
            try:
                curr = SharedConfig.currentProxy
                if curr and str(curr.address) == LOCAL_PROXY_HOST:
                    SharedConfig.currentProxy = None
            except Exception:
                pass
            try:
                SharedConfig.proxyEnabled = False
            except Exception:
                pass
            try:
                sc_cls = find_class("org.telegram.messenger.SharedConfig")
                for _fname, _fval in (("useProxySettings", False), ("proxyEnabled", False)):
                    try:
                        _f = _tgws_cached_field(sc_cls, str(_fname))
                        _f.set(None, _fval)
                    except Exception:
                        pass
            except Exception:
                pass
            ed.putBoolean("proxy_enabled", False)
            try:
                for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                    try:
                        try:
                            _uc = UserConfig.getInstance(ac)
                            if _uc is None or not bool(_uc.isClientActivated()):
                                continue
                        except Exception:
                            pass
                        prefs = MessagesController.getInstance(ac).getSharedPreferences("mainconfig", 0)
                        if prefs:
                            p2p_prev_key = "tgws_proxy_p2p_backup_" + str(ac)
                            saved_p2p = prefs.getInt(p2p_prev_key, -1)
                            if saved_p2p >= 0:
                                prefs.edit().putInt("calls_p2p", saved_p2p).remove(p2p_prev_key).apply()
                    except Exception:
                        pass
            except Exception:
                pass
        try:
            ed.commit()
        except Exception:
            ed.apply()
        try:
            SharedConfig.saveProxyList()
        except Exception:
            pass
        try:
            SharedConfig.saveConfig()
        except Exception:
            pass
        _secret2 = str(secret or "").strip()
        _su2 = "" if _secret2 else str(socks_user or "")
        _sp2 = "" if _secret2 else str(socks_pass or "")
        for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
            try:
                try:
                    _uc = UserConfig.getInstance(ac)
                    if _uc is None or not bool(_uc.isClientActivated()):
                        continue
                except Exception:
                    pass
                cm = ConnectionsManager.getInstance(ac)
                if cm:
                    if enable:
                        cm.setProxySettings(True, LOCAL_PROXY_HOST, int(port), _su2, _sp2, _secret2)
                    else:
                        cm.setProxySettings(False, "", 0, "", "", "")
            except Exception:
                pass
        try:
            if enable:
                ConnectionsManager.setProxySettings(True, LOCAL_PROXY_HOST, int(port), _su2, _sp2, _secret2)
            else:
                ConnectionsManager.setProxySettings(False, "", 0, "", "", "")
        except Exception:
            pass
        def _notify():
            global _TGWS_NOTIFY_IN_FLIGHT
            try:
                with _TGWS_NOTIFY_LOCK:
                    if _TGWS_NOTIFY_IN_FLIGHT:
                        return
                    _TGWS_NOTIFY_IN_FLIGHT = True
                try:
                    try:
                        from java import jarray
                        from java.lang import Object
                        NotificationCenter.getGlobalInstance().postNotificationName(
                            NotificationCenter.proxySettingsChanged, jarray(Object)(0)
                        )
                    except Exception:
                        NotificationCenter.getGlobalInstance().postNotificationName(
                            NotificationCenter.proxySettingsChanged
                        )
                finally:
                    with _TGWS_NOTIFY_LOCK:
                        _TGWS_NOTIFY_IN_FLIGHT = False
            except Exception:
                try:
                    with _TGWS_NOTIFY_LOCK:
                        _TGWS_NOTIFY_IN_FLIGHT = False
                except Exception:
                    pass
        try:
            run_on_ui_thread(_notify, 300)
        except Exception:
            pass
    except Exception as e:
        _log(f"apply_tg_proxy error: {e}")
def _get_free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind((LOCAL_PROXY_HOST, 0))
        return s.getsockname()[1]
def _tgws_lower_thread_priority(n=2):
    try:
        if jclass is not None:
            _JThread = jclass("java.lang.Thread")
            _target = max(int(_JThread.MIN_PRIORITY), int(_JThread.NORM_PRIORITY) - int(n))
            _JThread.currentThread().setPriority(_target)
    except Exception:
        pass
def _tgws_xor_mask(data, mask):
    if not mask:
        return data
    mv = bytes(data)
    n = len(mv)
    if n == 0:
        return mv
    key = (bytes(mask[:4]) * ((n >> 2) + 1))[:n]
    return (int.from_bytes(mv, "big") ^ int.from_bytes(key, "big")).to_bytes(n, "big")
def _tgws_build_frame(opcode, payload, mask=True):
    try:
        body = bytes(payload or b"")
    except (TypeError, ValueError):
        body = b""
    out = bytearray()
    out.append(0x80 | (int(opcode) & 0x0F))
    length = len(body)
    mask_bit = 0x80 if mask else 0x00
    if length < 126:
        out.append(mask_bit | length)
    elif length <= 0xFFFF:
        out.append(mask_bit | 126)
        out.extend(struct.pack(">H", length))
    else:
        out.append(mask_bit | 127)
        out.extend(struct.pack(">Q", length))
    if mask:
        mask_key = os.urandom(4)
        out.extend(mask_key)
        if length:
            full = (mask_key * (length // 4 + 1))[:length]
            out.extend(
                (int.from_bytes(body, "big") ^ int.from_bytes(full, "big")).to_bytes(length, "big")
            )
    else:
        out.extend(body)
    return bytes(out)
def _tgws_read_exact(reader, size):
    need = int(size or 0)
    if need <= 0:
        return b""
    chunk = reader.read(need)
    if not chunk:
        raise EOFError("unexpected eof")
    if len(chunk) >= need:
        return chunk
    parts = [chunk]
    have = len(chunk)
    while have < need:
        chunk = reader.read(need - have)
        if not chunk:
            raise EOFError("unexpected eof")
        parts.append(chunk)
        have += len(chunk)
    return b"".join(parts)
def _tgws_recv_exact(conn, size):
    need = int(size or 0)
    if need <= 0:
        return b""
    chunk = conn.recv(need)
    if not chunk:
        raise EOFError("unexpected eof")
    if len(chunk) >= need:
        return chunk
    parts = [chunk]
    have = len(chunk)
    while have < need:
        chunk = conn.recv(need - have)
        if not chunk:
            raise EOFError("unexpected eof")
        parts.append(chunk)
        have += len(chunk)
    return b"".join(parts)
_TGWS_DNS_CACHE = {}
_TGWS_DNS_CACHE_LOCK = threading.Lock()
_TGWS_DNS_TTL_SEC = 300.0
_TGWS_DNS_CACHE_MAX = 256
_TGWS_DNS_RESOLVE_TIMEOUT_SEC = 2.0
_TGWS_REDIRECT_RE = re.compile(r"\b30[1-8]\b")
def _tgws_exc_is_host_down(exc):
    try:
        s = str(exc or "")
        if " 101 " in s or " 401 " in s or " 403 " in s or _TGWS_REDIRECT_RE.search(s):
            return False
        return isinstance(exc, OSError)
    except Exception:
        return False
def _tgws_dns_cache_store(hn, ip):
    try:
        with _TGWS_DNS_CACHE_LOCK:
            if hn not in _TGWS_DNS_CACHE and len(_TGWS_DNS_CACHE) >= _TGWS_DNS_CACHE_MAX:
                _now = time.time()
                for _k in [
                    _hk for _hk, _hv in list(_TGWS_DNS_CACHE.items())
                    if (_now - float(_hv[1])) >= _TGWS_DNS_TTL_SEC
                ]:
                    _TGWS_DNS_CACHE.pop(_k, None)
                if len(_TGWS_DNS_CACHE) >= _TGWS_DNS_CACHE_MAX:
                    _oldest = min(_TGWS_DNS_CACHE.items(), key=lambda kv: kv[1][1])[0]
                    _TGWS_DNS_CACHE.pop(_oldest, None)
            _TGWS_DNS_CACHE[hn] = (ip, time.time())
    except Exception:
        pass
def _tgws_getaddrinfo_bounded(hn, timeout_sec=_TGWS_DNS_RESOLVE_TIMEOUT_SEC):
    res = {"v": None}
    def _work():
        try:
            infos = socket.getaddrinfo(hn, None, socket.AF_INET, socket.SOCK_STREAM)
            res["v"] = infos
            try:
                for _fam, _t1, _t2, _t3, _sa in (infos or []):
                    if _fam == socket.AF_INET:
                        _tgws_dns_cache_store(hn, str(_sa[0]))
                        break
            except Exception:
                pass
        except Exception:
            res["v"] = None
    t = threading.Thread(target=_work, daemon=True, name="tgws-dns")
    t.start()
    t.join(float(timeout_sec))
    if t.is_alive():
        return None
    return res["v"]
def _tgws_resolve_ipv4(hostname):
    try:
        hn = str(hostname or "").strip()
        if not hn:
            return None
        try:
            if ":" in hn:
                return None
            socket.inet_aton(hn)
            return hn
        except Exception:
            pass
        stale_ip = None
        try:
            with _TGWS_DNS_CACHE_LOCK:
                cached = _TGWS_DNS_CACHE.get(hn)
            if cached is not None:
                ip, ts = cached
                if (time.time() - float(ts)) < _TGWS_DNS_TTL_SEC:
                    return ip
                stale_ip = ip
        except Exception:
            pass
        infos = _tgws_getaddrinfo_bounded(hn, _TGWS_DNS_RESOLVE_TIMEOUT_SEC)
        if not infos:
            return stale_ip
        for family, _, _, _, sockaddr in infos:
            if family == socket.AF_INET:
                ip = str(sockaddr[0])
                _tgws_dns_cache_store(hn, ip)
                return ip
        return stale_ip
    except Exception:
        return None
    return None
TGWS_HANDSHAKE_LEN = 64
TGWS_SKIP_LEN = 8
TGWS_PREKEY_LEN = 32
TGWS_IV_LEN = 16
TGWS_PROTO_TAG_POS = 56
TGWS_DC_IDX_POS = 60
TGWS_ZERO_64 = b"\x00" * 64
TGWS_PROTO_TAG_ABRIDGED = b"\xef\xef\xef\xef"
TGWS_PROTO_TAG_INTERMEDIATE = b"\xee\xee\xee\xee"
TGWS_PROTO_TAG_SECURE = b"\xdd\xdd\xdd\xdd"
TGWS_RESERVED_FIRST_BYTES = {0xEF}
TGWS_RESERVED_STARTS = {
    b"HEAD", b"POST", b"GET ", b"\xee\xee\xee\xee", b"\xdd\xdd\xdd\xdd", b"\x16\x03\x01\x02"
}
TGWS_DIRECT_DC_IP = {
    1: "149.154.175.50",
    2: "149.154.167.51",
    3: "149.154.175.100",
    4: "149.154.167.91",
    5: "149.154.171.5",
    203: "91.105.192.100",
}
def _tgws_to_bytes(value):
    if value is None:
        return b""
    try:
        return bytes(value)
    except Exception:
        try:
            return bytes(bytearray(value))
        except Exception:
            return b""
def _tgws_cipher_new(key_bytes, iv_bytes):
    if JavaCipher is None or SecretKeySpec is None or IvParameterSpec is None:
        raise RuntimeError("Java crypto unavailable")
    cipher = JavaCipher.getInstance("AES/CTR/NoPadding")
    cipher.init(JavaCipher.ENCRYPT_MODE, SecretKeySpec(bytes(key_bytes), "AES"), IvParameterSpec(bytes(iv_bytes)))
    return cipher
def _tgws_cipher_update(cipher, data):
    try:
        if not data:
            return b""
        if type(data) is not bytes:
            data = bytes(data)
        out = cipher.update(data)
        return _tgws_to_bytes(out)
    except Exception:
        return b""
def _tgws_try_mtproto_handshake(handshake, secret_bytes):
    try:
        raw = bytes(handshake or b"")
        secret = bytes(secret_bytes or b"")
        if len(raw) < TGWS_HANDSHAKE_LEN or len(secret) != 16:
            return None
        dec_prekey_iv = raw[TGWS_SKIP_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN + TGWS_IV_LEN]
        dec_prekey = dec_prekey_iv[:TGWS_PREKEY_LEN]
        dec_iv = dec_prekey_iv[TGWS_PREKEY_LEN:]
        dec_key = hashlib.sha256(dec_prekey + secret).digest()
        dec = _tgws_cipher_new(dec_key, dec_iv)
        decrypted = _tgws_cipher_update(dec, raw[:TGWS_HANDSHAKE_LEN])
        if len(decrypted) < TGWS_HANDSHAKE_LEN:
            return None
        proto_tag = decrypted[TGWS_PROTO_TAG_POS:TGWS_PROTO_TAG_POS + 4]
        if proto_tag not in (TGWS_PROTO_TAG_ABRIDGED, TGWS_PROTO_TAG_INTERMEDIATE, TGWS_PROTO_TAG_SECURE):
            return None
        dc_idx = struct.unpack("<h", decrypted[TGWS_DC_IDX_POS:TGWS_DC_IDX_POS + 2])[0]
        dc_id = abs(int(dc_idx))
        if dc_id <= 0 or dc_id > 1000:
            return None
        proto_int = struct.unpack("<I", proto_tag)[0]
        return dc_id, bool(dc_idx < 0), int(proto_int), bytes(proto_tag), bytes(dec_prekey_iv)
    except Exception:
        return None
def _tgws_generate_relay_init(proto_tag, dc_idx):
    try:
        proto = bytes(proto_tag or b"")[:4]
        if len(proto) != 4:
            proto = TGWS_PROTO_TAG_ABRIDGED
        while True:
            rnd = bytearray(os.urandom(TGWS_HANDSHAKE_LEN))
            if rnd[0] in TGWS_RESERVED_FIRST_BYTES:
                continue
            if bytes(rnd[:4]) in TGWS_RESERVED_STARTS:
                continue
            if rnd[4:8] == b"\x00\x00\x00\x00":
                continue
            break
        rnd_bytes = bytes(rnd)
        enc_key = rnd_bytes[TGWS_SKIP_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN]
        enc_iv = rnd_bytes[TGWS_SKIP_LEN + TGWS_PREKEY_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN + TGWS_IV_LEN]
        enc = _tgws_cipher_new(enc_key, enc_iv)
        encrypted_full = _tgws_cipher_update(enc, rnd_bytes)
        if len(encrypted_full) < TGWS_HANDSHAKE_LEN:
            return rnd_bytes
        keystream_tail = bytes(encrypted_full[i] ^ rnd_bytes[i] for i in range(56, 64))
        tail_plain = proto + struct.pack("<h", int(dc_idx)) + os.urandom(2)
        encrypted_tail = bytes(tail_plain[i] ^ keystream_tail[i] for i in range(8))
        result = bytearray(rnd_bytes)
        result[56:64] = encrypted_tail
        return bytes(result)
    except Exception:
        return os.urandom(TGWS_HANDSHAKE_LEN)
class _TgWsCryptoCtx:
    def __init__(self, clt_dec, clt_enc, tg_enc, tg_dec):
        self.clt_dec = clt_dec
        self.clt_enc = clt_enc
        self.tg_enc = tg_enc
        self.tg_dec = tg_dec
def _tgws_build_crypto_ctx(client_dec_prekey_iv, secret_bytes, relay_init):
    secret = bytes(secret_bytes or b"")
    client_iv = bytes(client_dec_prekey_iv or b"")
    relay = bytes(relay_init or b"")
    clt_dec_prekey = client_iv[:TGWS_PREKEY_LEN]
    clt_dec_iv = client_iv[TGWS_PREKEY_LEN:TGWS_PREKEY_LEN + TGWS_IV_LEN]
    clt_dec_key = hashlib.sha256(clt_dec_prekey + secret).digest()
    clt_dec = _tgws_cipher_new(clt_dec_key, clt_dec_iv)
    _tgws_cipher_update(clt_dec, TGWS_ZERO_64)
    clt_enc_prekey_iv = client_iv[::-1]
    clt_enc_key = hashlib.sha256(clt_enc_prekey_iv[:TGWS_PREKEY_LEN] + secret).digest()
    clt_enc_iv = clt_enc_prekey_iv[TGWS_PREKEY_LEN:TGWS_PREKEY_LEN + TGWS_IV_LEN]
    clt_enc = _tgws_cipher_new(clt_enc_key, clt_enc_iv)
    relay_enc_key = relay[TGWS_SKIP_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN]
    relay_enc_iv = relay[TGWS_SKIP_LEN + TGWS_PREKEY_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN + TGWS_IV_LEN]
    tg_enc = _tgws_cipher_new(relay_enc_key, relay_enc_iv)
    _tgws_cipher_update(tg_enc, TGWS_ZERO_64)
    relay_dec_prekey_iv = relay[TGWS_SKIP_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN + TGWS_IV_LEN][::-1]
    relay_dec_key = relay_dec_prekey_iv[:TGWS_PREKEY_LEN]
    relay_dec_iv = relay_dec_prekey_iv[TGWS_PREKEY_LEN:TGWS_PREKEY_LEN + TGWS_IV_LEN]
    tg_dec = _tgws_cipher_new(relay_dec_key, relay_dec_iv)
    return _TgWsCryptoCtx(clt_dec, clt_enc, tg_enc, tg_dec)
def _tgws_generate_secret_hex():
    try:
        return binascii.hexlify(os.urandom(16)).decode("ascii")
    except Exception:
        return "%032x" % random.getrandbits(128)
def _tgws_valid_secret_hex(value):
    try:
        s = str(value or "").strip().lower()
        if s.startswith("dd") or s.startswith("ee"):
            s = s[2:34]
        if len(s) != 32:
            return ""
        bytes.fromhex(s)
        return s
    except Exception:
        return ""
class _TgWsMsgSplitter:
    def __init__(self, init_data, proto_int=None):
        raw = bytes(init_data or b"")
        key = raw[8:40]
        iv = raw[40:56]
        if JavaCipher is None or SecretKeySpec is None or IvParameterSpec is None:
            raise RuntimeError("Java crypto unavailable")
        cipher = JavaCipher.getInstance("AES/CTR/NoPadding")
        cipher.init(JavaCipher.ENCRYPT_MODE, SecretKeySpec(bytes(key), "AES"), IvParameterSpec(bytes(iv)))
        try:
            cipher.update(b"\x00" * 64)
        except Exception:
            pass
        self._cipher = cipher
        try:
            self._proto = int(proto_int or 0)
        except Exception:
            self._proto = 0
        self._cipher_buf = bytearray()
        self._plain_buf = bytearray()
        self._disabled = False
        self._max_buf = 16 * 1024 * 1024
    def split(self, chunk):
        if not chunk:
            return []
        if self._disabled:
            return [chunk]
        try:
            self._cipher_buf.extend(bytes(chunk))
            plain = self._cipher.update(bytes(chunk))
            try:
                self._plain_buf.extend(bytes(plain))
            except Exception:
                self._plain_buf.extend(bytes(bytearray(plain)))
        except Exception:
            return [chunk]
        parts = []
        while self._cipher_buf:
            packet_len = self._next_packet_len()
            if packet_len is None:
                if len(self._cipher_buf) > self._max_buf:
                    parts.append(bytes(self._cipher_buf))
                    self._cipher_buf.clear()
                    self._plain_buf.clear()
                    self._disabled = True
                break
            if packet_len <= 0:
                parts.append(bytes(self._cipher_buf))
                self._cipher_buf.clear()
                self._plain_buf.clear()
                self._disabled = True
                break
            parts.append(bytes(self._cipher_buf[:packet_len]))
            del self._cipher_buf[:packet_len]
            del self._plain_buf[:packet_len]
        return parts
    def flush(self):
        if not self._cipher_buf:
            return []
        tail = bytes(self._cipher_buf)
        self._cipher_buf.clear()
        self._plain_buf.clear()
        return [tail]
    def _next_packet_len(self):
        proto = self._proto
        if not self._plain_buf:
            return None
        if proto == 0xEFEFEFEF:
            return self._next_abridged_len()
        if proto in (0xEEEEEEEE, 0xDDDDDDDD):
            return self._next_intermediate_len()
        return 0
    def _next_abridged_len(self):
        first = self._plain_buf[0]
        if first in (0x7F, 0xFF):
            if len(self._plain_buf) < 4:
                return None
            payload_len = int.from_bytes(self._plain_buf[1:4], "little") * 4
            header_len = 4
        else:
            payload_len = (first & 0x7F) * 4
            header_len = 1
        if payload_len <= 0:
            return 0
        packet_len = header_len + payload_len
        if len(self._plain_buf) < packet_len:
            return None
        return packet_len
    def _next_intermediate_len(self):
        if len(self._plain_buf) < 4:
            return None
        payload_len = struct.unpack_from("<I", self._plain_buf, 0)[0] & 0x7FFFFFFF
        if payload_len <= 0:
            return 0
        packet_len = 4 + payload_len
        if len(self._plain_buf) < packet_len:
            return None
        return packet_len
def _tgws_ws_domains(dc, is_media):
    try:
        dc_num = int(dc or 0)
    except (TypeError, ValueError):
        dc_num = 0
    try:
        dc_num = int(TGWS_DC_OVERRIDES.get(int(dc_num), int(dc_num)))
    except Exception:
        pass
    bases = ["web.telegram.org"]
    out = []
    for base in bases:
        if is_media:
            out.append(f"kws{dc_num}-1.{base}")
            out.append(f"kws{dc_num}.{base}")
        else:
            out.append(f"kws{dc_num}.{base}")
            out.append(f"kws{dc_num}-1.{base}")
    seen = set()
    uniq = []
    for d in out:
        if d not in seen:
            seen.add(d)
            uniq.append(d)
    return uniq
_TGWS_MAX_FRAME_LEN = 16 * 1024 * 1024
class _TgWsRawWebSocket:
    def __init__(self, sock, reader):
        self.sock = sock
        self.reader = reader
        self._lock = threading.Lock()
        self._closed = False
        self._last_io_ts = time.time()
        self._last_pong_ts = 0.0
    def ping(self, payload=b""):
        try:
            with self._lock:
                if self._closed:
                    return False
                self.sock.sendall(_tgws_build_frame(0x9, bytes(payload or b""), mask=True))
                self._last_io_ts = time.time()
            return True
        except Exception:
            try:
                self.close()
            except Exception:
                pass
            return False
    def last_io_age(self):
        try:
            return float(time.time() - float(self._last_io_ts or 0.0))
        except Exception:
            return 0.0
    @staticmethod
    def _open_socket(connect_host, timeout):
        sock = socket.create_connection((str(connect_host), 443), timeout=float(timeout))
        try:
            if TGWS_TCP_NODELAY:
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
        except:
            pass
        try:
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
        except Exception:
            pass
        try:
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_KEEPALIVE, 1)
            if hasattr(socket, "TCP_KEEPIDLE"):
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPIDLE, int(TGWS_TCP_KEEPIDLE_SEC))
            if hasattr(socket, "TCP_KEEPINTVL"):
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPINTVL, int(TGWS_TCP_KEEPINTVL_SEC))
            if hasattr(socket, "TCP_KEEPCNT"):
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPCNT, int(TGWS_TCP_KEEPCNT))
        except Exception:
            pass
        return sock
    @staticmethod
    def connect(connect_host, sni_host, timeout=TGWS_WS_CONNECT_TIMEOUT_SEC, path="/apiws", extra_headers=None, connect_timeout=None):
        sni = str(sni_host or "")
        try:
            io_timeout = float(timeout)
        except Exception:
            io_timeout = float(TGWS_WS_CONNECT_TIMEOUT_SEC)
        try:
            if connect_timeout is not None:
                connect_budget = float(connect_timeout)
            else:
                connect_budget = min(io_timeout, float(TGWS_WS_TCP_CONNECT_TIMEOUT_SEC))
        except Exception:
            connect_budget = io_timeout
        sock = _TgWsRawWebSocket._open_socket(connect_host, connect_budget)
        wrapped = None
        try:
            if ssl is None:
                wrapped = sock
            else:
                try:
                    vctx = ssl.create_default_context(cafile=_CA_BUNDLE if isinstance(_CA_BUNDLE, str) else None)
                    vctx.check_hostname = True
                    vctx.verify_mode = ssl.CERT_REQUIRED
                    wrapped = vctx.wrap_socket(sock, server_hostname=sni)
                except getattr(ssl, "SSLCertVerificationError", ssl.SSLError):
                    try:
                        sock.close()
                    except Exception:
                        pass
                    sock = _TgWsRawWebSocket._open_socket(connect_host, connect_budget)
                    rctx = ssl.create_default_context()
                    rctx.check_hostname = False
                    rctx.verify_mode = ssl.CERT_NONE
                    wrapped = rctx.wrap_socket(sock, server_hostname=sni)
            wrapped.settimeout(io_timeout)
            key = base64.b64encode(os.urandom(16)).decode("ascii")
            req_lines = [
                "GET " + str(path or "/apiws") + " HTTP/1.1",
                "Host: " + str(sni_host or ""),
                "Upgrade: websocket",
                "Connection: Upgrade",
                "Sec-WebSocket-Key: " + key,
                "Sec-WebSocket-Version: 13",
                "Sec-WebSocket-Protocol: binary",
                "Origin: https://web.telegram.org",
                "User-Agent: Mozilla/5.0 (Linux; Android 13)",
            ]
            if extra_headers:
                for _hk, _hv in extra_headers.items():
                    if _hk and _hv:
                        req_lines.append(str(_hk) + ": " + str(_hv).replace("\r", "").replace("\n", ""))
            req_lines += ["", ""]
            req = "\r\n".join(req_lines)
            wrapped.sendall(req.encode("utf-8"))
            reader = wrapped.makefile("rb", buffering=65536)
            status_line = reader.readline().decode("utf-8", errors="ignore").strip()
            headers = {}
            try:
                while True:
                    line = reader.readline()
                    if not line:
                        break
                    if line in (b"\r\n", b"\n"):
                        break
                    try:
                        s = line.decode("utf-8", errors="ignore").strip()
                    except:
                        continue
                    if ":" in s:
                        k, v = s.split(":", 1)
                        headers[str(k).strip().lower()] = str(v).strip()
            except:
                headers = headers or {}
            if " 101 " not in status_line:
                try:
                    reader.close()
                except:
                    pass
                try:
                    wrapped.close()
                except:
                    pass
                try:
                    parts = str(status_line).split(" ", 2)
                    code = int(parts[1]) if len(parts) >= 2 else 0
                except:
                    code = 0
                try:
                    loc = str(headers.get("location", "") or "").strip()
                except:
                    loc = ""
                if code in (301, 302, 303, 307, 308) and loc:
                    raise RuntimeError(f"{status_line} -> {loc}")
                raise RuntimeError(status_line or "bad websocket handshake")
            return _TgWsRawWebSocket(wrapped, reader)
        except Exception:
            try:
                if wrapped is not None and wrapped is not sock:
                    wrapped.close()
            except Exception:
                pass
            try:
                sock.close()
            except Exception:
                pass
            raise
    def send(self, payload):
        with self._lock:
            if self._closed:
                raise EOFError("websocket closed")
            self.sock.sendall(_tgws_build_frame(0x2, payload, mask=True))
    def send_batch(self, parts):
        with self._lock:
            if self._closed:
                raise EOFError("websocket closed")
            frames = [_tgws_build_frame(0x2, payload, mask=True) for payload in (parts or ())]
            if frames:
                self.sock.sendall(b"".join(frames))
    def _read_frame(self):
        header = _tgws_read_exact(self.reader, 2)
        fin = bool(header[0] & 0x80)
        opcode = header[0] & 0x0F
        masked = bool(header[1] & 0x80)
        length = header[1] & 0x7F
        if length == 126:
            length = struct.unpack(">H", _tgws_read_exact(self.reader, 2))[0]
        elif length == 127:
            length = struct.unpack(">Q", _tgws_read_exact(self.reader, 8))[0]
        if length > _TGWS_MAX_FRAME_LEN:
            raise EOFError("ws frame too large: %d" % int(length))
        mask_key = b""
        if masked:
            mask_key = _tgws_read_exact(self.reader, 4)
        payload = _tgws_read_exact(self.reader, length)
        if masked:
            payload = _tgws_xor_mask(payload, mask_key)
        return fin, opcode, payload
    def recv(self):
        buf = None
        while True:
            fin, opcode, payload = self._read_frame()
            if opcode == 0x8:
                self.close()
                return None
            if opcode == 0x9:
                self._write_control(0xA, payload)
                continue
            if opcode == 0xA:
                self._last_pong_ts = time.time()
                continue
            if opcode in (0x1, 0x2):
                if fin and buf is None:
                    return payload
                if buf is None:
                    buf = bytearray(payload)
                else:
                    buf.extend(payload)
                if fin:
                    return bytes(buf)
                continue
            if opcode == 0x0:
                if buf is None:
                    buf = bytearray()
                buf += payload
                if fin:
                    return bytes(buf)
                continue
    def _write_control(self, opcode, payload):
        with self._lock:
            if self._closed:
                return
            self.sock.sendall(_tgws_build_frame(opcode, payload, mask=True))
    def close(self):
        with self._lock:
            if self._closed:
                return
            self._closed = True
            try:
                self.sock.sendall(_tgws_build_frame(0x8, b"", mask=True))
            except:
                pass
            try:
                self.reader.close()
            except:
                pass
            try:
                self.sock.close()
            except:
                pass
    def is_closed(self):
        try:
            return bool(self._closed)
        except Exception:
            return True
class _TgWsWsPool:
    def __init__(self, max_age_sec=120.0, max_items_per_key=2):
        self._max_age = float(max_age_sec or 120.0)
        self._max_items = int(max_items_per_key or 2)
        self._lock = threading.Lock()
        self._idle = {}
    def get(self, key):
        now = time.time()
        with self._lock:
            q = self._idle.get(key)
            if not q:
                return None
            while q:
                ws, ts = q.pop(0)
                if ws is None:
                    continue
                try:
                    if ws.is_closed():
                        continue
                except Exception:
                    continue
                if self._max_age and (now - float(ts or 0.0)) > self._max_age:
                    try:
                        ws.close()
                    except Exception:
                        pass
                    continue
                return ws
            return None
    def put(self, key, ws):
        if ws is None:
            return
        try:
            if ws.is_closed():
                return
        except Exception:
            return
        with self._lock:
            q = self._idle.get(key)
            if not q:
                q = []
                self._idle[key] = q
            if len(q) >= self._max_items:
                try:
                    old, _ = q.pop(0)
                    if old is not None:
                        old.close()
                except Exception:
                    pass
            q.append((ws, time.time()))
    def clear(self):
        with self._lock:
            all_items = []
            for q in self._idle.values():
                all_items.extend(list(q))
            self._idle = {}
        for ws, _ in all_items:
            try:
                if ws is not None:
                    ws.close()
            except Exception:
                pass
    def count(self, key):
        now = time.time()
        stale = []
        with self._lock:
            q = self._idle.get(key)
            if not q:
                return 0
            alive = []
            for ws, ts in q:
                if ws is None:
                    continue
                try:
                    if ws.is_closed():
                        continue
                except Exception:
                    continue
                if self._max_age and (now - float(ts or 0.0)) > self._max_age:
                    stale.append(ws)
                    continue
                alive.append((ws, ts))
            self._idle[key] = alive
            n = len(alive)
        for ws in stale:
            try:
                ws.close()
            except Exception:
                pass
        return n
    def total(self):
        with self._lock:
            return sum(len(q) for q in self._idle.values())
class TgWsCore:
    def __init__(self, plugin=None):
        self._plugin = plugin
        self.listener = None
        self.listener_thread = None
        self.warmup_thread = None
        self.stop_event = threading.Event()
        self.lock = threading.Lock()
        self._cfg_lock = threading.RLock()
        self.tracked = set()
        self.fail_until = {}
        self.fail_count = {}
        self.ws_blacklist = set()
        self.ws_blacklist_until = {}
        self._relay_health = {}
        self._ap_tls = threading.local()
        self.ws_domain_pref = {}
        self.port = 0
        self.dc_ip = dict(TGWS_DEFAULT_DC_IP)
        self.secret_hex = ""
        self.secret_bytes = b""
        self._ws_pool = _TgWsWsPool(max_age_sec=float(TGWS_WS_SPARE_MAX_AGE_SEC), max_items_per_key=int(TGWS_WS_SPARE_PER_KEY))
        self._cf_pref = {}
        self._active_keys = {}
        self.lane_pref = {}
        self._route_version = 0
        self._warm_kick = threading.Event()
        self._last_dc_key_saved = None
    def _cf_domains_for_dc(self, dc, is_media=False):
        return self._relay_hosts_ordered()

    def _active_relays(self):
        try:
            return list(self._active_provider.get("relays") or [])
        except Exception:
            return list(_TGWS_RELAY_HOSTS)

    def _relay_key(self, host):
        return (str(self._active_provider_name or ""), str(host or ""))

    def _relay_sticky_base(self):
        try:
            relays = self._active_relays()
            n = len(relays)
            if n <= 1:
                return 0
            p = self._plugin
            if p is None:
                return 0
            iid = p.get_setting("tgws_install_id", None)
            if not iid:
                iid = binascii.hexlify(os.urandom(8)).decode()
                p.set_setting("tgws_install_id", iid, reload_settings=False)
            h = hashlib.sha256(str(iid).encode()).digest()
            return h[0] % n
        except Exception:
            return 0

    def _relay_hosts_ordered(self):
        relays = self._active_relays()
        try:
            base = self._relay_sticky_base()
            n = len(relays)
            ordered = [relays[(base + i) % n] for i in range(n)]
        except Exception:
            return list(relays)
        try:
            healthy = [h for h in ordered if not self._relay_is_down(h)]
            if not healthy:
                return ordered
            down = [h for h in ordered if self._relay_is_down(h)]
            return healthy + down
        except Exception:
            return ordered
    def _relay_note_fail(self, host):
        try:
            h = str(host or "")
            if not h:
                return
            key = self._relay_key(h)
            with self._cfg_lock:
                ent = self._relay_health.get(key) or {}
                fc = int(ent.get("fail_count", 0) or 0) + 1
                backoff = min(300.0, 30.0 * (2 ** min(max(fc - 1, 0), 4)))
                self._relay_health[key] = {"fail_count": fc, "fail_until": time.time() + backoff}
                if len(self._relay_health) > 32:
                    now = time.time()
                    self._relay_health = {
                        k: v for k, v in self._relay_health.items()
                        if now < float(v.get("fail_until", 0.0) or 0.0)
                    }
        except Exception:
            pass
    def _relay_note_ok(self, host):
        try:
            h = str(host or "")
            if not h:
                return
            with self._cfg_lock:
                self._relay_health.pop(self._relay_key(h), None)
        except Exception:
            pass
    def _relay_is_down(self, host):
        try:
            h = str(host or "")
            if not h:
                return False
            with self._cfg_lock:
                ent = self._relay_health.get(self._relay_key(h))
                if not ent:
                    return False
                return time.time() < float(ent.get("fail_until", 0.0) or 0.0)
        except Exception:
            return False
    def _cf_candidates(self, dc, is_media):
        try:
            hosts = self._cf_domains_for_dc(dc, is_media)
        except Exception:
            hosts = []
        hosts = [str(h or "").strip() for h in (hosts or [])]
        hosts = [h for h in hosts if h]
        results = {}
        if len(hosts) == 1:
            try:
                results[hosts[0]] = _tgws_resolve_ipv4(hosts[0])
            except Exception:
                results[hosts[0]] = None
        elif hosts:
            def _res(hn):
                try:
                    results[hn] = _tgws_resolve_ipv4(hn)
                except Exception:
                    results[hn] = None
            workers = []
            for h in hosts:
                t = threading.Thread(target=_res, args=(h,), daemon=True, name="tgws-dns-fan")
                t.start()
                workers.append(t)
            deadline = time.time() + 2.0
            for t in workers:
                t.join(max(0.0, deadline - time.time()))
        out = []
        seen = set()
        for h in hosts:
            ip = results.get(h)
            key = ip or h
            if key in seen:
                continue
            seen.add(key)
            out.append((ip or h, h))
        return out
    def _ws_pool_key(self, dc, is_media):
        try:
            return (int(dc or 0), bool(is_media))
        except Exception:
            return (0, bool(is_media))
    def _ws_pool_key_p(self, dc, is_media, provider):
        base = self._ws_pool_key(dc, is_media)
        return (base[0], base[1], provider)
    def _ws_pool_get(self, dc, is_media, provider=None):
        return self._ws_pool.get(self._ws_pool_key_p(dc, is_media, provider))
    def _ws_pool_put(self, dc, is_media, ws, provider=None):
        try:
            self._ws_pool.put(self._ws_pool_key_p(dc, is_media, provider), ws)
        except Exception:
            try:
                if ws is not None:
                    ws.close()
            except Exception:
                pass
    def _ws_pool_count(self, dc, is_media, provider=None):
        try:
            return int(self._ws_pool.count(self._ws_pool_key_p(dc, is_media, provider)))
        except Exception:
            return 0
    def _ws_pool_total(self):
        try:
            return int(self._ws_pool.total())
        except Exception:
            return 0
    def _note_active_key(self, dc, is_media):
        try:
            k = self._ws_pool_key(dc, is_media)
            with self._cfg_lock:
                self._active_keys[k] = time.time()
                if len(self._active_keys) > 32:
                    cutoff = time.time() - float(TGWS_WS_ACTIVE_KEY_TTL_SEC)
                    self._active_keys = {kk: t for kk, t in self._active_keys.items() if t >= cutoff}
            p = self._plugin
            if p is not None:
                val = "%d:%d" % (int(k[0]), 1 if k[1] else 0)
                if getattr(self, "_last_dc_key_saved", None) != val:
                    self._last_dc_key_saved = val
                    p.set_setting("tgws_last_dc_key", val, reload_settings=False)
        except Exception:
            pass
    def _ws_fail_timeout(self, dc_key):
        try:
            with self._cfg_lock:
                fail_until = float(self.fail_until.get(dc_key, 0.0) or 0.0)
        except Exception:
            fail_until = 0.0
        try:
            if time.time() < fail_until:
                return float(TGWS_WS_FAIL_TIMEOUT_SEC)
        except Exception:
            pass
        return float(TGWS_WS_CONNECT_TIMEOUT_SEC)
    def _ws_fail_record(self, dc_key):
        try:
            with self._cfg_lock:
                prev = int(self.fail_count.get(dc_key, 0) or 0)
        except Exception:
            prev = 0
        new_count = prev + 1
        try:
            base = float(TGWS_WS_FAIL_COOLDOWN_SEC)
            backoff = base * (2 ** min(max(new_count - 1, 0), 4))
            backoff = min(backoff, float(TGWS_WS_FAIL_COOLDOWN_MAX_SEC))
        except Exception:
            backoff = float(TGWS_WS_FAIL_COOLDOWN_SEC)
        deadline = time.time() + backoff
        try:
            with self._cfg_lock:
                self.fail_count[dc_key] = int(new_count)
                self.fail_until[dc_key] = float(deadline)
        except Exception:
            pass
    def _ws_fail_clear(self, dc_key):
        try:
            with self._cfg_lock:
                self.fail_until.pop(dc_key, None)
                self.fail_count.pop(dc_key, None)
        except Exception:
            pass
    def _ws_is_blacklisted(self, dc_key):
        now = time.time()
        try:
            with self._cfg_lock:
                until = self.ws_blacklist_until.get(dc_key)
                if until is None:
                    return False
                if now >= float(until or 0.0):
                    self.ws_blacklist_until.pop(dc_key, None)
                    try:
                        self.ws_blacklist.discard(dc_key)
                    except Exception:
                        pass
                    return False
                return True
        except Exception:
            return False
    def _ws_blacklist_add(self, dc_key):
        try:
            with self._cfg_lock:
                self.ws_blacklist_until[dc_key] = time.time() + float(TGWS_WS_BLACKLIST_TTL_SEC)
                try:
                    self.ws_blacklist.add(dc_key)
                except Exception:
                    pass
        except Exception:
            pass
    def _bump_route_version(self):
        try:
            self._route_version = int(getattr(self, "_route_version", 0)) + 1
        except Exception:
            self._route_version = 1
    def route_version(self):
        try:
            return int(getattr(self, "_route_version", 0))
        except Exception:
            return 0
    def _lane_fail_key(self, dc_key, lane):
        try:
            return ("cf", dc_key) if lane == "cf" else dc_key
        except Exception:
            return dc_key
    def _ordered_lanes(self, dc_key):
        return ["cf", "direct"]
    def _lane_record_success(self, dc_key, lane):
        if lane not in ("cf", "direct"):
            return
        try:
            with self._cfg_lock:
                cur = str(self.lane_pref.get(dc_key) or "").strip().lower()
                if cur == lane:
                    return
                if cur in ("cf", "direct"):
                    cur_key = self._lane_fail_key(dc_key, cur)
                    if not self._ws_is_blacklisted(cur_key):
                        fails = int(self.fail_count.get(cur_key, 0) or 0)
                        if fails < int(TGWS_LANE_HYSTERESIS):
                            return
                self.lane_pref[dc_key] = lane
                self._bump_route_version()
        except Exception:
            pass
    def export_route_pref(self):
        try:
            with self._cfg_lock:
                lane = {f"{int(k[0])}:{int(bool(k[1]))}": str(v)
                        for k, v in self.lane_pref.items() if v in ("cf", "direct")}
                dom = {f"{int(k[0])}:{int(bool(k[1]))}": str(v)
                       for k, v in self.ws_domain_pref.items() if v}
                cf = {str(int(k)): str(v) for k, v in self._cf_pref.items() if v}
            return {"lane": lane, "dom": dom, "cf": cf}
        except Exception:
            return None
    def import_route_pref(self, data):
        def _kk(s):
            a, b = str(s).split(":", 1)
            return (int(a), bool(int(b)))
        _CAP = 64
        try:
            d = data if isinstance(data, dict) else {}
            new_lane, new_dom, new_cf = {}, {}, {}
            for k, v in (d.get("lane") or {}).items():
                if len(new_lane) >= _CAP:
                    break
                try:
                    if str(v) in ("cf", "direct"):
                        new_lane[_kk(k)] = str(v)
                except Exception:
                    continue
            for k, v in (d.get("dom") or {}).items():
                if len(new_dom) >= _CAP:
                    break
                try:
                    if v:
                        new_dom[_kk(k)] = str(v)
                except Exception:
                    continue
            for k, v in (d.get("cf") or {}).items():
                if len(new_cf) >= _CAP:
                    break
                try:
                    if v:
                        new_cf[int(k)] = str(v)
                except Exception:
                    continue
            with self._cfg_lock:
                if new_lane:
                    self.lane_pref.update(new_lane)
                if new_dom:
                    self.ws_domain_pref.update(new_dom)
                if new_cf:
                    self._cf_pref.update(new_cf)
        except Exception:
            pass
    def reset_resilience_state(self):
        try:
            with self._cfg_lock:
                self.ws_blacklist = set()
                self.ws_blacklist_until = {}
                self.fail_until = {}
                self.fail_count = {}
                self._relay_health = {}
        except Exception:
            try:
                self.ws_blacklist = set()
                self.ws_blacklist_until = {}
                self.fail_until = {}
                self.fail_count = {}
                self._relay_health = {}
            except Exception:
                pass
    def _warm_one_spare(self, dc, is_media):
        provider = self._warm_provider()
        if provider is None:
            return False
        self._set_active_provider(provider)
        pname = self._active_provider_name
        try:
            candidates = self._cf_candidates(dc, is_media)
        except Exception:
            candidates = []
        warm_timeout = float(TGWS_WS_WARM_CONNECT_TIMEOUT_SEC)
        path = "/apiws?dc=" + str(int(dc or 0))
        headers = _kws_auth_headers(pname)
        if not headers:
            return False
        for connect_host, sni_host in candidates:
            if self.stop_event.is_set():
                return False
            if self._relay_is_down(sni_host):
                continue
            try:
                ws = _TgWsRawWebSocket.connect(connect_host, sni_host, timeout=warm_timeout, path=path, extra_headers=headers)
                self._relay_note_ok(sni_host)
                self._ws_pool_put(dc, is_media, ws, pname)
                return True
            except Exception as exc:
                try:
                    if _tgws_exc_is_host_down(exc):
                        self._relay_note_fail(sni_host)
                except Exception:
                    pass
                _kws_note_ws_failure(pname, exc)
                continue
        return False
    def _warmup_ws_pool(self, delay_sec=0):
        try:
            d = float(delay_sec or 0)
        except Exception:
            d = 0.0
        try:
            if d > 0:
                end = time.time() + d
                while time.time() < end:
                    if self.stop_event.is_set():
                        return
                    time.sleep(min(0.2, max(0.0, end - time.time())))
        except Exception:
            pass
        try:
            boot_end = time.time() + 8.0
            while (not self.stop_event.is_set()) and time.time() < boot_end and self._warm_provider() is None:
                if self.stop_event.wait(0.25):
                    return
        except Exception:
            pass
        while not self.stop_event.is_set():
            try:
                now = time.time()
                ttl = float(TGWS_WS_ACTIVE_KEY_TTL_SEC)
                with self._cfg_lock:
                    keys = [k for k, t in self._active_keys.items() if (now - float(t or 0)) <= ttl]
                if not keys:
                    dcs = []
                    for k in list((self.dc_ip or {}).keys()):
                        try:
                            dcs.append(int(k))
                        except Exception:
                            continue
                    for dcn in dcs:
                        keys.append((dcn, False))
                    for dcn in dcs:
                        keys.append((dcn, True))
                warm_provider = self._warm_provider()
                warm_pname = warm_provider["name"] if warm_provider else None
                for (dc, is_media) in keys:
                    if self.stop_event.is_set():
                        return
                    if warm_provider is None:
                        break
                    if self._ws_pool_total() >= int(TGWS_WS_SPARE_MAX):
                        break
                    if self._ws_pool_count(dc, is_media, warm_pname) >= int(TGWS_WS_SPARE_PER_KEY):
                        continue
                    self._warm_one_spare(dc, is_media)
                    try:
                        if self.stop_event.wait(max(0.0, float(TGWS_WARMUP_STAGGER_SEC))):
                            return
                    except Exception:
                        return
            except Exception:
                pass
            try:
                if self._warm_kick.wait(max(0.5, float(TGWS_WS_WARM_INTERVAL_SEC))):
                    self._warm_kick.clear()
                if self.stop_event.is_set():
                    return
            except Exception:
                return
    def is_available(self):
        return JavaCipher is not None
    def _track(self, closer):
        with self.lock:
            self.tracked.add(closer)
    def _untrack(self, closer):
        with self.lock:
            self.tracked.discard(closer)
    def _close_all_tracked(self):
        with self.lock:
            closers = list(self.tracked)
            self.tracked.clear()
        for closer in closers:
            try:
                closer.close()
            except Exception:
                pass
    def _parse_config(self, config_json):
        cfg = {"port": int(TGWS_LOCAL_PORT), "dc_ip": dict(TGWS_DEFAULT_DC_IP)}
        raw = str(config_json or "").strip()
        if raw:
            parsed = json.loads(raw)
            if isinstance(parsed, dict):
                if parsed.get("port"):
                    cfg["port"] = int(parsed.get("port") or TGWS_LOCAL_PORT)
                dc_ip = parsed.get("dc_ip")
                if isinstance(dc_ip, dict):
                    for key, value in dc_ip.items():
                        cfg["dc_ip"][str(key)] = str(value)
        if cfg["port"] <= 0 or cfg["port"] > 65535:
            cfg["port"] = int(TGWS_LOCAL_PORT)
        return cfg
    def start(self, config_json, socks_user="", socks_pass="", secret_hex=""):
        if not self.is_available():
            return Z("java_crypto_missing")
        try:
            cfg = self._parse_config(config_json)
            secret = _tgws_valid_secret_hex(secret_hex) or _tgws_generate_secret_hex()
            self.stop()
            self.secret_hex = secret
            self.secret_bytes = bytes.fromhex(secret)
            listener = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            listener.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            try:
                if TGWS_TCP_NODELAY:
                    listener.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
            except Exception:
                pass
            try:
                listener.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
                listener.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
            except Exception:
                pass
            listener.bind((LOCAL_PROXY_HOST, int(cfg["port"])))
            listener.listen(64)
            listener.settimeout(1.0)
            self.listener = listener
            self.port = int(cfg["port"])
            self.dc_ip = dict(cfg.get("dc_ip") or {})
            try:
                with self._cfg_lock:
                    self.fail_until = {}
                    self.fail_count = {}
                    self.ws_blacklist = set()
                    self.ws_blacklist_until = {}
            except Exception:
                self.fail_until = {}
                self.fail_count = {}
                self.ws_blacklist = set()
                self.ws_blacklist_until = {}
            self.stop_event.clear()
            self.listener_thread = threading.Thread(target=self._accept_loop, name="tgws-accept", daemon=True)
            self.listener_thread.start()
            try:
                _kws_prefetch_all()
            except Exception:
                pass
            try:
                def _dns_prewarm():
                    for pr in list(_KWS_PROVIDERS):
                        for h in list(pr.get("relays") or []):
                            try:
                                _tgws_resolve_ipv4(h)
                            except Exception:
                                pass
                threading.Thread(target=_dns_prewarm, daemon=True, name="tgws-dns-prewarm").start()
            except Exception:
                pass
            try:
                p = self._plugin
                if p is not None:
                    lv = str(p.get_setting("tgws_last_dc_key", "") or "")
                    if lv and ":" in lv:
                        a, b = lv.split(":", 1)
                        self._last_dc_key_saved = lv
                        with self._cfg_lock:
                            self._active_keys[(int(a), bool(int(b)))] = time.time()
            except Exception:
                pass
            try:
                self._warm_kick.clear()
            except Exception:
                pass
            if bool(TGWS_WARMUP_ON_START):
                wt = threading.Thread(target=self._warmup_ws_pool, kwargs={"delay_sec": float(TGWS_WARMUP_DELAY_SEC)}, name="tgws-warmup", daemon=True)
                self.warmup_thread = wt
                wt.start()
            return ""
        except Exception as exc:
            try:
                if self.listener is not None:
                    self.listener.close()
            except Exception:
                pass
            self.listener = None
            return str(exc)
    def stop(self):
        self.stop_event.set()
        try:
            self._warm_kick.set()
        except Exception:
            pass
        try:
            if self.listener is not None:
                self.listener.close()
        except Exception:
            pass
        self.listener = None
        try:
            self._ws_pool.clear()
        except Exception:
            pass
        self._close_all_tracked()
        thread = self.listener_thread
        self.listener_thread = None
        if thread is not None and thread.is_alive():
            try:
                thread.join(1.5)
            except Exception:
                pass
        wthread = self.warmup_thread
        self.warmup_thread = None
        if wthread is not None and wthread.is_alive():
            try:
                wthread.join(1.5)
            except Exception:
                pass
    def _accept_loop(self):
        while not self.stop_event.is_set():
            try:
                conn, _ = self.listener.accept()
                try:
                    if TGWS_TCP_NODELAY:
                        conn.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
                except Exception:
                    pass
                try:
                    conn.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
                    conn.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
                except Exception:
                    pass
            except socket.timeout:
                continue
            except Exception:
                if self.stop_event.is_set():
                    break
                continue
            try:
                self._track(conn)
                threading.Thread(target=self._handle_client, args=(conn,), daemon=True).start()
            except Exception:
                try:
                    conn.close()
                except Exception:
                    pass
                try:
                    self._untrack(conn)
                except Exception:
                    pass
                if self.stop_event.is_set():
                    break
                continue
    def _close_write(self, conn):
        try:
            conn.shutdown(socket.SHUT_WR)
        except Exception:
            pass
    def _connect_ws_direct(self, dc, is_media, target_ip, timeout):
        dc_key = self._ws_pool_key(dc, is_media)
        try:
            ws = self._ws_pool_get(dc, is_media)
            if ws is not None:
                return ws
        except Exception:
            pass
        domains = _tgws_ws_domains(dc, is_media)
        try:
            with self._cfg_lock:
                pref = str(self.ws_domain_pref.get(dc_key) or "").strip()
        except Exception:
            pref = ""
        if pref:
            domains = [pref] + [d for d in domains if d != pref]
        last_exc = None
        redirected = set()
        for di, domain in enumerate(domains):
            candidates = []
            for c in (domain, _tgws_resolve_ipv4(domain), str(target_ip or "").strip()):
                if c and c not in candidates:
                    candidates.append(c)
            for hi, host in enumerate(candidates):
                if di == len(domains) - 1 and hi == len(candidates) - 1:
                    eff_to = float(timeout)
                else:
                    eff_to = min(float(timeout), 2.0)
                try:
                    ws = _TgWsRawWebSocket.connect(str(host), domain, timeout=eff_to)
                    try:
                        with self._cfg_lock:
                            self.ws_domain_pref[dc_key] = str(domain)
                            self._bump_route_version()
                    except Exception:
                        pass
                    return ws
                except Exception as exc:
                    last_exc = exc
                    if " 30" in str(exc):
                        redirected.add(domain)
                    continue
        if domains and len(redirected) >= len(domains):
            self._ws_blacklist_add(dc_key)
        if last_exc:
            raise last_exc
        raise RuntimeError("websocket unavailable")
    def _reap_cf_dials(self, result_q, remaining, keep_ws):
        def _reap(n):
            left = int(n)
            while left > 0:
                try:
                    kind, _sni, obj = result_q.get(timeout=20.0)
                except Exception:
                    return
                left -= 1
                if kind == "ok" and obj is not None and obj is not keep_ws:
                    try:
                        obj.close()
                    except Exception:
                        pass
        try:
            threading.Thread(target=_reap, args=(int(remaining),), daemon=True, name="tgws-cf-reap").start()
        except Exception:
            pass
    @property
    def _active_provider(self):
        try:
            p = getattr(self._ap_tls, "provider", None)
            if p is not None:
                return p
        except Exception:
            pass
        return _KWS_PROVIDERS[0]

    @property
    def _active_provider_name(self):
        try:
            n = getattr(self._ap_tls, "name", None)
            if n is not None:
                return n
        except Exception:
            pass
        return _KWS_PROVIDERS[0]["name"]

    def _set_active_provider(self, provider):
        p = provider if isinstance(provider, dict) else _kws_provider(provider)
        try:
            self._ap_tls.provider = p
            self._ap_tls.name = p["name"]
        except Exception:
            pass

    def _provider_has_cred(self, provider):
        try:
            return _kws_cred_valid(_KWS_CTX[_kws_pname(provider)]["cred"]["v"])
        except Exception:
            return False

    def _sticky_provider_idx(self):
        try:
            p = self._plugin
            if p is None:
                return 0
            idx = int(p.get_setting("tgws_provider_idx", 0) or 0)
            if 0 <= idx < len(_KWS_PROVIDERS):
                return idx
        except Exception:
            pass
        return 0

    def _persist_provider_idx(self, name):
        try:
            p = self._plugin
            if p is None:
                return
            idx = next((i for i, pr in enumerate(_KWS_PROVIDERS) if pr["name"] == name), 0)
            if int(self._sticky_provider_idx()) != int(idx):
                p.set_setting("tgws_provider_idx", int(idx), reload_settings=False)
        except Exception:
            pass

    def _warm_provider(self):
        try:
            sp = _KWS_PROVIDERS[self._sticky_provider_idx()]
            if self._provider_has_cred(sp):
                return sp
        except Exception:
            pass
        for pr in _KWS_PROVIDERS:
            try:
                if self._provider_has_cred(pr):
                    return pr
            except Exception:
                pass
        return None

    def _cf_provider_order(self, dc=None, is_media=False):
        mode = "auto"
        try:
            p = getattr(self, "_plugin", None)
            if p is not None:
                mode = str(p.get_setting("tgws_provider_mode", "auto") or "auto").strip().lower()
        except Exception:
            mode = "auto"
        if mode in ("nimarko", "th3", "lte"):
            forced = [pr for pr in _KWS_PROVIDERS if pr.get("name") == mode]
            if forced:
                if self._provider_has_cred(forced[0]):
                    return forced
                return forced + [pr for pr in _KWS_PROVIDERS if pr.get("name") != mode]
        order = [pr for pr in _KWS_PROVIDERS if not pr.get("manual")]
        if dc is None:
            return order
        if _kws_ever_authed["v"]:
            return order
        try:
            hot = [pr for pr in order if self._ws_pool_count(dc, is_media, pr["name"]) > 0]
            if hot:
                hot_names = {pr["name"] for pr in hot}
                return hot + [pr for pr in order if pr["name"] not in hot_names]
        except Exception:
            pass
        return order

    def _connect_ws_cf(self, dc, is_media, timeout):
        last_exc = None
        order = self._cf_provider_order(dc, is_media)
        forced_mode = None
        try:
            _p = getattr(self, "_plugin", None)
            if _p is not None:
                _fm = str(_p.get_setting("tgws_provider_mode", "auto") or "auto").strip().lower()
                if _fm in ("nimarko", "th3", "lte"):
                    forced_mode = _fm
        except Exception:
            forced_mode = None
        for pidx, provider in enumerate(order):
            if self.stop_event.is_set():
                break
            self._set_active_provider(provider)
            pname = self._active_provider_name
            has_cred = self._provider_has_cred(provider)
            trickle = False
            if not has_cred:
                try:
                    _kws_prefetch_async(provider)
                except Exception:
                    pass
                if forced_mode == provider.get("name") and not has_cred:
                    try:
                        _ns = bool(_kws_slot(provider)["needs_sub"]["v"])
                    except Exception:
                        _ns = False
                    if not _ns and _kws_wait_cred(provider, 5.0):
                        has_cred = True
                if provider.get("allow_trickle") and _kws_grace_active():
                    if _kws_wait_cred(provider, 4.0):
                        has_cred = True
                if not has_cred:
                    if not provider.get("allow_trickle"):
                        continue
                    trickle = True
            eff_timeout = float(timeout) if pidx == len(order) - 1 else min(float(timeout), 2.0)
            try:
                ws = self._connect_ws_cf_one(dc, is_media, eff_timeout)
            except Exception as exc:
                last_exc = exc
                continue
            if ws is not None:
                if has_cred:
                    _kws_on_trickle["v"] = False
                    self._persist_provider_idx(pname)
                    _kws_last_provider["name"] = pname
                    _kws_last_provider["trickle"] = False
                elif trickle:
                    _kws_on_trickle["v"] = True
                    _kws_last_provider["name"] = pname
                    _kws_last_provider["trickle"] = True
                try:
                    plugin = getattr(self, "_plugin", None)
                    if plugin is not None:
                        plugin._on_provider_connected(pname)
                except Exception:
                    pass
                return ws
        if last_exc:
            raise last_exc
        raise RuntimeError("cf websocket unavailable")

    def _connect_ws_cf_one(self, dc, is_media, timeout):
        pname = self._active_provider_name
        try:
            spare = self._ws_pool_get(dc, is_media, pname)
            if spare is not None:
                try:
                    self._warm_kick.set()
                except Exception:
                    pass
                return spare
        except Exception:
            pass
        candidates = self._cf_candidates(dc, is_media)
        if not candidates:
            raise RuntimeError("cf websocket unavailable")
        path = "/apiws?dc=" + str(int(dc or 0))
        headers = _kws_auth_headers(pname)
        result_q = queue.Queue()
        stop_dial = threading.Event()
        def _dial(connect_host, sni_host):
            ws = None
            try:
                ws = _TgWsRawWebSocket.connect(connect_host, sni_host, timeout=timeout, path=path, extra_headers=headers)
            except Exception as exc:
                result_q.put(("err", sni_host, exc))
                return
            if stop_dial.is_set():
                try:
                    ws.close()
                except Exception:
                    pass
                result_q.put(("late", sni_host, None))
                return
            result_q.put(("ok", sni_host, ws))
        try:
            race_n = min(max(1, int(TGWS_WS_CF_RACE_N)), len(candidates))
        except Exception:
            race_n = min(2, len(candidates))
        launched = 0
        for connect_host, sni_host in candidates[:race_n]:
            if self.stop_event.is_set():
                break
            threading.Thread(target=_dial, args=(connect_host, sni_host), daemon=True, name="tgws-cf-dial").start()
            launched += 1
            if launched < race_n:
                if self.stop_event.wait(max(0.0, float(TGWS_WS_CF_RACE_STAGGER_SEC))):
                    break
        winner_ws = None
        winner_host = None
        last_exc = None
        remaining = launched
        while remaining > 0 and winner_ws is None:
            try:
                kind, sni_host, obj = result_q.get(timeout=float(timeout) + 0.5)
            except Exception:
                break
            remaining -= 1
            if kind == "ok":
                winner_ws = obj
                winner_host = sni_host
                stop_dial.set()
                break
            if kind == "err":
                last_exc = obj
                try:
                    if _tgws_exc_is_host_down(obj):
                        self._relay_note_fail(sni_host)
                    _kws_note_ws_failure(pname, obj)
                except Exception:
                    pass
        if winner_ws is None:
            stop_dial.set()
            for connect_host, sni_host in candidates[race_n:]:
                if self.stop_event.is_set():
                    break
                try:
                    winner_ws = _TgWsRawWebSocket.connect(connect_host, sni_host, timeout=timeout, path=path, extra_headers=headers)
                    winner_host = sni_host
                    break
                except Exception as exc:
                    last_exc = exc
                    try:
                        if _tgws_exc_is_host_down(exc):
                            self._relay_note_fail(sni_host)
                        _kws_note_ws_failure(pname, exc)
                    except Exception:
                        pass
                    continue
        if remaining > 0:
            self._reap_cf_dials(result_q, remaining, winner_ws)
        if winner_ws is not None:
            try:
                self._relay_note_ok(winner_host)
            except Exception:
                pass
            try:
                base = str(winner_host).split(".", 1)[1]
                if base:
                    with self._cfg_lock:
                        self._cf_pref[int(dc)] = base
                        self._bump_route_version()
            except Exception:
                pass
            return winner_ws
        if last_exc:
            raise last_exc
        raise RuntimeError("cf websocket unavailable")
    def _bridge_tcp_reencrypt(self, client, remote, ctx):
        done = threading.Event()
        def _client_to_remote():
            recv = client.recv
            cu = _tgws_cipher_update
            cd = ctx.clt_dec
            te = ctx.tg_enc
            sendall = remote.sendall
            try:
                while not done.is_set():
                    chunk = recv(TGWS_RECV_CHUNK)
                    if not chunk:
                        break
                    plain = cu(cd, chunk)
                    out = cu(te, plain)
                    if out:
                        sendall(out)
            except Exception:
                pass
            try:
                done.set()
            except Exception:
                pass
            try:
                self._close_write(remote)
            except Exception:
                pass
        def _remote_to_client():
            recv = remote.recv
            cu = _tgws_cipher_update
            td = ctx.tg_dec
            ce = ctx.clt_enc
            sendall = client.sendall
            try:
                while not done.is_set():
                    chunk = recv(TGWS_RECV_CHUNK)
                    if not chunk:
                        break
                    plain = cu(td, chunk)
                    out = cu(ce, plain)
                    if out:
                        sendall(out)
            except Exception:
                pass
            try:
                done.set()
            except Exception:
                pass
            try:
                self._close_write(client)
            except Exception:
                pass
        t1 = threading.Thread(target=_client_to_remote, daemon=True)
        t2 = threading.Thread(target=_remote_to_client, daemon=True)
        t1.start(); t2.start()
        try:
            while not done.is_set() and (t1.is_alive() or t2.is_alive()):
                done.wait(0.25)
        except Exception:
            pass
        done.set()
        for t in (t1, t2):
            try:
                if t.is_alive():
                    t.join(0.5)
            except Exception:
                pass
        for item in (client, remote):
            try:
                item.close()
            except Exception:
                pass
            try:
                self._untrack(item)
            except Exception:
                pass
    def _bridge_ws_reencrypt(self, client, ws, ctx, splitter):
        done = threading.Event()
        def _client_to_ws():
            recv = client.recv
            cu = _tgws_cipher_update
            cd = ctx.clt_dec
            te = ctx.tg_enc
            sp = splitter
            send = ws.send
            send_batch = ws.send_batch
            try:
                while not done.is_set():
                    chunk = recv(TGWS_RECV_CHUNK)
                    if not chunk:
                        if sp is not None:
                            try:
                                tail = sp.flush() if hasattr(sp, "flush") else []
                            except Exception:
                                tail = []
                            for p in list(tail or []):
                                try:
                                    send(p)
                                except Exception:
                                    break
                        break
                    plain = cu(cd, chunk)
                    data = cu(te, plain)
                    if not data:
                        continue
                    if sp is not None:
                        parts = sp.split(data)
                        if not parts:
                            continue
                        if len(parts) > 1:
                            try:
                                send_batch(parts)
                            except Exception:
                                for p in parts:
                                    send(p)
                        else:
                            send(parts[0])
                    else:
                        send(data)
            except Exception:
                pass
            try:
                done.set()
            except Exception:
                pass
        def _ws_to_client():
            recv = ws.recv
            cu = _tgws_cipher_update
            td = ctx.tg_dec
            ce = ctx.clt_enc
            sendall = client.sendall
            idle = 0
            if TGWS_BRIDGE_KEEPALIVE:
                try:
                    ws.sock.settimeout(float(TGWS_BRIDGE_IDLE_PING_SEC))
                except Exception:
                    pass
            try:
                while not done.is_set():
                    try:
                        payload = recv()
                    except socket.timeout:
                        if not TGWS_BRIDGE_KEEPALIVE:
                            break
                        if not ws.ping():
                            break
                        pong0 = float(getattr(ws, "_last_pong_ts", 0.0) or 0.0)
                        probe = None
                        try:
                            ws.sock.settimeout(float(TGWS_BRIDGE_PONG_WAIT_SEC))
                            probe = ws.recv()
                        except socket.timeout:
                            probe = None
                        except Exception:
                            break
                        finally:
                            try:
                                ws.sock.settimeout(float(TGWS_BRIDGE_IDLE_PING_SEC))
                            except Exception:
                                pass
                        if probe:
                            payload = probe
                            idle = 0
                        elif float(getattr(ws, "_last_pong_ts", 0.0) or 0.0) > pong0:
                            idle += 1
                            if idle >= int(TGWS_BRIDGE_MAX_IDLE):
                                break
                            continue
                        else:
                            break
                    except Exception:
                        break
                    if not payload:
                        break
                    idle = 0
                    plain = cu(td, payload)
                    out = cu(ce, plain)
                    if out:
                        sendall(out)
            except Exception:
                pass
            try:
                done.set()
            except Exception:
                pass
        t1 = threading.Thread(target=_client_to_ws, daemon=True)
        t2 = threading.Thread(target=_ws_to_client, daemon=True)
        t1.start(); t2.start()
        try:
            while not done.is_set() and (t1.is_alive() or t2.is_alive()):
                done.wait(0.25)
        except Exception:
            pass
        done.set()
        for t in (t1, t2):
            try:
                if t.is_alive():
                    t.join(0.5)
            except Exception:
                pass
        try:
            ws.close()
        except Exception:
            pass
        try:
            client.close()
        except Exception:
            pass
        try:
            self._untrack(ws)
        except Exception:
            pass
        try:
            self._untrack(client)
        except Exception:
            pass
    def _tcp_fallback_reencrypt(self, client, dc, relay_init, ctx):
        try:
            dc_eff = int(TGWS_DC_OVERRIDES.get(int(dc), int(dc)))
        except Exception:
            dc_eff = int(dc or 0)
        dst = str(TGWS_DIRECT_DC_IP.get(int(dc or 0), "") or TGWS_DIRECT_DC_IP.get(int(dc_eff), "") or "").strip()
        if not dst:
            dst = str((self.dc_ip or {}).get(str(dc), "") or (self.dc_ip or {}).get(str(dc_eff), "") or "").strip()
        if not dst:
            return False
        remote = None
        try:
            remote = socket.create_connection((dst, 443), 10.0)
            self._track(remote)
            remote.sendall(bytes(relay_init or b""))
            self._bridge_tcp_reencrypt(client, remote, ctx)
            return True
        except Exception:
            try:
                client.close()
            except Exception:
                pass
            if remote is not None:
                try:
                    self._untrack(remote)
                except Exception:
                    pass
                try:
                    remote.close()
                except Exception:
                    pass
            return False
    def _handle_client(self, conn):
        try:
            conn.settimeout(10.0)
            init_packet = _tgws_recv_exact(conn, TGWS_HANDSHAKE_LEN)
            conn.settimeout(None)
            result = _tgws_try_mtproto_handshake(init_packet, self.secret_bytes)
            if result is None:
                return
            dc, is_media, proto_int, proto_tag, client_dec_prekey_iv = result
            self._note_active_key(dc, is_media)
            relay_dc_idx = -int(dc) if bool(is_media) else int(dc)
            relay_init = _tgws_generate_relay_init(proto_tag, relay_dc_idx)
            ctx = _tgws_build_crypto_ctx(client_dec_prekey_iv, self.secret_bytes, relay_init)
            target_ip = str((self.dc_ip or {}).get(str(dc), "") or "").strip()
            dc_key = self._ws_pool_key(dc, is_media)
            ws = None
            for idx, lane in enumerate(self._ordered_lanes(dc_key)):
                if lane == "direct" and not target_ip:
                    continue
                fk = self._lane_fail_key(dc_key, lane)
                if self._ws_is_blacklisted(fk):
                    continue
                timeout = self._ws_fail_timeout(fk)
                try:
                    if lane == "cf":
                        ws = self._connect_ws_cf(dc, is_media, timeout)
                    else:
                        ws = self._connect_ws_direct(dc, is_media, target_ip, timeout)
                except Exception:
                    ws = None
                if ws is not None:
                    self._ws_fail_clear(fk)
                    self._lane_record_success(dc_key, lane)
                    break
                self._ws_fail_record(fk)
            if ws is None:
                try:
                    self._tcp_fallback_reencrypt(conn, dc, relay_init, ctx)
                except Exception:
                    pass
                return
            self._track(ws)
            try:
                ws.send(relay_init)
                splitter = None
                try:
                    splitter = _TgWsMsgSplitter(relay_init, proto_int)
                except Exception:
                    splitter = None
                self._bridge_ws_reencrypt(conn, ws, ctx, splitter)
            except Exception:
                try:
                    ws.close()
                except Exception:
                    pass
                try:
                    self._untrack(ws)
                except Exception:
                    pass
            return
        except Exception:
            pass
        finally:
            try:
                conn.close()
            except Exception:
                pass
            try:
                self._untrack(conn)
            except Exception:
                pass
_tgws_enabled = {"v": False}
_tgws_sub_channel = "th3nek1t_projects"

_KWS_PROVIDERS = [
    {"name": "nimarko", "api": "https://calls.nimarko.org", "relays": ["r1.nimarko.org"], "allow_trickle": False},
    {"name": "th3",     "api": "https://kws.th3web.com",     "relays": ["ws.th3web.com"],  "allow_trickle": True},
    {"name": "lte",     "api": "https://kwszh.th3web.com",   "relays": ["wszh.th3web.com"], "allow_trickle": False, "manual": True},
]

_KWS_API = _KWS_PROVIDERS[0]["api"]
_TGWS_RELAY_HOSTS = list(_KWS_PROVIDERS[0]["relays"])

def _kws_new_ctx():
    return {
        "cred": {"v": None},
        "token": {"v": None},
        "needs_sub": {"v": False},
        "bot_username": {"v": None},
        "prefetch_inflight": [False],
        "recheck_inflight": [False],
    }

_KWS_CTX = {p["name"]: _kws_new_ctx() for p in _KWS_PROVIDERS}

_kws_lock = threading.RLock()
_kws_guard_lock = threading.Lock()
_kws_refresh_stop = threading.Event()

_kws_needs_sub = {"v": False}
_kws_on_trickle = {"v": False}
_kws_ever_authed = {"v": False}
_kws_plugin = {"p": None}
_kws_grace = {"until": 0.0}
_KWS_GRACE_SEC = 14 * 86400
_kws_th3_403 = {"n": 0, "first": 0.0}
_kws_ws403 = {}
_kws_last_provider = {"name": None, "trickle": False}
def _kws_provider_display(name):
    return {"nimarko": "Nimarko", "th3": "Th3Nekit", "lte": "LeanVPN Premium"}.get(str(name or ""), str(name or "—"))
_kws_sub_cb = {"fn": None}
_KWS_POLL_SCHEDULE = [0.3, 0.5, 0.8, 1.0, 1.0, 1.5, 2.0, 2.0, 3.0, 3.0, 4.0, 4.0]
_KWS_REFRESH_WINDOW_SEC = 1200

def _kws_provider(name):
    if isinstance(name, dict):
        return name
    for p in _KWS_PROVIDERS:
        if p["name"] == name:
            return p
    return _KWS_PROVIDERS[0]

def _kws_pname(provider):
    try:
        return provider["name"] if isinstance(provider, dict) else str(provider)
    except Exception:
        return _KWS_PROVIDERS[0]["name"]

def _kws_slot(provider):
    ctx = _KWS_CTX.get(_kws_pname(provider))
    if ctx is None:
        ctx = _KWS_CTX[_KWS_PROVIDERS[0]["name"]]
    return ctx

def _kws_grace_active():
    try:
        return bool(_kws_ever_authed["v"]) or float(_kws_grace["until"]) > time.time()
    except Exception:
        return False

def _kws_persist_proof(provider, cred):
    p = _kws_plugin["p"]
    if p is None:
        return
    try:
        _kws_grace["until"] = time.time() + float(_KWS_GRACE_SEC)
        p.set_setting("kws_ever_authed", True, reload_settings=False)
        p.set_setting("kws_grace_until", float(_kws_grace["until"]), reload_settings=False)
        p.set_setting("kws_cred_" + _kws_pname(provider), json.dumps(cred), reload_settings=False)
    except Exception:
        pass

def _kws_clear_proof():
    _kws_grace["until"] = 0.0
    _kws_ever_authed["v"] = False
    p = _kws_plugin["p"]
    if p is not None:
        try:
            p.set_setting("kws_ever_authed", False, reload_settings=False)
            p.set_setting("kws_grace_until", 0.0, reload_settings=False)
        except Exception:
            pass

def _kws_note_th3_403():
    try:
        now = time.time()
        if _kws_th3_403["n"] == 0:
            _kws_th3_403["first"] = now
        _kws_th3_403["n"] += 1
        if _kws_th3_403["n"] >= 3 and (now - _kws_th3_403["first"]) > 600.0:
            _kws_th3_403["n"] = 0
            _kws_th3_403["first"] = 0.0
            _kws_clear_proof()
    except Exception:
        pass

def _kws_wait_cred(provider, timeout=4.0):
    try:
        end = time.time() + float(timeout)
        slot = _kws_slot(provider)
        while time.time() < end:
            if _kws_cred_valid(slot["cred"]["v"]):
                return True
            time.sleep(0.05)
    except Exception:
        pass
    return False

def _kws_restore_proof(p):
    _kws_plugin["p"] = p
    try:
        _kws_grace["until"] = float(p.get_setting("kws_grace_until", 0.0) or 0.0)
        if bool(p.get_setting("kws_ever_authed", False)) and _kws_grace["until"] > time.time():
            _kws_ever_authed["v"] = True
    except Exception:
        pass
    for pr in _KWS_PROVIDERS:
        try:
            cj = p.get_setting("kws_cred_" + pr["name"], "")
            if cj:
                c = json.loads(cj)
                if isinstance(c, dict) and c.get("hmac"):
                    _kws_slot(pr)["cred"]["v"] = c
        except Exception:
            pass

def _kws_set_needs_sub(v, provider=None):
    v = bool(v)
    if provider is not None:
        try:
            _kws_slot(provider)["needs_sub"]["v"] = v
        except Exception:
            pass
    try:
        reconciled = not any(_kws_cred_valid(_kws_slot(p)["cred"]["v"]) for p in _KWS_PROVIDERS)
        if reconciled:
            reconciled = bool(_kws_slot("th3")["needs_sub"]["v"])
    except Exception:
        reconciled = v
    if _kws_grace_active():
        reconciled = False
    elif reconciled:
        try:
            if any(_kws_slot(p)["prefetch_inflight"][0] or _kws_slot(p)["recheck_inflight"][0] for p in _KWS_PROVIDERS):
                reconciled = False
        except Exception:
            pass
    prev = _kws_needs_sub["v"]
    _kws_needs_sub["v"] = reconciled
    if prev != reconciled:
        fn = _kws_sub_cb["fn"]
        if fn:
            try:
                fn(reconciled)
            except Exception:
                pass

def _kws_current_account():
    try:
        return UserConfig.selectedAccount
    except Exception:
        return 0

def _kws_uid(account):
    try:
        return int(UserConfig.getInstance(account).getClientUserId())
    except Exception:
        return 0

def _kws_cred_valid(c):
    try:
        if not (bool(c) and c.get("hmac") and int(c.get("expiry", 0)) - 60 > int(time.time())):
            return False
        return int(c.get("uid", -1)) == int(_kws_uid(_kws_current_account()))
    except Exception:
        return False

def _kws_auth_headers(provider):
    slot = _kws_slot(provider)
    try:
        c = slot["cred"]["v"]
        if _kws_cred_valid(c):
            return {"X-Cred": "%d:%d:%s" % (int(c["expiry"]), int(c["uid"]), str(c["hmac"]))}
    except Exception:
        pass
    try:
        _kws_prefetch_async(provider)
    except Exception:
        pass
    return {}

def _kws_store_cred(provider, cred):
    slot = _kws_slot(provider)
    try:
        if isinstance(cred, dict):
            cred["_set_ts"] = time.time()
            _kws_ever_authed["v"] = True
            _kws_persist_proof(provider, cred)
        with _kws_lock:
            slot["cred"]["v"] = cred
        if isinstance(cred, dict):
            prev_gate = _kws_needs_sub["v"]
            _kws_set_needs_sub(False, provider)
            if (not prev_gate) and _kws_on_trickle["v"] and _kws_cred_valid(cred):
                fn = _kws_sub_cb["fn"]
                if fn:
                    try:
                        fn(False)
                    except Exception:
                        pass
    except Exception:
        slot["cred"]["v"] = cred

def _kws_note_ws_failure(provider, exc):
    try:
        if _tgws_exc_is_host_down(exc):
            return
        s = str(exc or "")
        if " 401 " not in s and " 403 " not in s:
            return
        slot = _kws_slot(provider)
        c = slot["cred"]["v"]
        try:
            if isinstance(c, dict):
                ts = float(c.get("_set_ts", 0.0) or 0.0)
                if ts and (time.time() - ts) < 5.0:
                    _kws_recheck_async(provider)
                    return
        except Exception:
            pass
        pn = _kws_pname(provider)
        now = time.time()
        hist = [t for t in _kws_ws403.get(pn, []) if now - t < 60.0]
        hist.append(now)
        _kws_ws403[pn] = hist
        if len(hist) >= 3:
            _kws_ws403[pn] = []
            slot["cred"]["v"] = None
        _kws_recheck_async(provider)
    except Exception:
        pass

def _kws_send_inline_verification(account, bot_username, code):
    def do_send():
        try:
            manager = ConnectionsManager.getInstance(int(account))
            if manager is None:
                return False
            rq = TLRPC.TL_contacts_resolveUsername()
            rq.username = str(bot_username or "").lstrip("@")
            def on_resolve(r, e):
                try:
                    if e or not r or not getattr(r, "users", None) or r.users.size() == 0:
                        return
                    bot_user = r.users.get(0)
                    req = TLRPC.TL_messages_getInlineBotResults()
                    iu = TLRPC.TL_inputUser()
                    iu.user_id = bot_user.id
                    iu.access_hash = bot_user.access_hash
                    req.bot = iu
                    req.query = str(code or "")
                    req.offset = ""
                    req.peer = TLRPC.TL_inputPeerEmpty()
                    manager.sendRequest(req, RequestCallback(lambda r2, e2: None))
                except Exception:
                    pass
            manager.sendRequest(rq, RequestCallback(on_resolve))
            return True
        except Exception:
            return False
    return bool(do_send())

def _kws_http_register(provider, uid):
    p = _kws_provider(provider)
    try:
        r = requests.post(p["api"] + "/api/v1/kws/register?user_id=" + str(uid), timeout=15, verify=_CA_BUNDLE)
        if r.status_code != 200:
            return None
        o = r.json()
        bot = o.get("bot_username")
        try:
            if bot:
                _kws_slot(provider)["bot_username"]["v"] = str(bot)
        except Exception:
            pass
        return (o.get("code"), bot)
    except Exception:
        return None

def _kws_http_poll(provider, uid, code):
    p = _kws_provider(provider)
    try:
        r = requests.post(p["api"] + "/api/v1/kws/poll?user_id=" + str(uid) + "&code=" + str(code), timeout=15, verify=_CA_BUNDLE)
        if r.status_code == 200:
            t = r.json().get("token", "")
            return t or None
        if r.status_code == 202:
            return None
        return "__give_up__"
    except Exception:
        return None

def _kws_http_credential(provider, token):
    p = _kws_provider(provider)
    try:
        r = requests.post(p["api"] + "/api/v1/kws/credential",
                          headers={"X-Auth-Token": token, "X-KWS-V": "2"},
                          timeout=15, verify=_CA_BUNDLE)
        if r.status_code == 403:
            if _kws_pname(provider) == "th3":
                _kws_note_th3_403()
            _kws_set_needs_sub(True, provider)
            return None
        if r.status_code != 200:
            return None
        o = r.json()
        if not o.get("hmac"):
            return None
        if _kws_pname(provider) == "th3":
            _kws_th3_403["n"] = 0
            _kws_th3_403["first"] = 0.0
        _kws_set_needs_sub(False, provider)
        return {"expiry": int(o["expiry"]), "uid": int(o["uid"]), "hmac": str(o["hmac"])}
    except Exception:
        return None

def _kws_schedule_prefetch(provider, delay_sec=4.0):
    def _fire():
        try:
            time.sleep(float(delay_sec))
        except Exception:
            pass
        try:
            _kws_prefetch_async(provider)
        except Exception:
            pass
    try:
        threading.Thread(target=_fire, daemon=True, name="kws-rearm").start()
    except Exception:
        pass

def _tt(ru, en):
    try:
        return ru if _is_ru_language() else en
    except Exception:
        return en

def _kws_mint_for_account(provider, account):
    uid = _kws_uid(account)
    if not uid:
        return None
    reg = _kws_http_register(provider, uid)
    if not reg or not reg[0]:
        return None
    code, bot_username = reg
    if not _kws_send_inline_verification(account, bot_username, code):
        return None
    token = None
    for delay in _KWS_POLL_SCHEDULE:
        token = _kws_http_poll(provider, uid, code)
        if token == "__give_up__":
            return "__give_up__"
        if token:
            break
        time.sleep(float(delay))
    if not token or token == "__give_up__":
        return None
    cred = _kws_http_credential(provider, token)
    if cred:
        _kws_slot(provider)["token"]["v"] = token
    return cred

def _kws_lte_account():
    try:
        p = _kws_plugin["p"]
        if p is not None:
            ac = int(p.get_setting("tgws_lte_account", -1))
            if 0 <= ac < int(UserConfig.MAX_ACCOUNT_COUNT) and _kws_uid(ac):
                return ac
    except Exception:
        pass
    return _kws_current_account()

def _kws_mark_lte_entitled(account):
    try:
        p = _kws_plugin["p"]
        if p is not None:
            p.set_setting("tgws_lte_entitled", "1", reload_settings=False)
            p.set_setting("tgws_lte_account", int(account), reload_settings=False)
    except Exception:
        pass

def _kws_lte_entitled():
    try:
        p = _kws_plugin["p"]
        if p is not None and str(p.get_setting("tgws_lte_entitled", "") or "") == "1":
            return True
    except Exception:
        pass
    try:
        return _kws_cred_valid(_kws_slot("lte")["cred"]["v"])
    except Exception:
        return False

def _kws_ensure(provider):
    slot = _kws_slot(provider)
    if _kws_cred_valid(slot["cred"]["v"]):
        return
    with _kws_guard_lock:
        if slot["prefetch_inflight"][0]:
            return
        slot["prefetch_inflight"][0] = True
    try:
        if _kws_cred_valid(slot["cred"]["v"]):
            return
        is_lte = _kws_pname(provider) == "lte"
        account = _kws_lte_account() if is_lte else _kws_current_account()
        if not _kws_uid(account):
            _kws_schedule_prefetch(provider, 4.0)
            return
        cred = _kws_mint_for_account(provider, account)
        if cred == "__give_up__":
            return
        if cred:
            _kws_store_cred(provider, cred)
            if is_lte:
                _kws_mark_lte_entitled(account)
        else:
            _kws_schedule_prefetch(provider, 4.0)
    finally:
        with _kws_guard_lock:
            slot["prefetch_inflight"][0] = False

def _kws_recheck(provider):
    slot = _kws_slot(provider)
    tok = slot["token"]["v"]
    if not tok:
        _kws_ensure(provider)
        return
    cred = _kws_http_credential(provider, tok)
    if cred:
        _kws_store_cred(provider, cred)
    else:
        slot["token"]["v"] = None
        _kws_ensure(provider)

def _kws_recheck_async(provider):
    slot = _kws_slot(provider)
    with _kws_guard_lock:
        if slot["recheck_inflight"][0]:
            return
        slot["recheck_inflight"][0] = True
    def run():
        try:
            _kws_recheck(provider)
        except Exception:
            pass
        finally:
            with _kws_guard_lock:
                slot["recheck_inflight"][0] = False
    threading.Thread(target=run, daemon=True, name="kws-recheck").start()

def _kws_prefetch_async(provider):
    slot = _kws_slot(provider)
    if _kws_cred_valid(slot["cred"]["v"]):
        return
    with _kws_guard_lock:
        if slot["prefetch_inflight"][0]:
            return
    threading.Thread(target=_kws_ensure, args=(provider,), daemon=True, name="kws-auth").start()

def _kws_prefetch_all():
    for p in _KWS_PROVIDERS:
        if p.get("manual"):
            continue
        try:
            _kws_prefetch_async(p)
        except Exception:
            pass

def _kws_recheck_all():
    for p in _KWS_PROVIDERS:
        try:
            _kws_recheck(p)
        except Exception:
            pass

def _kws_start_refresh_loop(is_enabled=None):
    global _kws_refresh_stop
    try:
        _kws_refresh_stop.set()
    except Exception:
        pass
    _kws_refresh_stop = threading.Event()
    stop = _kws_refresh_stop
    def _loop():
        while not stop.is_set():
            try:
                if is_enabled is None or is_enabled():
                    for p in _KWS_PROVIDERS:
                        slot = _kws_slot(p)
                        c = slot["cred"]["v"]
                        if _kws_cred_valid(c):
                            try:
                                ttl = int(c.get("expiry", 0)) - int(time.time())
                            except Exception:
                                ttl = 10 ** 9
                            if ttl < int(_KWS_REFRESH_WINDOW_SEC):
                                if slot["token"]["v"]:
                                    _kws_recheck_async(p)
                                else:
                                    _kws_prefetch_async(p)
                        else:
                            if not p.get("manual"):
                                _kws_prefetch_async(p)
            except Exception:
                pass
            stop.wait(60)
    threading.Thread(target=_loop, daemon=True, name="kws-refresh").start()

class TgWsProxyPlugin(BasePlugin):
    def _parse_version(self, v):
        try:
            return tuple(map(int, str(v).split(".")))
        except Exception:
            return (0,)

    def check_for_update(self, silent=False):
        api_url = _UPDATE_MANIFEST_URL
        ua = {"User-Agent": f"wsbypass-updater/{__version__}"}
        try:
            r = requests.get(api_url, timeout=10, verify=_CA_BUNDLE, headers=ua)
            r.raise_for_status()
            info = r.json() or {}
        except Exception as e:
            if not silent:
                run_on_ui_thread(
                    lambda err=e: BulletinHelper.show_error(f"Не удалось проверить обновления: {err}")
                )
            return

        latest = str(info.get("version") or "").strip()
        if not latest:
            if not silent:
                run_on_ui_thread(lambda: BulletinHelper.show_error("Не удалось получить версию"))
            return

        if self._parse_version(latest) <= self._parse_version(__version__):
            try:
                self._pending_update = None
            except Exception:
                pass
            if not silent:
                run_on_ui_thread(
                    lambda: BulletinHelper.show_info(f"У вас актуальная версия: {__version__}")
                )
                run_on_ui_thread(self._reload_settings_ui)
            return

        self._pending_update = {
            "version": latest,
            "url": info.get("url"),
            "sha256": (info.get("sha256") or "").lower().strip() or None,
            "sig": info.get("sig") or None,
            "changelog": info.get("changelog") or "",
            "min_app_version": info.get("min_app_version") or "",
        }
        run_on_ui_thread(
            lambda v=latest: BulletinHelper.show_info(
                f"Доступна версия {v} — нажмите «Установить обновление»"
            )
        )
        run_on_ui_thread(self._reload_settings_ui)

    def _on_install_update_clicked(self, v=None):
        try:
            run_on_queue(self._do_install_update)
        except Exception:
            try:
                threading.Thread(
                    target=self._do_install_update,
                    name="wsbypass-update-install",
                    daemon=True,
                ).start()
            except Exception:
                pass

    @staticmethod
    def _update_url_host(url):
        try:
            s = str(url or "")
            i = s.find("://")
            if i >= 0:
                s = s[i + 3:]
            for sep in ("/", "?", "#"):
                j = s.find(sep)
                if j >= 0:
                    s = s[:j]
            if "@" in s:
                return ""
            s = s.split(":", 1)[0]
            return s.strip().lower()
        except Exception:
            return ""

    def _do_install_update(self):
        pending = getattr(self, "_pending_update", None)
        if not pending:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Нет обновления для установки"))
            return
        latest = str(pending.get("version") or "").strip()
        plugin_url = str(pending.get("url") or "")
        expected_sha = pending.get("sha256")
        ua = {"User-Agent": f"wsbypass-updater/{__version__}"}

        if not plugin_url.lower().startswith("https://"):
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(
                    "Небезопасный адрес обновления — отклонено"
                )
            )
            return
        _host = self._update_url_host(plugin_url)
        if _host not in _UPDATE_HOST_ALLOW:
            run_on_ui_thread(
                lambda h=_host: BulletinHelper.show_error(
                    f"Недоверенный источник обновления ({h}) — отклонено"
                )
            )
            return

        try:
            d = requests.get(plugin_url, timeout=30, verify=_CA_BUNDLE, headers=ua)
            d.raise_for_status()
            payload = d.content
        except Exception as e:
            run_on_ui_thread(
                lambda err=e: BulletinHelper.show_error(f"Не удалось скачать обновление: {err}")
            )
            return

        if not payload:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Пустой ответ сервера"))
            return

        if not expected_sha:
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(
                    "Нет контрольной суммы — обновление отклонено"
                )
            )
            return
        actual_sha = hashlib.sha256(payload).hexdigest()
        if actual_sha != expected_sha:
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(
                    "Хеш не совпал — обновление отклонено"
                )
            )
            return

        if not _ED25519_SELFTEST_OK:
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(
                    "Проверка подписи недоступна — обновление отклонено"
                )
            )
            return
        sig_b64 = pending.get("sig")
        if not sig_b64:
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(
                    "Нет подписи — обновление отклонено"
                )
            )
            return
        try:
            _pubkey = base64.b64decode(_UPDATE_PUBKEY_B64)
            _sig = base64.b64decode(sig_b64)
        except Exception:
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(
                    "Повреждённая подпись — обновление отклонено"
                )
            )
            return
        if ed25519_verify(_pubkey, payload, _sig) is not True:
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(
                    "Подпись неверна — обновление отклонено"
                )
            )
            return

        try:
            code = payload.decode("utf-8")
        except Exception as e:
            run_on_ui_thread(
                lambda err=e: BulletinHelper.show_error(f"Повреждённое обновление: {err}")
            )
            return

        try:
            _m = re.search(r'__version__\s*=\s*["\']([^"\']+)', code)
            _payload_ver = _m.group(1) if _m else ""
        except Exception:
            _payload_ver = ""
        if self._parse_version(_payload_ver) <= self._parse_version(__version__):
            run_on_ui_thread(
                lambda pv=_payload_ver: BulletinHelper.show_error(
                    f"Версия обновления ({pv or '?'}) не новее текущей — отклонено"
                )
            )
            return

        p = __file__
        tmp = p + ".new"
        try:
            with open(tmp, "w", encoding="utf-8") as _f:
                _f.write(code)
                _f.flush()
                try:
                    os.fsync(_f.fileno())
                except Exception:
                    pass
        except Exception as e:
            try:
                if os.path.exists(tmp):
                    os.remove(tmp)
            except Exception:
                pass
            run_on_ui_thread(
                lambda err=e: BulletinHelper.show_error(f"Не удалось записать обновление: {err}")
            )
            return
        try:
            if os.path.exists(p + ".backup"):
                os.remove(p + ".backup")
        except Exception:
            pass
        _backed_up = False
        try:
            os.rename(p, p + ".backup")
            _backed_up = True
        except Exception:
            pass
        try:
            os.replace(tmp, p)
        except Exception as e:
            try:
                if os.path.exists(tmp):
                    os.remove(tmp)
            except Exception:
                pass
            if _backed_up and not os.path.exists(p):
                try:
                    os.rename(p + ".backup", p)
                except Exception:
                    pass
            run_on_ui_thread(
                lambda err=e: BulletinHelper.show_error(f"Не удалось записать обновление: {err}")
            )
            return

        try:
            self._pending_update = None
        except Exception:
            pass
        run_on_ui_thread(
            lambda v=latest: BulletinHelper.show_success(
                f"✅ WS-Bypass обновлён до {v}!\nПерезапустите клиент!"
            )
        )
        run_on_ui_thread(self._reload_settings_ui)

    def _update_settings_items(self, _t):
        out = [Text(
            text=_t("Проверить обновления", "Check for updates"),
            icon="msg_download",
            on_click=self._on_check_update_clicked,
        )]
        out.append(Switch(
            key="tgws_update_autocheck",
            text=_t("Проверять раз в час", "Auto-check hourly"),
            default=False,
            on_change=self._on_autocheck_changed,
        ))
        pending = getattr(self, "_pending_update", None)
        if pending:
            ver = str(pending.get("version") or "")
            out.append(Text(
                text=_t(f"⬇️ Установить обновление {ver}", f"⬇️ Install update {ver}"),
                icon="msg_download",
                on_click=self._on_install_update_clicked,
            ))
        return out

    def _on_check_update_clicked(self, v=None):
        try:
            run_on_queue(self.check_for_update)
        except Exception:
            try:
                threading.Thread(
                    target=self.check_for_update,
                    name="wsbypass-update-check",
                    daemon=True,
                ).start()
            except Exception:
                pass

    def _autocheck_loop(self, stop):
        while not stop.is_set():
            if stop.wait(_UPDATE_AUTO_INTERVAL_SEC):
                break
            try:
                if bool(self.get_setting("tgws_update_autocheck", False)):
                    self.check_for_update(silent=True)
            except Exception:
                pass

    def _start_autocheck(self):
        try:
            _th = getattr(self, "_autocheck_thread", None)
            if _th is not None and _th.is_alive():
                return
        except Exception:
            pass
        try:
            self._autocheck_stop = threading.Event()
            stop = self._autocheck_stop
            self._autocheck_thread = threading.Thread(
                target=self._autocheck_loop,
                args=(stop,),
                name="wsbypass-update-autocheck",
                daemon=True,
            )
            self._autocheck_thread.start()
        except Exception:
            pass

    def _stop_autocheck(self):
        try:
            _ev = getattr(self, "_autocheck_stop", None)
            if _ev is not None:
                _ev.set()
            self._autocheck_thread = None
        except Exception:
            pass

    def _on_autocheck_changed(self, v):
        try:
            if bool(v):
                self._start_autocheck()
            else:
                self._stop_autocheck()
        except Exception:
            pass

    def _is_advanced_enabled(self) -> bool:
        return False
    def _normalize_local_host(self, raw_host) -> str:
        try:
            host = str(raw_host or "").strip()
        except Exception:
            host = ""
        if not host or host.lower() == "localhost":
            return "127.0.0.1"
        try:
            socket.inet_aton(host)
            return host
        except Exception:
            return "127.0.0.1"
    def _local_host(self) -> str:
        if not self._is_advanced_enabled():
            return "127.0.0.1"
        return self._normalize_local_host(self.get_setting("local_socks_host", "127.0.0.1"))
    def _apply_runtime_local_host(self) -> str:
        global LOCAL_PROXY_HOST
        host = self._normalize_local_host(self._local_host())
        with _TGWS_HOST_LOCK:
            LOCAL_PROXY_HOST = host
        return host
    def _normalize_local_port(self, raw_port) -> int:
        try:
            port = int(raw_port)
        except Exception:
            port = int(DEFAULT_LOCAL_PROXY_PORT)
        if port < 1024 or port > 65535:
            port = int(DEFAULT_LOCAL_PROXY_PORT)
        return int(port)
    def _is_local_port_free(self, port: int) -> bool:
        try:
            host = self._apply_runtime_local_host()
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                s.bind((host, int(port)))
            return True
        except Exception:
            return False
    def _pick_random_local_port(self) -> int:
        self._apply_runtime_local_host()
        for _ in range(48):
            try:
                p = random.randint(20000, 55000)
            except Exception:
                p = 0
            if p > 0 and self._is_local_port_free(p):
                return int(p)
        try:
            p = int(_get_free_port())
            if 1024 <= p <= 65535 and self._is_local_port_free(p):
                return int(p)
        except Exception:
            pass
        return int(DEFAULT_LOCAL_PROXY_PORT)
    def _local_port(self) -> int:
        if self._is_advanced_enabled():
            return self._normalize_local_port(self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT)))
        try:
            cached = int(getattr(self, "_runtime_random_local_port", 0) or 0)
        except Exception:
            cached = 0
        if cached > 0 and self._is_local_port_free(cached):
            return int(cached)
        p = int(self._pick_random_local_port())
        self._runtime_random_local_port = int(p)
        return int(p)
    def _wait_local_port_free(self, port: int, timeout_sec: float = 1.8) -> bool:
        deadline = time.time() + float(max(0.2, timeout_sec))
        while time.time() < deadline:
            if self._is_local_port_free(int(port)):
                return True
            time.sleep(0.08)
        return self._is_local_port_free(int(port))
    def on_plugin_load(self):
        self._state_lock = threading.RLock()
        self._tgws_core = TgWsCore(self)
        self._route_pref_saved_v = 0
        try:
            _rp = self.get_setting("route_pref", "")
            if _rp:
                self._tgws_core.import_route_pref(json.loads(_rp))
            self._route_pref_saved_v = int(self._tgws_core.route_version())
        except Exception:
            pass
        self._tgws_port = 0
        self._tgws_running = False
        self._tgws_proxy_snapshot = None
        self._tgws_proxy_managed = False
        self._tgws_last_error = ""
        self._tgws_starting = False
        self._tgws_start_seq = 0
        self._tgws_start_token = 0
        self._runtime_random_local_port = 0
        self._reload_ui_pending = False
        self._last_rendered_state = None
        self._provider_switch_target = None
        self._provider_switch_ready = False
        self._pending_update = None
        self._autocheck_stop = None
        self._autocheck_thread = None
        self._chat_menu_item_id = "tgws_settings_chat"
        self._drawer_menu_item_id = "tgws_settings_drawer"
        try:
            _adv_raw = self.get_setting("advanced_enabled", False)
            _adv_norm = bool(_adv_raw)
            if _adv_raw is None or _adv_raw != _adv_norm:
                self.set_setting("advanced_enabled", _adv_norm, reload_settings=False)
            _host_norm = self._local_host()
            if str(self.get_setting("local_socks_host", "") or "") != str(_host_norm):
                self.set_setting("local_socks_host", _host_norm, reload_settings=False)
            if self._is_advanced_enabled():
                _port_raw = self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT))
                _port_norm = self._normalize_local_port(_port_raw)
                if _port_raw != _port_norm:
                    self.set_setting(
                        "local_socks_port",
                        _port_norm,
                        reload_settings=False,
                    )
        except Exception:
            pass
        try:
            self._apply_runtime_local_host()
        except Exception:
            pass
        self._add_menu_items()
        _tgws_enabled["v"] = bool(self.get_setting("tgws_enabled", False))
        _kws_restore_proof(self)
        _kws_sub_cb["fn"] = self._on_sub_gate_changed
        _kws_start_refresh_loop(lambda: bool(self.get_setting("tgws_enabled", False)))
        self._tgws_label_hook = None
        self._tgws_fail_dialog = None
        self._tgws_fail_last_ts = 0.0
        try:
            _cell_cls = find_class("org.telegram.ui.ProxyListActivity$TextDetailProxyCell")
            if _cell_cls is not None:
                self._tgws_label_hook = self.hook_all_methods(_cell_cls, "setProxy", _TgwsProxyLabelHook())
        except Exception:
            self._tgws_label_hook = None
        try:
            self._tgws_proxyerr_hook = self.hook_all_methods(
                find_class("org.telegram.tgnet.ConnectionsManager"), "onProxyError", _TgwsProxyErrorHook(self))
        except Exception:
            self._tgws_proxyerr_hook = None
        if bool(self.get_setting("tgws_enabled", False)):
            self._start_tgws_runtime(auto_start=True, delay_ms=int(TGWS_AUTOSTART_DELAY_MS))
        try:
            if bool(self.get_setting("tgws_update_autocheck", False)):
                self._start_autocheck()
        except Exception:
            pass
    def on_plugin_unload(self):
        try:
            _lh = getattr(self, "_tgws_label_hook", None)
            if _lh is not None:
                if isinstance(_lh, list):
                    for _x in _lh:
                        try:
                            self.unhook_method(_x)
                        except Exception:
                            pass
                else:
                    self.unhook_method(_lh)
            self._tgws_label_hook = None
        except Exception:
            pass
        try:
            _peh = getattr(self, "_tgws_proxyerr_hook", None)
            if _peh is not None:
                if isinstance(_peh, list):
                    for _x in _peh:
                        try:
                            self.unhook_method(_x)
                        except Exception:
                            pass
                else:
                    self.unhook_method(_peh)
            self._tgws_proxyerr_hook = None
        except Exception:
            pass
        try:
            _kws_refresh_stop.set()
        except Exception:
            pass
        try:
            self._stop_autocheck()
        except Exception:
            pass
        try:
            self._tgws_persist_route_pref(force=True)
        except Exception:
            pass
        try:
            with self._state_lock:
                self._tgws_running = False
                self._tgws_starting = False
                self._tgws_start_seq = int(getattr(self, "_tgws_start_seq", 0) or 0) + 1
                self._tgws_start_token = int(self._tgws_start_seq)
        except Exception:
            pass
        try:
            self._tgws_core.stop()
        except Exception:
            pass
        try:
            self._tgws_restore_previous_proxy()
        except Exception:
            pass
        try:
            _apply_tg_proxy(0, False)
        except Exception:
            pass
        try:
            self._tgws_force_clear_current_proxy()
        except Exception:
            pass
        try:
            self._tgws_remove_local_from_list()
        except Exception:
            pass
        try:
            self._remove_menu_items()
        except Exception:
            pass

    def _tgws_force_clear_current_proxy(self):
        try:
            shared_config_cls = find_class("org.telegram.messenger.SharedConfig")
            if not shared_config_cls:
                return
            current = self._tgws_get_static_field(shared_config_cls, "currentProxyInfo", None)
            if current is None:
                return
            try:
                addr = str(getattr(current, "address", "") or "")
            except Exception:
                addr = ""
            if addr == LOCAL_PROXY_HOST:
                try:
                    self._tgws_set_static_field(shared_config_cls, "currentProxyInfo", None)
                except Exception:
                    pass
        except Exception:
            pass
    def on_app_event(self, event_type):
        try:
            AppEvent = find_class("com.exteragram.messenger.plugins.AppEvent")
            if not AppEvent:
                return
            if event_type in (AppEvent.START, AppEvent.RESUME):
                try:
                    with self._state_lock:
                        _running = bool(getattr(self, "_tgws_running", False))
                        _busy = _running or bool(getattr(self, "_tgws_starting", False))
                except Exception:
                    _running = bool(getattr(self, "_tgws_running", False))
                    _busy = _running or bool(getattr(self, "_tgws_starting", False))
                _enabled = bool(self.get_setting("tgws_enabled", False))
                if _enabled:
                    try:
                        _kws_prefetch_all()
                    except Exception:
                        pass
                if _enabled and _running:
                    try:
                        self._tgws_core.reset_resilience_state()
                    except Exception:
                        pass
                if _enabled and not _busy:
                    self._start_tgws_runtime(auto_start=True, delay_ms=int(TGWS_RESUME_START_DELAY_MS))
        except Exception:
            pass
    def _tgws_state_token(self):
        try:
            if not bool(self.get_setting("tgws_enabled", False)):
                return "off"
        except Exception:
            pass
        try:
            if bool(getattr(self, "_tgws_running", False)):
                return "running"
            if bool(getattr(self, "_tgws_starting", False)):
                return "starting"
            return "failed"
        except Exception:
            return "starting"
    def create_settings(self):
        def _t(ru, en):
            try:
                return ru if _is_ru_language() else en
            except Exception:
                return en

        enabled = bool(self.get_setting("tgws_enabled", False))

        items = [
            Header(text=_t("Главное", "General")),
            Switch(
                key="tgws_enabled",
                text=_t("Включить туннель", "Enable tunnel"),
                default=False,
                on_change=self._on_enabled_changed,
            ),
        ]

        _pm = str(self.get_setting("tgws_provider_mode", "auto") or "auto").strip().lower()
        if _pm not in ("auto", "nimarko", "th3", "lte"):
            _pm = "auto"
        try:
            for _m in ("auto", "nimarko", "th3", "lte"):
                self.set_setting("tgws_prov_" + _m, (_m == _pm), reload_settings=False)
        except Exception:
            pass
        def _prow(mode, label):
            return Switch(
                key="tgws_prov_" + mode,
                text=label,
                default=(_pm == mode),
                on_change=lambda v, m=mode: self._on_provider_toggle(m, v),
            )
        items.append(Header(text=_t("Провайдер", "Provider")))
        items.append(_prow("auto", _t("Авто (рекомендуется)", "Auto (recommended)")))
        items.append(_prow("nimarko", _t("Nimarko (Быстрый)", "Nimarko (Fast)")))
        items.append(_prow("th3", _t("Th3Nekit (Резервный)", "Th3Nekit (Backup)")))
        if _kws_lte_entitled():
            items.append(_prow("lte", _t("LeanVPN (Premium - С обходом)", "LeanVPN (Premium - Bypass)")))
            items.append(Divider(text=_t(
                "Работает только с активной подпиской LTE или Ultimate в @VPN_Lean_bot.",
                "Works only with an active LTE or Ultimate subscription in @VPN_Lean_bot.")))
        else:
            _lte_rem = int(60 - (time.time() - float(getattr(self, "_lte_check_ts", 0.0) or 0.0)))
            if bool(getattr(self, "_lte_checking", False)):
                items.append(Text(text=_t("🇨🇭 Проверяю доступ LTE…", "🇨🇭 Checking LTE access…")))
            elif _lte_rem > 0:
                items.append(Text(text=_t("🇨🇭 LeanVPN Premium — подождите %dс" % _lte_rem, "🇨🇭 LeanVPN Premium — wait %ds" % _lte_rem)))
            else:
                items.append(Text(text=_t("Проверить доступ", "Check access"), icon="msg_retry",
                                  on_click=self._on_lte_check_clicked))
            items.append(Divider(text=_t(
                "LeanVPN Premium — обход белых списков для подписчиков LTE или Ultimate (@VPN_Lean_bot). Кнопка появится после проверки доступа.",
                "LeanVPN Premium — white-list bypass for LTE or Ultimate subscribers (@VPN_Lean_bot). The toggle appears after an access check.")))

        if (_kws_needs_sub["v"] or _kws_on_trickle["v"]) and not _kws_grace_active():
            items.append(Header(text=_t("Требуется подписка", "Subscription required")))
            items.append(Divider(text=_t(
                "⚠️ Для ПОЛНОЙ скорости нужна подписка на канал " + _tgws_sub_channel + ". "
                "Без подписки доступ работает в режиме тонкого канала (очень медленно) — его "
                "хватает только чтобы открыть Telegram и подписаться. Подпишитесь на канал ниже "
                "(достаточно одного аккаунта) — полная скорость откроется автоматически.",
                "⚠️ FULL speed requires a subscription to " + _tgws_sub_channel + ". Without it "
                "access runs as a tiny throttled trickle (very slow) — just enough to open "
                "Telegram and subscribe. Subscribe to the channel below (one account is enough) "
                "— full speed unlocks automatically.",
            )))
            items.append(Text(text=_t("Подписаться на канал", "Subscribe to channel"),
                              icon="msg_channel",
                              on_click=lambda v: self._open_channel(_tgws_sub_channel)))
            items.append(Text(text=_t("Проверить подписку", "Check subscription"),
                              icon="msg_retry",
                              on_click=lambda v: self._on_check_sub_clicked()))
            items.append(Divider())

        if not enabled:
            items.append(Divider(text=_t(
                "Включите, чтобы Telegram работал в обход блокировок.",
                "Turn on to keep Telegram working in Russia.",
            )))
            items.append(Header(text=_t("О плагине", "About")))
            for _it in self._update_settings_items(_t):
                items.append(_it)
            items.append(Text(text=Z("author_channel"), icon="msg_channel", on_click=lambda v: self._open_author_channel()))
            items.append(Divider(text=Z("about")))
            self._last_rendered_state = "off"
            return items

        try:
            running = bool(getattr(self, "_tgws_running", False))
            starting = bool(getattr(self, "_tgws_starting", False))
            if running:
                status = f"\U0001F7E2 {Z('state_connected')}"
                self._last_rendered_state = "running"
            elif starting:
                status = f"\U0001F7E1 {Z('state_starting')}"
                self._last_rendered_state = "starting"
            else:
                status = f"\U0001F534 {Z('state_failed')}"
                self._last_rendered_state = "failed"
        except Exception:
            status = f"\U0001F7E1 {Z('state_starting')}"
            try:
                self._last_rendered_state = "starting"
            except Exception:
                pass
        if _kws_on_trickle["v"] and not _kws_grace_active():
            status = "\U0001F40C " + _t("Тонкий канал — нужна подписка",
                                        "Trickle mode — subscription required")
        elif _kws_needs_sub["v"]:
            status = "\U0001F512 " + _t("Нужна подписка", "Subscription required")
        items.append(Text(text=status, icon="msg_info"))
        try:
            if getattr(self, "_provider_switch_target", None) is not None:
                items.append(Text(text=_t("Провайдер: Переключение...", "Provider: Switching..."), icon="msg_info"))
            else:
                _pv = _kws_last_provider["name"]
                if _pv:
                    _pd = _kws_provider_display(_pv)
                    if _kws_last_provider["trickle"] and not _kws_grace_active():
                        _pl = _t("Провайдер: " + _pd + " (ознакомительный)",
                                 "Provider: " + _pd + " (limited)")
                    else:
                        _pl = _t("Провайдер: " + _pd, "Provider: " + _pd)
                    items.append(Text(text=_pl, icon="msg_info"))
        except Exception:
            pass
        items.append(Text(
            text=_t("Открыть настройки прокси", "Open proxy settings"),
            icon="msg_settings",
            on_click=lambda v: self._open_tg_proxy_settings(),
        ))
        items.append(Divider())

        items.append(Header(text=_t("О плагине", "About")))
        for _it in self._update_settings_items(_t):
            items.append(_it)
        items.append(Text(text=Z("author_channel"), icon="msg_channel", on_click=lambda v: self._open_author_channel()))
        items.append(Divider(text=Z("about")))
        return items
    def _on_sub_gate_changed(self, needs_sub):
        try:
            if needs_sub:
                self._schedule_sub_retry()
                if bool(self.get_setting("tgws_enabled", False)):
                    run_on_queue(lambda: self._start_tgws_runtime(auto_start=True, delay_ms=0))
            else:
                self._cancel_sub_retry()
                if bool(self.get_setting("tgws_enabled", False)):
                    def _promote_to_full():
                        try:
                            if bool(getattr(self, "_tgws_running", False)):
                                try:
                                    self._tgws_core.stop()
                                except Exception:
                                    pass
                                try:
                                    with self._state_lock:
                                        self._tgws_running = False
                                        self._tgws_starting = False
                                except Exception:
                                    pass
                        except Exception:
                            pass
                        self._start_tgws_runtime(auto_start=True, delay_ms=0)
                    run_on_queue(_promote_to_full)
            try:
                run_on_ui_thread(self._reload_settings_ui)
            except Exception:
                pass
        except Exception:
            pass

    def _tgws_suspend_for_sub(self):
        try:
            with self._state_lock:
                self._tgws_running = False
                self._tgws_starting = False
        except Exception:
            pass
        try:
            self._tgws_core.stop()
        except Exception:
            pass
        try:
            self._tgws_restore_previous_proxy()
        except Exception:
            pass
        try:
            _apply_tg_proxy(0, False)
        except Exception:
            pass
        try:
            self._tgws_remove_local_from_list()
        except Exception:
            pass

    def _schedule_sub_retry(self):
        with self._state_lock:
            if bool(getattr(self, "_sub_retry_running", False)):
                return
            self._sub_retry_running = True
        def _loop():
            while _kws_needs_sub["v"] and bool(self.get_setting("tgws_enabled", False)):
                try:
                    _kws_recheck_all()
                except Exception:
                    pass
                time.sleep(20)
            self._sub_retry_running = False
        threading.Thread(target=_loop, daemon=True, name="kws-sub-retry").start()

    def _cancel_sub_retry(self):
        self._sub_retry_running = False

    def _start_tgws_runtime(self, auto_start=False, delay_ms=0):
        try:
            _kws_prefetch_all()
        except Exception:
            pass
        if _kws_needs_sub["v"]:
            self._schedule_sub_retry()
        try:
            with self._state_lock:
                if bool(getattr(self, "_tgws_running", False)) or bool(getattr(self, "_tgws_starting", False)):
                    return
                if bool(auto_start) and not bool(self.get_setting("tgws_enabled", False)):
                    return
                self._tgws_starting = True
                self._tgws_start_seq = int(getattr(self, "_tgws_start_seq", 0) or 0) + 1
                self._tgws_start_token = int(self._tgws_start_seq)
                token = int(self._tgws_start_token)
        except Exception:
            token = -1
        def _run():
            try:
                with self._state_lock:
                    if int(getattr(self, "_tgws_start_token", 0) or 0) != int(token):
                        return
                    if bool(auto_start) and not bool(self.get_setting("tgws_enabled", False)):
                        self._tgws_starting = False
                        return
                threading.Thread(target=self._tgws_connect_bg, kwargs={"auto_start": bool(auto_start)}, daemon=True).start()
            except Exception:
                try:
                    with self._state_lock:
                        self._tgws_starting = False
                except Exception:
                    pass
        try:
            d = int(delay_ms or 0)
        except Exception:
            d = 0
        if d > 0:
            try:
                run_on_ui_thread(_run, d)
                return
            except Exception:
                pass
        _run()
    def _tgws_connect_bg(self, auto_start=False):
        ok = False
        try:
            ok = bool(self._tgws_connect(auto_start=bool(auto_start)))
        except Exception as e:
            try:
                self._tgws_last_error = str(e)
            except Exception:
                pass
            ok = False
        if not ok:
            try:
                with self._state_lock:
                    self._tgws_starting = False
            except Exception:
                pass
            msg = Z("tgws_connect_failed")
            try:
                last = str(getattr(self, "_tgws_last_error", "") or "").strip()
                if last:
                    msg = f"{Z('tgws_connect_failed')}: {last}"
            except Exception:
                pass
            try:
                run_on_ui_thread(lambda: BulletinHelper.show_error(str(msg)))
            except Exception:
                pass
            if not bool(auto_start):
                try:
                    self.set_setting("tgws_enabled", False, reload_settings=True)
                except Exception:
                    pass
            try:
                run_on_ui_thread(self._reload_settings_ui)
            except Exception:
                pass
    def _tgws_get_static_field(self, cls, name, default=None):
        try:
            f = _tgws_cached_field(cls, str(name))
            return f.get(None)
        except Exception:
            return default
    def _tgws_set_static_field(self, cls, name, value):
        try:
            f = _tgws_cached_field(cls, str(name))
            f.set(None, value)
        except Exception:
            pass
    def _tgws_snapshot_current_proxy(self):
        if self._tgws_proxy_snapshot is not None:
            return
        try:
            shared_config_cls = find_class("org.telegram.messenger.SharedConfig")
            current = self._tgws_get_static_field(shared_config_cls, "currentProxyInfo", None)
            enabled = bool(self._tgws_get_static_field(shared_config_cls, "useProxySettings", False))
            snapshot = {"enabled": enabled, "host": "", "port": 0, "user": "", "password": "", "secret": ""}
            if current:
                snapshot["host"] = str(get_private_field(current, "address") or "")
                snapshot["port"] = int(get_private_field(current, "port") or 0)
                snapshot["user"] = str(get_private_field(current, "username") or "")
                snapshot["password"] = str(get_private_field(current, "password") or "")
                snapshot["secret"] = str(get_private_field(current, "secret") or "")
            _h = str(snapshot.get("host", "") or "")
            if (not _h) or _h == LOCAL_PROXY_HOST or _h == "127.0.0.1" or _h.lower() == "localhost":
                snapshot = {"enabled": False, "host": "", "port": 0, "user": "", "password": "", "secret": ""}
            self._tgws_proxy_snapshot = snapshot
        except Exception:
            pass
    def _tgws_restore_previous_proxy(self):
        if not bool(getattr(self, "_tgws_proxy_managed", False)):
            return
        snapshot = getattr(self, "_tgws_proxy_snapshot", None)
        try:
            if snapshot is None:
                return
            enabled = bool(snapshot.get("enabled", False))
            host = str(snapshot.get("host", "") or "")
            port = int(snapshot.get("port", 0) or 0)
            user = str(snapshot.get("user", "") or "")
            password = str(snapshot.get("password", "") or "")
            secret = str(snapshot.get("secret", "") or "")
            shared_config_cls = find_class("org.telegram.messenger.SharedConfig")
            try:
                self._tgws_set_static_field(shared_config_cls, "useProxySettings", bool(enabled))
            except Exception:
                pass
            try:
                if host and port > 0:
                    ProxyInfo = jclass("org.telegram.messenger.SharedConfig$ProxyInfo")
                    pinfo = ProxyInfo(host, int(port), user, password, secret)
                    try:
                        self._tgws_set_static_field(shared_config_cls, "currentProxyInfo", pinfo)
                    except Exception:
                        pass
                    try:
                        SharedConfig.addProxy(pinfo)
                    except Exception:
                        pass
                else:
                    self._tgws_set_static_field(shared_config_cls, "currentProxyInfo", None)
            except Exception:
                pass
            try:
                ConnectionsManager.setProxySettings(bool(enabled), host, int(port), user, password, secret)
            except Exception:
                try:
                    for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                        cm = ConnectionsManager.getInstance(ac)
                        if cm:
                            cm.setProxySettings(bool(enabled), host, int(port), user, password, secret)
                except Exception:
                    pass
        finally:
            try:
                self._tgws_proxy_managed = False
            except Exception:
                pass
            try:
                self._tgws_proxy_snapshot = None
            except Exception:
                pass
    def _tgws_get_or_create_secret(self):
        cached = getattr(self, "_tgws_secret_cache", "") or ""
        if cached:
            return cached
        try:
            current = _tgws_valid_secret_hex(self.get_setting("mtproto_secret", ""))
        except Exception:
            current = ""
        if current:
            try:
                self._tgws_secret_cache = current
            except Exception:
                pass
            return current
        current = _tgws_generate_secret_hex()
        try:
            self.set_setting("mtproto_secret", current, reload_settings=False)
        except Exception:
            pass
        try:
            self._tgws_secret_cache = current
        except Exception:
            pass
        return current
    def _tgws_connect(self, auto_start=False):
        try:
            self._apply_runtime_local_host()
            port = int(self._local_port())
            if not self._wait_local_port_free(port, timeout_sec=0.8):
                try:
                    self._tgws_last_error = f"{Z('local_port_busy')}: {port}"
                except Exception:
                    pass
                return False
            if int(port or 0) <= 0:
                try:
                    self._tgws_last_error = Z("tgws_no_port")
                except Exception:
                    pass
                self._tgws_running = False
                self._tgws_port = 0
                try:
                    self._tgws_starting = False
                except Exception:
                    pass
                return False
            self._tgws_port = int(port)
            secret_hex = self._tgws_get_or_create_secret()
            config_json = json.dumps({"port": int(port), "verbose": False})
            err = self._tgws_core.start(config_json, secret_hex=secret_hex)
            if err:
                try:
                    self._tgws_last_error = str(err)
                except Exception:
                    pass
                try:
                    run_on_ui_thread(lambda: BulletinHelper.show_error(str(err)))
                except Exception:
                    pass
                self._tgws_running = False
                self._tgws_port = 0
                try:
                    self._tgws_starting = False
                except Exception:
                    pass
                return False
            _secret = str(secret_hex or "")
            try:
                self._tgws_snapshot_current_proxy()
            except Exception:
                pass
            try:
                self._tgws_proxy_managed = True
            except Exception:
                pass
            try:
                _apply_tg_proxy(int(port), True, secret=_secret)
            except Exception as _e:
                try:
                    self._tgws_last_error = str(_e)
                except Exception:
                    pass
            try:
                with self._state_lock:
                    self._tgws_running = True
                    self._tgws_starting = False
            except Exception:
                self._tgws_running = True
                try:
                    self._tgws_starting = False
                except Exception:
                    pass
            try:
                self.set_setting("tgws_enabled", True, reload_settings=False)
            except Exception:
                pass
            try:
                self._reload_settings_ui(delay_ms=400)
            except Exception:
                pass
            try:
                if bool(TGWS_SHOW_SUCCESS_BULLETIN) and not bool(auto_start):
                    BulletinHelper.show_success(Z("tgws_connected"))
            except Exception:
                pass
            try:
                self._tgws_start_proxy_watchdog(int(port), str(_secret or ""))
            except Exception:
                pass
            return True
        except Exception as exc:
            self._tgws_running = False
            self._tgws_port = 0
            try:
                self._tgws_starting = False
            except Exception:
                pass
            try:
                self._tgws_last_error = str(exc)
            except Exception:
                pass
            try:
                self._tgws_core.stop()
            except Exception:
                pass
            return False

    def _tgws_start_proxy_watchdog(self, port, secret):
        if bool(getattr(self, "_tgws_watchdog_running", False)):
            return
        self._tgws_watchdog_running = True
        host = LOCAL_PROXY_HOST
        port_i = int(port or 0)
        secret_s = str(secret or "")
        plugin = self

        def _loop():
            try:
                while bool(getattr(plugin, "_tgws_running", False)):
                    try:
                        time.sleep(30.0)
                    except Exception:
                        break
                    if not bool(getattr(plugin, "_tgws_running", False)):
                        break
                    try:
                        pl = getattr(SharedConfig, "proxyList", None)
                        found = False
                        if pl:
                            with _TGWS_PROXYLIST_LOCK:
                                snap = list(pl)
                            for p in snap:
                                try:
                                    if str(getattr(p, "address", "")) == host and int(getattr(p, "port", 0) or 0) == port_i:
                                        found = True
                                        break
                                except Exception:
                                    continue
                        if not found:
                            try:
                                _log("tgws watchdog: 127.0.0.1 entry vanished, re-installing")
                            except Exception:
                                pass
                            try:
                                _apply_tg_proxy(port_i, True, secret=secret_s)
                            except Exception:
                                pass
                    except Exception:
                        pass
                    try:
                        last = getattr(plugin, "_last_rendered_state", None)
                        if last is not None:
                            cur = plugin._tgws_state_token()
                            if str(cur) != str(last):
                                plugin._last_rendered_state = cur
                                plugin._reload_settings_ui()
                    except Exception:
                        pass
                    try:
                        plugin._tgws_persist_route_pref()
                    except Exception:
                        pass
            finally:
                try:
                    plugin._tgws_watchdog_running = False
                except Exception:
                    pass

        try:
            threading.Thread(target=_loop, name="tgws-watchdog", daemon=True).start()
        except Exception:
            try:
                self._tgws_watchdog_running = False
            except Exception:
                pass

    def _tgws_disconnect(self, silent=False):
        try:
            self._tgws_persist_route_pref(force=True)
        except Exception:
            pass
        try:
            self._tgws_core.stop()
        except Exception:
            pass
        try:
            with self._state_lock:
                self._tgws_running = False
                self._tgws_port = 0
                self._tgws_starting = False
                self._tgws_start_seq = int(getattr(self, "_tgws_start_seq", 0) or 0) + 1
                self._tgws_start_token = int(self._tgws_start_seq)
        except Exception:
            pass
        try:
            self._tgws_restore_previous_proxy()
        except Exception:
            _apply_tg_proxy(0, False)
        try:
            self._tgws_remove_local_from_list()
        except Exception:
            pass
        if not silent:
            self._reload_settings_ui()

    def _tgws_remove_local_from_list(self):
        try:
            SharedConfig.loadProxyList()
        except Exception:
            pass
        try:
            with _TGWS_PROXYLIST_LOCK:
                pl = getattr(SharedConfig, "proxyList", None)
                if not pl:
                    return
                snap = list(pl)
            to_remove = []
            for p in snap:
                try:
                    if str(getattr(p, "address", "")) == LOCAL_PROXY_HOST:
                        to_remove.append(p)
                except Exception:
                    continue
            if not to_remove:
                return
            for p in to_remove:
                try:
                    SharedConfig.deleteProxy(p)
                except Exception:
                    pass
            try:
                SharedConfig.saveProxyList()
            except Exception:
                pass
        except Exception:
            pass

    def _tgws_persist_route_pref(self, force=False):
        try:
            core = getattr(self, "_tgws_core", None)
            if core is None:
                return
            v = int(core.route_version())
            if not force and v == int(getattr(self, "_route_pref_saved_v", -1)):
                return
            data = core.export_route_pref()
            if not data:
                return
            self.set_setting("route_pref", json.dumps(data), reload_settings=False)
            self._route_pref_saved_v = v
        except Exception:
            pass

    def _on_enabled_changed(self, v):
        enabled = bool(v)
        _tgws_enabled["v"] = enabled
        if enabled:
            try:
                _kws_prefetch_all()
            except Exception:
                pass
            self._start_tgws_runtime(auto_start=False, delay_ms=TGWS_SOFT_RESTART_DELAY_MS)
        else:
            try:
                with self._state_lock:
                    self._tgws_running = False
                    self._tgws_starting = False
            except Exception:
                pass
            self._tgws_disconnect()
        self._reload_settings_ui()
    def _reload_settings_ui(self, delay_ms=100):
        try:
            if bool(getattr(self, "_reload_ui_pending", False)):
                return
            self._reload_ui_pending = True
        except Exception:
            pass
        def _do():
            try:
                self._reload_ui_pending = False
            except Exception:
                pass
            try:
                self.set_setting("__reload__", time.time(), reload_settings=True)
            except Exception:
                pass
        try:
            run_on_ui_thread(_do, int(delay_ms))
        except Exception:
            pass
    def _open_tg_proxy_settings(self):
        try:
            frag = get_last_fragment()
            if frag:
                from org.telegram.ui import ProxyListActivity
                frag.presentFragment(ProxyListActivity())
        except Exception:
            pass
    def _on_provider_mode_clicked(self, mode):
        try:
            if bool(self.get_setting("tgws_enabled", False)) and bool(getattr(self, "_tgws_running", False)):
                self._provider_switch_target = str(mode)
                self._provider_switch_ready = False
            else:
                self._provider_switch_target = None
                self._provider_switch_ready = False
        except Exception:
            self._provider_switch_target = None
            self._provider_switch_ready = False
        try:
            self.set_setting("tgws_provider_mode", str(mode), reload_settings=False)
            for _m in ("auto", "nimarko", "th3", "lte"):
                self.set_setting("tgws_prov_" + _m, (_m == str(mode)), reload_settings=False)
        except Exception:
            pass
        try:
            self._reload_ui_pending = False
        except Exception:
            pass
        try:
            self._reload_settings_ui(delay_ms=0)
        except Exception:
            pass
        try:
            gen = int(getattr(self, "_provider_switch_gen", 0)) + 1
            self._provider_switch_gen = gen
            if bool(self.get_setting("tgws_enabled", False)) and bool(getattr(self, "_tgws_running", False)):
                def _reswitch(g=gen):
                    if int(getattr(self, "_provider_switch_gen", 0)) != g:
                        return
                    try:
                        self._tgws_core.stop()
                    except Exception:
                        pass
                    try:
                        if int(getattr(self, "_provider_switch_gen", 0)) == g:
                            self._provider_switch_ready = True
                    except Exception:
                        pass
                    try:
                        with self._state_lock:
                            self._tgws_running = False
                            self._tgws_starting = False
                    except Exception:
                        pass
                    self._start_tgws_runtime(auto_start=True, delay_ms=0)
                def _fire(g=gen):
                    if int(getattr(self, "_provider_switch_gen", 0)) == g:
                        run_on_queue(_reswitch)
                run_on_ui_thread(_fire, 700)
        except Exception:
            pass

    def _on_provider_connected(self, name):
        try:
            target = getattr(self, "_provider_switch_target", None)
            ready = bool(getattr(self, "_provider_switch_ready", False))
            provider = str(name or "").strip().lower()
            target = str(target).strip().lower() if target is not None else None
        except Exception:
            return False
        if target is None or not ready:
            return False
        if target != "auto" and target != provider:
            return False
        self._provider_switch_target = None
        self._provider_switch_ready = False
        try:
            self._reload_settings_ui(delay_ms=0)
        except Exception:
            pass
        return True

    def _on_provider_toggle(self, mode, value):
        try:
            cur = str(self.get_setting("tgws_provider_mode", "auto") or "auto").strip().lower()
        except Exception:
            cur = "auto"
        if value and str(mode) != cur:
            self._on_provider_mode_clicked(mode)
            return
        try:
            for _m in ("auto", "nimarko", "th3", "lte"):
                self.set_setting("tgws_prov_" + _m, (_m == cur), reload_settings=False)
        except Exception:
            pass
        try:
            self._reload_ui_pending = False
        except Exception:
            pass
        try:
            self._reload_settings_ui(delay_ms=0)
        except Exception:
            pass

    def _on_lte_check_clicked(self, v=None):
        if bool(getattr(self, "_lte_checking", False)):
            return
        rem = int(60 - (time.time() - float(getattr(self, "_lte_check_ts", 0.0) or 0.0)))
        if rem > 0:
            try:
                BulletinHelper.show_info(_tt("Подождите %dс — не нагружаем сервер" % rem, "Wait %ds — sparing the server" % rem))
            except Exception:
                pass
            return
        self._lte_check_ts = time.time()
        self._lte_checking = True
        try:
            BulletinHelper.show_info(_tt("Проверяю доступ…", "Checking access…"))
        except Exception:
            pass
        try:
            self._reload_ui_pending = False
        except Exception:
            pass
        self._reload_settings_ui(delay_ms=0)
        try:
            threading.Thread(target=self._lte_run_access_check, daemon=True, name="kws-lte-check").start()
        except Exception:
            self._lte_checking = False
        try:
            run_on_ui_thread(self._reload_settings_ui, 61000)
        except Exception:
            pass

    def _lte_run_access_check(self):
        found = None
        try:
            lte = _kws_provider("lte")
            _active = _kws_current_account()
            _order = [_active] + [a for a in range(int(UserConfig.MAX_ACCOUNT_COUNT)) if a != _active]
            for ac in _order:
                try:
                    if _kws_uid(ac) <= 0:
                        continue
                    cred = _kws_mint_for_account(lte, ac)
                    if cred and cred != "__give_up__":
                        _kws_store_cred(lte, cred)
                        _kws_mark_lte_entitled(ac)
                        found = ac
                        break
                except Exception:
                    continue
        except Exception:
            pass
        self._lte_checking = False
        if found is None:
            try:
                self.set_setting("tgws_lte_entitled", "0", reload_settings=False)
            except Exception:
                pass
            try:
                run_on_ui_thread(lambda: BulletinHelper.show_error(_tt("Подписка LTE или Ultimate не найдена ни на одном аккаунте", "No LTE or Ultimate subscription found on any account")))
            except Exception:
                pass
            try:
                self._reload_ui_pending = False
            except Exception:
                pass
            self._reload_settings_ui(delay_ms=0)
        else:
            try:
                run_on_ui_thread(lambda: BulletinHelper.show_info(_tt("Доступ LTE найден — LeanVPN Premium включён", "LTE access found — LeanVPN Premium enabled")))
            except Exception:
                pass
            try:
                run_on_ui_thread(lambda: self._on_provider_mode_clicked("lte"))
            except Exception:
                pass

    def _open_channel(self, username):
        u = str(username or "").lstrip("@")
        if not u:
            return
        url = "https://t.me/" + u
        try:
            from org.telegram.messenger.browser import Browser
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag else None
            if ctx is not None:
                Browser.openUrl(ctx, url)
                return
        except Exception:
            pass
        try:
            from android.content import Intent
            from android.net import Uri
            from org.telegram.messenger import ApplicationLoader
            it = Intent(Intent.ACTION_VIEW, Uri.parse(url))
            it.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            ApplicationLoader.applicationContext.startActivity(it)
        except Exception:
            pass

    def _open_author_channel(self):
        self._open_channel("th3nek1t_projects")

    def _on_check_sub_clicked(self):
        def _do():
            try:
                run_on_ui_thread(lambda: BulletinHelper.show_info(
                    "Проверяю подписку…" if _is_ru_language() else "Checking subscription…"))
            except Exception:
                pass
            try:
                _kws_recheck_all()
            except Exception:
                pass
            ok = False
            try:
                ok = any(_kws_cred_valid(_kws_slot(p)["cred"]["v"]) for p in _KWS_PROVIDERS)
            except Exception:
                pass
            def _res():
                try:
                    if ok:
                        BulletinHelper.show_success(
                            "Подписка подтверждена ✓" if _is_ru_language() else "Subscription confirmed ✓")
                    else:
                        BulletinHelper.show_error(
                            ("Подписка не найдена. Подпишитесь на @" + str(_tgws_sub_channel) + " и попробуйте снова.")
                            if _is_ru_language() else
                            ("Subscription not found. Subscribe to @" + str(_tgws_sub_channel) + " and try again."))
                except Exception:
                    pass
                try:
                    self._reload_settings_ui()
                except Exception:
                    pass
            try:
                run_on_ui_thread(_res)
            except Exception:
                pass
        try:
            threading.Thread(target=_do, daemon=True, name="tgws-check-sub").start()
        except Exception:
            pass

    def _on_native_proxy_error(self):
        try:
            now = time.time()
            if self._tgws_fail_dialog is not None:
                return
            if now - float(getattr(self, "_tgws_fail_last_ts", 0.0) or 0.0) < float(TGWS_WS_FAIL_COOLDOWN_SEC):
                return
            self._tgws_fail_last_ts = now
            run_on_ui_thread(self._show_bypass_fail_dialog)
        except Exception:
            pass

    def _show_bypass_fail_dialog(self):
        def _t(ru, en):
            try:
                return ru if _is_ru_language() else en
            except Exception:
                return en
        if getattr(self, "_tgws_fail_dialog", None) is not None:
            return
        frag = get_last_fragment()
        ctx = frag.getParentActivity() if frag else None
        if ctx is None:
            return
        try:
            from org.telegram.ui.ActionBar import AlertDialog
            from java import dynamic_proxy
            from android.content import DialogInterface

            class _OnClick(dynamic_proxy(DialogInterface.OnClickListener)):
                def __init__(self, fn):
                    super().__init__()
                    self._fn = fn

                def onClick(self, dialog, which):
                    try:
                        self._fn()
                    except Exception:
                        pass

            class _OnDismiss(dynamic_proxy(DialogInterface.OnDismissListener)):
                def __init__(self, plugin):
                    super().__init__()
                    self._p = plugin

                def onDismiss(self, dialog):
                    try:
                        self._p._tgws_fail_dialog = None
                    except Exception:
                        pass

            b = AlertDialog.Builder(ctx)
            b.setTitle("WS-Bypass")
            b.setMessage(_t("Обход не смог подключиться", "The bypass could not connect"))
            b.setPositiveButton(_t("Попробовать снова", "Retry"), _OnClick(self._tgws_fail_retry))
            b.setNegativeButton(_t("Отключить прокси", "Disable proxy"), _OnClick(self._tgws_fail_disable))
            dlg = b.create()
            try:
                dlg.setOnDismissListener(_OnDismiss(self))
            except Exception:
                pass
            self._tgws_fail_dialog = dlg
            dlg.show()
        except Exception:
            try:
                self._tgws_fail_dialog = None
            except Exception:
                pass
            try:
                BulletinHelper.show_error(
                    _t("Обход не смог подключиться. Откройте настройки WS-Bypass, чтобы повторить или отключить прокси.",
                       "The bypass could not connect. Open WS-Bypass settings to retry or disable the proxy."))
            except Exception:
                pass

    def _tgws_fail_disable(self):
        try:
            self._tgws_fail_dialog = None
        except Exception:
            pass
        try:
            self.set_setting("tgws_enabled", False, reload_settings=True)
        except Exception:
            pass
        try:
            self._on_enabled_changed(False)
        except Exception:
            pass

    def _tgws_fail_retry(self):
        try:
            self._tgws_fail_dialog = None
        except Exception:
            pass
        try:
            self._tgws_disconnect()
        except Exception:
            pass
        try:
            self._start_tgws_runtime(auto_start=True, delay_ms=0)
        except Exception:
            pass
        try:
            self._tgws_fail_last_ts = 0.0
        except Exception:
            pass

    def _add_menu_items(self):
        def on_click(ctx):
            self._open_settings()
        try:
            self.remove_menu_item(self._chat_menu_item_id)
        except Exception:
            pass
        try:
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                item_id=self._chat_menu_item_id,
                text=Z("menu_settings"),
                on_click=on_click,
                icon="msg_settings",
                priority=1,
            ))
        except Exception:
            pass
        try:
            self.remove_menu_item(self._drawer_menu_item_id)
        except Exception:
            pass
        try:
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.DRAWER_MENU,
                item_id=self._drawer_menu_item_id,
                text=Z("menu_settings"),
                on_click=on_click,
                icon="msg_settings",
                priority=1,
            ))
        except Exception:
            pass
    def _remove_menu_items(self):
        try:
            self.remove_menu_item(self._chat_menu_item_id)
        except Exception:
            pass
        try:
            self.remove_menu_item(self._drawer_menu_item_id)
        except Exception:
            pass
    def _open_settings(self):
        try:
            PC = find_class("com.exteragram.messenger.plugins.PluginsController")
        except Exception:
            PC = None
        try:
            PSA = find_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
        except Exception:
            PSA = None
        try:
            if PC:
                inst = None
                try:
                    inst = PC.getInstance()
                except Exception:
                    inst = None
                if inst is not None and hasattr(inst, "plugins") and PSA:
                    plugin_obj = None
                    try:
                        plugin_obj = inst.plugins.get(self.id)
                    except Exception:
                        plugin_obj = None
                    if plugin_obj is not None:
                        frag = get_last_fragment()
                        if frag is not None:
                            frag.presentFragment(PSA(plugin_obj))
                            return
                try:
                    PC.openPluginSettings(self.id)
                    return
                except Exception:
                    pass
            frag = get_last_fragment()
            if frag and PC:
                PC.getInstance().openPluginSettings(self.id, frag)
        except Exception:
            pass
