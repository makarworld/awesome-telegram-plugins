_q = 2 ** 255 - 19
_L = 2 ** 252 + 27742317777372353535851937790883648493

def _sha512(b):
    return hashlib.sha512(b).digest()

def _inv(x):
    return pow(x, _q - 2, _q)

_d = (-121665 * _inv(121666)) % _q
_I = pow(2, (_q - 1) // 4, _q)

def _xrecover(y):
    xx = (y * y - 1) * _inv(_d * y * y + 1)
    x = pow(xx, (_q + 3) // 8, _q)
    if (x * x - xx) % _q != 0:
        x = (x * _I) % _q
    if x % 2 != 0:
        x = _q - x
    return x

_By = (4 * _inv(5)) % _q
_Bx = _xrecover(_By)
_B = (_Bx % _q, _By % _q, 1, (_Bx * _By) % _q)

def _edwards_add(P, Q):
    (x1, y1, z1, t1) = P
    (x2, y2, z2, t2) = Q
    a = ((y1 - x1) * (y2 - x2)) % _q
    b = ((y1 + x1) * (y2 + x2)) % _q
    c = (2 * t1 * t2 * _d) % _q
    dd = (2 * z1 * z2) % _q
    e = b - a
    f = dd - c
    g = dd + c
    h = b + a
    return ((e * f) % _q, (g * h) % _q, (f * g) % _q, (e * h) % _q)

def _scalarmult(P, e):
    Q = (0, 1, 1, 0)
    while e > 0:
        if e & 1:
            Q = _edwards_add(Q, P)
        P = _edwards_add(P, P)
        e >>= 1
    return Q

def _bit(h, i):
    return (h[i // 8] >> (i % 8)) & 1

def _isoncurve(P):
    (x, y, z, t) = P
    zi = _inv(z)
    xa = (x * zi) % _q
    ya = (y * zi) % _q
    return (-xa * xa + ya * ya - 1 - _d * xa * xa * ya * ya) % _q == 0

def _decodepoint(s):
    y = int.from_bytes(s, "little") & ((1 << 255) - 1)
    x = _xrecover(y)
    if (x & 1) != _bit(s, 255):
        x = _q - x
    P = (x, y, 1, (x * y) % _q)
    if not _isoncurve(P):
        raise ValueError("point not on curve")
    return P

def _pt_eq(P, Q):
    (x1, y1, z1, _t1) = P
    (x2, y2, z2, _t2) = Q
    if (x1 * z2 - x2 * z1) % _q != 0:
        return False
    if (y1 * z2 - y2 * z1) % _q != 0:
        return False
    return True

def ed25519_verify(public_key, message, signature):
    try:
        if len(signature) != 64 or len(public_key) != 32:
            return False
        R = _decodepoint(signature[:32])
        A = _decodepoint(public_key)
        S = int.from_bytes(signature[32:], "little")
        if S >= _L:
            return False
        h = int.from_bytes(_sha512(signature[:32] + public_key + message), "little") % _L
        lhs = _scalarmult(_B, S)
        rhs = _edwards_add(R, _scalarmult(A, h))
        return _pt_eq(lhs, rhs)
    except Exception:
        return False

def _selftest():
    pk = bytes.fromhex("d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a")
    sig = bytes.fromhex(
        "e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e06522490155"
        "5fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b"
    )
    if not ed25519_verify(pk, b"", sig):
        raise RuntimeError("ed25519 self-test FAILED")
    if ed25519_verify(pk, b"x", sig):
        raise RuntimeError("ed25519 self-test FAILED (accepted tampered)")
    return True

try:
    _ED25519_SELFTEST_OK = _selftest()
except Exception:
    _ED25519_SELFTEST_OK = False

class _TgwsProxyLabelHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            args = getattr(param, "args", None)
            if not args:
                return
            info = args[0]
            if info is None:
                return
            if str(getattr(info, "address", "")) != LOCAL_PROXY_HOST:
                return
            cell = getattr(param, "thisObject", None)
            if cell is None:
                return
            tv = get_private_field(cell, "textView")
            if tv is not None:
                tv.setText(TGWS_PROXY_LABEL)
        except Exception:
            pass

class _TgwsProxyErrorHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self._p = plugin

    def before_hooked_method(self, param):
        try:
            if not _tgws_enabled["v"]:
                return
            _ours = True
            try:
                shared_config_cls = find_class("org.telegram.messenger.SharedConfig")
                if shared_config_cls is not None:
                    _curr = self._p._tgws_get_static_field(shared_config_cls, "currentProxyInfo", None)
                    if _curr is not None:
                        _addr = str(getattr(_curr, "address", "") or "")
                        if _addr and _addr != LOCAL_PROXY_HOST:
                            _ours = False
            except Exception:
                _ours = True
            if not _ours:
                return
            param.setResult(None)
            try:
                self._p._on_native_proxy_error()
            except Exception:
                pass
        except Exception:
            try:
                if _tgws_enabled["v"]:
                    param.setResult(None)
            except Exception:
                pass
_TGWS_HOST_LOCK = threading.RLock()
_TGWS_PROXYLIST_LOCK = threading.RLock()
_TGWS_NOTIFY_LOCK = threading.Lock()
