_EMOJI_GRAPHEME = (
    r"[\U0001F1E0-\U0001F1FF]{2}"
    r"|[\U0001F300-\U0001FAFF\U00002600-\U000027BF\U0000FE00-\U0000FE0F"
    r"\U0001F3FB-\U0001F3FF\U0000200D\U000E0020-\U000E007F]+"
)
_EMOJI_CLUSTER_RE = re.compile(r"^(?:\s|" + _EMOJI_GRAPHEME + r")+$")
_EMOJI_ONLY_MSG_RE = re.compile(rf"^(?:{_EMOJI_GRAPHEME})(?:\s+(?:{_EMOJI_GRAPHEME})){{0,2}}$")


def _utf16_len(text):
    if not text:
        return 0
    return len(text.encode("utf-16-le", "surrogatepass")) // 2


def _py_to_utf16_offset(text, py_index):
    if py_index <= 0:
        return 0
    return _utf16_len(text[:py_index])


def _utf16_to_py_range(text, utf16_offset, utf16_length):
    if not text or utf16_length <= 0:
        return 0, 0
    u = 0
    py_start = None
    py_end = len(text)
    target_end = int(utf16_offset) + int(utf16_length)
    for i, ch in enumerate(text):
        next_u = u + _utf16_len(ch)
        if py_start is None and next_u > int(utf16_offset):
            py_start = i
        if next_u >= target_end:
            py_end = i + 1
            break
        u = next_u
    if py_start is None:
        py_start = len(text)
    return py_start, py_end


class LocalizationManager:
    def __init__(self):
        self._override = None
        self._apply_system_language()

    def _apply_system_language(self):
        lang = Locale.getDefault().getLanguage()
        self.language = lang if lang in self._get_supported_languages() else "en"

    def apply_override(self, index):
        if index == 1:
            self._override = "ru"
        elif index == 2:
            self._override = "en"
        else:
            self._override = None
        if self._override:
            self.language = self._override
        else:
            self._apply_system_language()

    def get_string(self, string_key):
        return self.strings[self.language].get(string_key, self.strings["en"].get(string_key, string_key))

    def _get_supported_languages(self):
        return self.strings.keys()

