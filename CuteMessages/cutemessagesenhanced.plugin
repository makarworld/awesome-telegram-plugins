                key="enable_cute_actions",
                text=locali.get_string("ENABLE_CUTE_ACTIONS_SWITCH"),
                default=False,
                icon="msg_filled_plus",
            ),
            Selector(
                key="cute_actions_frequency",
                text=locali.get_string("CUTE_ACTIONS_FREQUENCY"),
                items=extended_frequency_items,
                default=2,
                icon="msg_forward_replace",
            ),
            Switch(
                key="actions_on_new_line",
                text=locali.get_string("ACTIONS_ON_NEW_LINE"),
                subtext=locali.get_string("ACTIONS_ON_NEW_LINE_INFO"),
                default=False,
                icon="msg_reorder",
            ),
            Divider(text=locali.get_string("CUTE_ACTIONS_INFO")),
            Divider(text=locali.get_string("INFO_TEXT")),
            Divider(),
            Header(text=locali.get_string("DONATE_HEADER")),
            Text(
                text=locali.get_string("DONATE_CRYPTO"),
                icon="menu_cashtag",
                accent=True,
                on_click=lambda view: run_on_ui_thread(
                    lambda: self._copy_to_clipboard("CRYPTO", "http://t.me/send?start=IVaZsLfW7aSn")
                ),
            ),
            Text(
                text=locali.get_string("DONATE_INFO"),
                icon="msg_info",
                accent=True,
                on_click=lambda view: run_on_ui_thread(
                    lambda: get_messages_controller().openByUserName("mishabotov", get_last_fragment(), 1)
                ),
            ),
        ]

        return settings

    def on_plugin_load(self):
        ignore_commands = self.get_setting("ignore_dot_commands", True)
        priority = -100 if ignore_commands else 200
        self.add_on_send_message_hook(priority)
        for req_name in self._SEND_REQUESTS:
            try:
                self.add_hook(req_name)
            except Exception as e:
                log(f"[{__id__}] failed to register {req_name} hook: {e}")
        if self.get_setting("show_settings_buttons", True):
            self._add_settings_menu_items()
        self._add_chat_action_items()
        self._add_undo_menu_item()
        self._install_chat_dialog_hook()

    def on_app_event(self, event_type):
        if event_type in (AppEvent.START, AppEvent.RESUME):
            self._update_chat_list_menu_text()

    def on_plugin_unload(self):
        self._uninstall_chat_dialog_hook()
        self._remove_settings_menu_items()
        self._remove_chat_action_items()
        self._remove_undo_menu_item()
        try:
            self._pending_undo.clear()
            self._undo_cache.clear()
            self._undo_cache_order.clear()
        except Exception:
            pass

    def get_classic_effects_probability(self):
        frequency = self.get_setting("emoji_frequency", 1)
        if frequency == 0:
            return 0.25
        if frequency == 2:
            return 0.75
        if frequency == 3:
            return 1.0
        return 0.5

    def _should_skip_text(self, text):
        if not text or not text.strip():
            return True
        stripped = text.strip()
        if self.get_setting("ignore_dot_commands", True) and stripped.startswith("."):
            return True
        if self.get_setting("ignore_slash_commands", True) and stripped.startswith("/"):
            return True
        return False

    def _extract_sent_message_info(self, response):
        msg_ids = set()
        updates = getattr(response, "updates", None)
        try:
            arr = updates if updates is not None else getattr(response, "updatess", None)
            if arr:
                for u in self._iter_java(arr):
                    cls_name = u.getClass().getName()
                    if cls_name.endswith("TL_updateMessageID"):
                        mid = getattr(u, "id", None)
                        if mid is not None:
                            msg_ids.add(int(mid))
                    elif cls_name.endswith("TL_updateNewMessage"):
                        msg_obj = getattr(u, "message", None)
                        if msg_obj is not None:
                            try:
                                msg_ids.add(int(getattr(msg_obj, "id", 0)))
                            except Exception:
                                pass
                    elif cls_name.endswith("TL_updateNewChannelMessage"):
                        msg_obj = getattr(u, "message", None)
                        if msg_obj is not None:
                            try:
                                msg_ids.add(int(getattr(msg_obj, "id", 0)))
                            except Exception:
                                pass
        except Exception:
            log(f"[{__id__}] extract sent message info failed: {traceback.format_exc()}")
        return msg_ids

    def _store_undo_record(self, dialog_id, msg_ids, record):
        did = int(dialog_id) if dialog_id is not None else 0
        ids = sorted({int(mid) for mid in msg_ids if mid is not None})
        if not ids:
            return
        primary = (did, ids[0])
        self._undo_cache[primary] = record
        self._undo_cache_order.append(primary)
        for mid in ids[1:]:
            self._undo_cache[(did, mid)] = record
        while len(self._undo_cache_order) > self._undo_cache_limit:
            oldest = self._undo_cache_order.pop(0)
            self._pop_undo_cache_key(oldest)

    def post_request_hook(self, request_name, account, response, error):
        try:
            if error is not None or request_name not in self._SEND_REQUESTS or response is None:
                return HookResult()

            msg_ids = self._extract_sent_message_info(response)
            if not msg_ids:
                return HookResult()

            record = None
            dialog_id = 0
            if self._pending_undo:
                dialog_id, record = self._pending_undo.pop(0)

            log(
                f"[{__id__}] post_request_hook: msg_ids={sorted(msg_ids)}, dialog_id={dialog_id}, "
                f"pending_left={len(self._pending_undo)}"
            )
            if record is None:
                return HookResult()

            self._store_undo_record(dialog_id, msg_ids, record)
        except Exception:
            log(f"[{__id__}] post_request_hook error:\n{traceback.format_exc()}")
        return HookResult()

    def on_send_message_hook(self, account, params):
        original_text_for_error = (
            params.message
            if hasattr(params, "message") and params.message
            else (params.caption if hasattr(params, "caption") and params.caption else None)
        )
        try:
            if hasattr(params, "message") and params.message and params.message.strip() in (".picme", ".cute"):
                current_state = self.get_setting("enabled", True)
                new_state = not current_state
                self.set_setting("enabled", new_state)

                if new_state:
                    BulletinHelper.show_info(locali.get_string("ENABLED"))
                else:
                    BulletinHelper.show_info(locali.get_string("DISABLED"))

                return HookResult(strategy=HookStrategy.CANCEL)

            if not self.get_setting("enabled", True):
                return HookResult()

            if self._should_skip_text(original_text_for_error):
                return HookResult()

            peer = getattr(params, "peer", None)
            if not self._should_apply_in_chat(peer):
                return HookResult()

            classic_effects_prob = self.get_classic_effects_probability()
            text_style_setting = self.get_setting("text_style", 0)

            entities = getattr(params, "entities", None)
            is_caption = False
            if hasattr(params, "message") and params.message:
                target_attr = "message"
            elif hasattr(params, "caption") and params.caption:
                target_attr = "caption"
                is_caption = True
            else:
                target_attr = None

            original_text = original_text_for_error
            entities_list = self._snapshot_entities(entities)
            modified_text, new_entities = self._transform_with_entities(
                original_text, entities_list, classic_effects_prob, text_style_setting
            )

            if target_attr:
                setattr(params, target_attr, modified_text)
            self._apply_entities_to_params(params, new_entities, is_caption)

            undo_key = self._normalize_dialog_id(peer)
            self._pending_undo.append(
                (
                    undo_key,
                    {
                        "text": original_text,
                        "html": self._entities_to_html(original_text, entities_list),
                        "ts": time.time(),
                    },
                )
            )
            return HookResult(strategy=HookStrategy.MODIFY, params=params)
        except Exception:
            exc_type, exc_val, exc_tb = sys.exc_info()
            tb_lines = traceback.format_exception(exc_type, exc_val, exc_tb)
            tb_text = "".join(tb_lines)
            log(f"Exception in plugin {__name__}:\n{tb_text}")
            exc_type_name = exc_type.__name__ if exc_type else "Exception"
            err_msg = ""
            try:
                err_msg = traceback.format_exception_only(exc_type, exc_val)[-1].strip()
            except Exception:
                err_msg = str(exc_val) if exc_val else ""
            tb_last = ""
            for line in reversed(tb_lines):
                m = re.search(r'File\s+"([^"]+)",\s+line\s+(\d+),\s+in\s+(.+)', line)
                if m:
                    fname = m.group(1).replace("\\", "/").split("/")[-1]
                    tb_last = f"{fname}:{m.group(2)} in {m.group(3).strip()}"
                    break
            debug_suffix = f"\n\n[debug: {exc_type_name}: {err_msg}"
            if tb_last:
                debug_suffix += f" @ {tb_last}"
            debug_suffix += "]"
            error_prefix = locali.get_string("ERROR_MESSAGE_CUTE")
            if hasattr(params, "message") and params.message is not None:
                params.message = f"{error_prefix}\n\n{original_text_for_error}{debug_suffix}"
            elif hasattr(params, "caption") and params.caption is not None:
                params.caption = f"{error_prefix}\n\n{original_text_for_error}{debug_suffix}"
            return HookResult(strategy=HookStrategy.MODIFY_FINAL, params=params)

    def _transform_lowercase(self, text):
        return text.lower()

    _ENTITY_HTML_TAG = {
        "MessageEntityBold": ("b", "b"),
        "MessageEntityItalic": ("i", "i"),
        "MessageEntityUnderline": ("u", "u"),
        "MessageEntityStrike": ("s", "s"),
        "MessageEntitySpoiler": ("spoiler", "spoiler"),
        "MessageEntityBlockquote": ("blockquote", "blockquote"),
        "MessageEntityCode": ("code", "code"),
        "MessageEntityPre": ("pre", "pre"),
        "MessageEntityUrl": (None, None),
        "MessageEntityTextUrl": ("a", "a"),
        "MessageEntityMentionName": (None, None),
        "MessageEntityMention": (None, None),
        "MessageEntityHashtag": (None, None),
        "MessageEntityBotCommand": (None, None),
        "MessageEntityCustomEmoji": (None, None),
    }

    _ENTITY_NO_TRANSFORM = ("MessageEntityCode", "MessageEntityPre")

    def _entity_class_name(self, entity):
        try:
            cls = entity.getClass()
            name = cls.getName().rsplit(".", 1)[-1]
            if name.startswith("TL_messageEntity"):
                name = "MessageEntity" + name[len("TL_messageEntity") :]
            return name
        except Exception:
            try:
                name = type(entity).__name__
                if name.startswith("TL_messageEntity"):
                    name = "MessageEntity" + name[len("TL_messageEntity") :]
                return name
            except Exception:
                return ""

    def _iter_java(self, obj):
        if obj is None:
            return []
        if isinstance(obj, (list, tuple, set)):
            return list(obj)
        try:
            if hasattr(obj, "toArray"):
                return list(obj.toArray())
        except Exception:
            pass
        try:
            if hasattr(obj, "size") and hasattr(obj, "get"):
                size = int(obj.size())
                return [obj.get(i) for i in range(size)]
        except Exception:
            pass
        try:
            if hasattr(obj, "hasNext") and hasattr(obj, "next"):
                items = []
                while obj.hasNext():
                    items.append(obj.next())
                return items
        except Exception:
            pass
        try:
            return list(obj)
        except Exception:
            return []

    def _snapshot_entities(self, entities):
        result = []
        if entities is None:
            return result
        items = self._iter_java(entities)
        for ent in items:
            try:
                result.append(
                    {
                        "offset": int(getattr(ent, "offset", 0)),
                        "length": int(getattr(ent, "length", 0)),
                        "type": self._entity_class_name(ent),
                        "url": getattr(ent, "url", None),
                        "language": getattr(ent, "language", None),
                        "document_id": getattr(ent, "document_id", None),
                        "java": ent,
                    }
                )
            except Exception:
                log(f"[{__id__}] entity snapshot skip: {traceback.format_exc()}")
        return result

    def _apply_entities_to_params(self, params, entities_list, is_caption):
        try:
            if not entities_list:
                return
            target_field = "captionEntities" if is_caption else "entities"
            existing = getattr(params, target_field, None)
            if existing is None or not hasattr(existing, "add"):
                new_list = ArrayList()
                for rec in entities_list:
                    java_ent = rec.get("java")
                    if java_ent is not None:
                        try:
                            java_ent.offset = int(rec.get("new_offset", rec.get("offset", 0)))
                            java_ent.length = int(rec.get("new_length", rec.get("length", 0)))
                        except Exception:
                            pass
                        new_list.add(java_ent)
                setattr(params, target_field, new_list)
            else:
                existing.clear()
                for rec in entities_list:
                    java_ent = rec.get("java")
                    if java_ent is not None:
                        try:
                            java_ent.offset = int(rec.get("new_offset", rec.get("offset", 0)))
                            java_ent.length = int(rec.get("new_length", rec.get("length", 0)))
                        except Exception:
                            pass
                        existing.add(java_ent)
        except Exception:
            log(f"[{__id__}] apply entities failed: {traceback.format_exc()}")

    def _transform_with_entities(self, text, entities_list, classic_prob, style_setting):
        if not entities_list:
            return self.apply_cute_transformations(text, classic_prob, style_setting), []

        for rec in entities_list:
            rec["new_offset"] = rec["offset"]
            rec["new_length"] = rec["length"]

        boundaries = set([0, len(text)])
        protected = []
        for rec in entities_list:
            start = max(0, min(rec["offset"], len(text)))
            end = max(0, min(rec["offset"] + rec["length"], len(text)))
            if end <= start:
                continue
            boundaries.add(start)
            boundaries.add(end)
            if rec["type"] in self._ENTITY_NO_TRANSFORM:
                protected.append((start, end))

        points = sorted(boundaries)
        new_text_parts = []
        delta_by_pos = {p: 0 for p in points}
        cumulative_delta = 0

        for i in range(len(points) - 1):
            seg_start = points[i]
            seg_end = points[i + 1]
            if seg_end <= seg_start:
                new_text_parts.append(text[seg_start:seg_end])
                continue
            segment = text[seg_start:seg_end]
            is_protected = any(p_start <= seg_start and seg_end <= p_end for p_start, p_end in protected)
            if is_protected or not segment.strip():
                new_segment = segment
            else:
                new_segment = self.apply_cute_transformations(segment, classic_prob, style_setting)
            new_text_parts.append(new_segment)
            seg_delta = len(new_segment) - len(segment)
            delta_by_pos[seg_end] = seg_delta
            cumulative_delta += seg_delta

        new_text = "".join(new_text_parts)

        for rec in entities_list:
            old_start = max(0, min(rec["offset"], len(text)))
            old_end = max(0, min(rec["offset"] + rec["length"], len(text)))
            new_start = old_start
            new_end = old_end
            for p in points:
                if p <= old_start:
                    new_start += delta_by_pos.get(p, 0)
                if p < old_end:
                    new_end += delta_by_pos.get(p, 0)
            new_start = max(0, min(new_start, len(new_text)))
            new_end = max(new_start, min(new_end, len(new_text)))
            rec["new_offset"] = new_start
            rec["new_length"] = max(0, new_end - new_start)

        return new_text, entities_list

    def _html_escape(self, value):
        return value.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")

    def _entities_to_html(self, text, entities_list):
        if not entities_list:
            return None
        spans = []
        for rec in entities_list:
            typ = rec["type"]
            tag_info = self._ENTITY_HTML_TAG.get(typ)
            if not tag_info or tag_info[0] is None:
                continue
            start = max(0, min(rec["offset"], len(text)))
            end = max(0, min(rec["offset"] + rec["length"], len(text)))
            if end <= start:
                continue
            spans.append((start, end, tag_info, rec))
        if not spans:
            return None
        spans.sort(key=lambda s: (s[0], -(s[1] - s[0])))
        out = []
        cursor = 0
        open_stack = []
        positions = sorted({s[0] for s in spans} | {s[1] for s in spans} | {0, len(text)})
        for pos in positions:
            if pos > cursor:
                out.append(self._html_escape(text[cursor:pos]))
            closing = [s for s in open_stack if s[1] == pos]
            for s in reversed(closing):
                tag = s[2][1]
                attrs = ""
                if tag == "a" and s[3].get("url"):
                    attrs = f' href="{self._html_escape(s[3]["url"])}"'
                out.append(f"</{tag.split(' ', 1)[0]}>")
                open_stack.remove(s)
            opening = [s for s in spans if s[0] == pos and s not in open_stack]
            for s in opening:
                tag = s[2][0]
                if tag is None:
                    continue
                if tag == "pre" and s[3].get("language"):
                    out.append(f'<pre language="{self._html_escape(s[3]["language"])}">')
                elif tag == "a" and s[3].get("url"):
                    out.append(f'<a href="{self._html_escape(s[3]["url"])}">')
                else:
                    out.append(f"<{tag}>")
                open_stack.append(s)
            cursor = pos
        if cursor < len(text):
            out.append(self._html_escape(text[cursor:]))
        for s in reversed(open_stack):
            out.append(f"</{s[2][1]}>")
        return "".join(out)

    def _transform_uwu_speak(self, text):
        text = text.replace("r", "w").replace("l", "w").replace("R", "W").replace("L", "W")
        text = text.replace("СҖ", "РІ").replace("Р»", "РІ").replace("Р ", "Р’").replace("Рӣ", "Р’")
        return text

    def _transform_stutter(self, word):
        if len(word) > 1 and self.letter_pattern.match(word) and "-" not in word:
            first_char = word[0]
            stutter_prefix = first_char.lower() + "-"
            if random.random() < 0.4:
                stutter_prefix += first_char.lower() + "-"
            return stutter_prefix + word
        return word

    def _transform_vowel_stretch(self, word, stretch_probability, max_stretch_factor, vowels_for_lang):
        if not word or not vowels_for_lang:
            return word
        output_chars = []
        for char_w in word:
            output_chars.append(char_w)
            if char_w in vowels_for_lang and random.random() < stretch_probability:
                current_streak = 0
                for k_idx in range(len(output_chars) - 1, -1, -1):
                    if output_chars[k_idx] == char_w:
                        current_streak += 1
                    else:
                        break
                if current_streak < max_stretch_factor:
                    num_additional_chars = random.randint(1, max_stretch_factor - current_streak)
                    output_chars.extend([char_w] * num_additional_chars)
        return "".join(output_chars)

    def _transform_exclamations(self, ending_punctuation):
        def replace_match(match):
            return random.choice(self.extended_exclamations)

        return re.sub(r"!", replace_match, ending_punctuation)

    def apply_cute_transformations(self, text, classic_effects_probability, style_setting):
        apply_lowercase = self.get_setting("enable_lowercase", False)
        apply_uwu_speak = self.get_setting("enable_uwu_speak", False)

        enable_uwu_suffixes = self.get_setting("enable_uwu_suffixes", False)
        uwu_suffix_prob = self._get_frequency_prob_for_new_effects("uwu_suffix_frequency")

        enable_stutter = self.get_setting("enable_stuttering", False)
        stutter_prob = self._get_frequency_prob_for_new_effects("stuttering_frequency")

        enable_vowel_stretch = self.get_setting("enable_vowel_stretching", False)
        vowel_stretch_word_prob = self._get_frequency_prob_for_new_effects("vowel_stretching_frequency")
        vowel_stretch_per_vowel_prob = 0.6
        max_vowel_stretch_idx = self.get_setting("vowel_stretching_max_length", 0)
        max_stretch_factor = 2 if max_vowel_stretch_idx == 0 else 3

        enable_soft_sign = self.get_setting("enable_soft_sign", False)
        soft_sign_prob = self._get_frequency_prob_for_new_effects("soft_sign_frequency")

        enable_cute_punctuation = self.get_setting("enable_cute_punctuation", False)
        cute_punctuation_prob = self._get_frequency_prob_for_new_effects("cute_punctuation_frequency")

        enable_cute_actions = self.get_setting("enable_cute_actions", False)
        cute_actions_prob = self._get_frequency_prob_for_new_effects("cute_actions_frequency")
        actions_on_new_line = self.get_setting("actions_on_new_line", False)
        current_cute_actions = self.cute_actions_map.get(locali.language, self.cute_actions_map["en"])

        enable_text_borders = self.get_setting("enable_text_borders", False)
        text_borders_prob = self._get_frequency_prob_for_new_effects("text_borders_frequency", 2)

        theme_idx = self.get_setting("theme_selector", 0)
        current_theme = None
        if theme_idx > 0:
            theme_names = list(self.themes.keys())
            if theme_idx - 1 < len(theme_names):
                current_theme = self.themes[theme_names[theme_idx - 1]]
        elif random.random() < 0.3:
            current_theme = random.choice(list(self.themes.values()))

        if apply_lowercase:
            text = self._transform_lowercase(text)
        if apply_uwu_speak:
            text = self._transform_uwu_speak(text)

        sentences = re.split(r"([.!?]+\s*)", text)
        result_parts = []

        if current_theme and random.random() < 0.7:
            if len(text) < 100 and random.random() < 0.5:
                prefix = random.choice(current_theme["prefix"])
                suffix = random.choice(current_theme["suffix"])
                if random.random() < 0.3:
                    text = f"{prefix} {text} {suffix}"

            if len(text) > 20 and random.random() < 0.3:
                theme_word = random.choice(current_theme["words"])
                theme_emoji = random.choice(current_theme["emojis"])
                insert_text = f" {theme_word} {theme_emoji} "
                words = text.split()
                if len(words) > 5:
                    insert_pos = random.randint(2, len(words) - 2)
                    words.insert(insert_pos, insert_text)
                    text = " ".join(words)
                    sentences = re.split(r"([.!?]+\s*)", text)

        for i in range(0, len(sentences), 2):
            sentence_part = sentences[i].strip() if i < len(sentences) else ""
            ending_punctuation = sentences[i + 1] if i + 1 < len(sentences) else ""

            if not sentence_part and ending_punctuation:
                if (style_setting == 2 or style_setting == 3) and "!" in ending_punctuation:
                    if random.random() < classic_effects_probability:
                        ending_punctuation = self._transform_exclamations(ending_punctuation)
                if enable_cute_punctuation and random.random() < cute_punctuation_prob:
                    if "?" in ending_punctuation and self.cute_question_mark_replacements:
                        m = re.search(r"([?!]+)(\s*)$", ending_punctuation)
                        if m and "?" in m.group(1):
                            ending_punctuation = (
                                ending_punctuation[: m.start(1)]
                                + random.choice(self.cute_question_mark_replacements)
                                + m.group(2)
                            )
                    elif (
                        "." in ending_punctuation and "..." not in ending_punctuation and self.cute_period_replacements
                    ):
                        m = re.search(r"(\.+)(\s*)$", ending_punctuation)
                        if m and len(m.group(1)) == 1:
                            ending_punctuation = (
                                ending_punctuation[: m.start(1)]
                                + random.choice(self.cute_period_replacements)
                                + m.group(2)
                            )
                result_parts.append(ending_punctuation)
                continue

            if not sentence_part and not ending_punctuation:
                continue

            words = sentence_part.split()
            processed_words = []
            for word_idx, word in enumerate(words):
                leading_punc, temp_word, trailing_punc = "", word, ""
                m_lead = re.match(r"^([^\w\s]+)", temp_word)
                if m_lead:
                    leading_punc, temp_word = m_lead.group(1), temp_word[len(leading_punc) :]
                m_trail = re.search(r"([^\w\s]+)$", temp_word)
                if m_trail:
                    trailing_punc, temp_word = m_trail.group(1), temp_word[: -len(trailing_punc)]

                if not temp_word:
                    processed_words.append(word)
                    continue

                vowels_for_word = self.vowels_map["ru"] if self._is_cyrillic(temp_word) else self.vowels_map["en"]

                if enable_stutter and random.random() < stutter_prob:
                    temp_word = self._transform_stutter(temp_word)

                if enable_vowel_stretch and random.random() < vowel_stretch_word_prob:
                    temp_word = self._transform_vowel_stretch(
                        temp_word, vowel_stretch_per_vowel_prob, max_stretch_factor, vowels_for_word
                    )

                if (
                    enable_soft_sign
                    and temp_word
                    and temp_word[-1].lower() in self.consonants_ru
                    and temp_word[-1].lower() not in "СҢСҠ"
                    and random.random() < soft_sign_prob
                ):
                    if len(temp_word) > 1 or temp_word[-1].lower() != "Р№":
                        temp_word += "СҢ"

                processed_words.append(leading_punc + temp_word + trailing_punc)
            sentence_part = " ".join(processed_words)

            if style_setting == 0 or style_setting == 3:
                words_for_emojis = sentence_part.split()
                emoji_list = self.emojis
                if current_theme and random.random() < 0.7:
                    emoji_list = current_theme["emojis"]
                sentence_part = " ".join(
                    w + (f" {random.choice(emoji_list)}" if w and random.random() < classic_effects_probability else "")
                    for w in words_for_emojis
                ).strip()

            if style_setting == 1 or style_setting == 3:
                if random.random() < classic_effects_probability:
                    sentence_part = (sentence_part + f" {random.choice(self.kaomojis)}").strip()

            if enable_uwu_suffixes and random.random() < uwu_suffix_prob:
                if sentence_part:
                    sentence_part += f" {random.choice(self.uwu_suffixes)}"
                else:
                    sentence_part = random.choice(self.uwu_suffixes)
                sentence_part = sentence_part.strip()

            if enable_cute_punctuation and random.random() < cute_punctuation_prob:
                if "?" in ending_punctuation and self.cute_question_mark_replacements:
                    m = re.search(r"([?!]+)(\s*)$", ending_punctuation)
                    if m and "?" in m.group(1):
                        ending_punctuation = (
                            ending_punctuation[: m.start(1)]
                            + random.choice(self.cute_question_mark_replacements)
                            + m.group(2)
                        )
                elif "." in ending_punctuation and "..." not in ending_punctuation and self.cute_period_replacements:
                    m = re.search(r"(\.+)(\s*)$", ending_punctuation)
                    if m and len(m.group(1)) == 1:
                        ending_punctuation = (
                            ending_punctuation[: m.start(1)] + random.choice(self.cute_period_replacements) + m.group(2)
                        )

            if style_setting == 2 or style_setting == 3:
                if random.random() < classic_effects_probability * 0.7:
                    sentence_part = (
                        f"{random.choice(self.sparkles)} {sentence_part} {random.choice(self.sparkles)}".strip()
                    )
                if "!" in ending_punctuation and random.random() < classic_effects_probability:
                    ending_punctuation = self._transform_exclamations(ending_punctuation)

            if enable_text_borders and sentence_part and random.random() < text_borders_prob:
                if len(sentence_part) < 50:
                    borders = random.choice(self.text_borders)
                    sentence_part = f"{borders[0]}{sentence_part}{borders[1]}"

            result_parts.append(sentence_part)
            result_parts.append(ending_punctuation)

            if enable_cute_actions and sentence_part and current_cute_actions and random.random() < cute_actions_prob:
                action_str = random.choice(current_cute_actions)
                if actions_on_new_line:
                    if result_parts and result_parts[-1]:
                        result_parts[-1] = result_parts[-1].rstrip(" \t")
                    result_parts.append("\n" + action_str)
                else:
                    if result_parts and result_parts[-1] and not result_parts[-1].endswith((" ", "\n", "\t")):
                        result_parts.append(" " + action_str)
                    else:
                        result_parts.append(action_str)

        return "".join(result_parts)
