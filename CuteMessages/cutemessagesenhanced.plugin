    def _copy_to_clipboard(self, label, text):
        if AndroidUtilities.addToClipboard(text):
            BulletinHelper.show_info(f"Copied {label} to clipboard")

    def _get_frequency_prob_for_new_effects(self, setting_key, default_index=2):
        frequency_idx = self.get_setting(setting_key, default_index)
        if frequency_idx == 0:
            return 0.10
        if frequency_idx == 1:
            return 0.25
        if frequency_idx == 3:
            return 0.75
        if frequency_idx == 4:
            return 1.00
        return 0.5

    def _open_plugin_settings(self, java_plugin):
        try:
            get_last_fragment().presentFragment(PluginSettingsActivity(java_plugin))
        except Exception as e:
            log(f"[{__id__}] Error opening plugin settings: {e}")

    def _add_settings_menu_items(self):
        try:
            if not self._drawer_settings_item:
                self._drawer_settings_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.DRAWER_MENU,
                        text=locali.get_string("SETTINGS_HEADER"),
                        icon="menu_premium_effects",
                        priority=5,
                        on_click=lambda ctx: run_on_ui_thread(
                            lambda: self._open_plugin_settings(PluginsController.getInstance().plugins.get(self.id))
                        ),
                    )
                )
            if not self._chat_settings_item:
                self._chat_settings_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.CHAT_ACTION_MENU,
                        text=locali.get_string("SETTINGS_HEADER"),
                        icon="menu_premium_effects",
                        priority=5,
                        on_click=lambda ctx: run_on_ui_thread(
                            lambda: self._open_plugin_settings(PluginsController.getInstance().plugins.get(self.id))
                        ),
                    )
                )
        except Exception as e:
            log(f"[{__id__}] Failed to add settings menu items: {e}")

    def _remove_settings_menu_items(self):
        try:
            if self._drawer_settings_item:
                self.remove_menu_item(self._drawer_settings_item)
                self._drawer_settings_item = None
            if self._chat_settings_item:
                self.remove_menu_item(self._chat_settings_item)
                self._chat_settings_item = None
        except Exception as e:
            log(f"[{__id__}] Failed to remove settings menu items: {e}")

    def _on_show_settings_buttons_change(self, enabled: bool):
        def _toggle():
            try:
                if enabled:
                    self._add_settings_menu_items()
                else:
                    self._remove_settings_menu_items()
            except Exception as e:
                log(f"[{__id__}] Failed toggling settings buttons: {e}")

        run_on_ui_thread(_toggle)

    def _show_bulletin(self, message):
        run_on_ui_thread(lambda: BulletinHelper.show_info(message))

    def _ctx_get(self, context, key):
        if context is None:
            return None
        if isinstance(context, dict):
            return context.get(key)
        if hasattr(context, "get"):
            try:
                return context.get(key)
            except Exception:
                pass
        return None

    def _get_chat_filter_mode(self):
        try:
            return int(self.get_setting("chat_filter_mode", 0) or 0)
        except (TypeError, ValueError):
            return 0

    def _reload_plugin_settings(self):
        try:
            self.set_setting("chat_filter_mode", self._get_chat_filter_mode(), reload_settings=True)
        except Exception as e:
            log(f"[{__id__}] reload plugin settings failed: {e}")

    def _normalize_dialog_id(self, peer):
        if peer is None:
            return 0
        try:
            if hasattr(peer, "getClass"):
                return int(DialogObject.getPeerDialogId(peer))
            return int(peer)
        except Exception:
            try:
                return int(peer)
            except Exception:
                return 0

    def _message_ids_from_obj(self, message):
        ids = set()
        if message is None:
            return ids
        for getter in ("getId", "getRealId", "getStableId"):
            if hasattr(message, getter):
                try:
                    mid = int(getattr(message, getter)())
                    ids.add(mid)
                except Exception:
                    pass
        owner = getattr(message, "messageOwner", None)
        if owner is not None:
            try:
                ids.add(int(getattr(owner, "id", 0)))
            except Exception:
                pass
        return ids

    def _message_id_from_obj(self, message):
        ids = self._message_ids_from_obj(message)
        return next(iter(ids), None)

    def _message_id_from_ctx(self, context):
        for key in ("message_id", "msg_id", "messageId"):
            val = self._ctx_get(context, key)
            if val is not None:
                try:
                    return int(val)
                except Exception:
                    pass
        return self._message_id_from_obj(self._ctx_get(context, "message"))

    def _pop_undo_cache_key(self, key):
        record = self._undo_cache.pop(key, None)
        if record is None:
            return None
        try:
            self._undo_cache_order.remove(key)
        except ValueError:
            pass
        for alias_key in list(self._undo_cache.keys()):
            if self._undo_cache.get(alias_key) is record:
                self._undo_cache.pop(alias_key, None)
                try:
                    self._undo_cache_order.remove(alias_key)
                except ValueError:
                    pass
        return record

    def _find_undo_record(self, dialog_id, msg_id, message=None):
        did = int(dialog_id) if dialog_id is not None else None
        msg_ids = set()
        if msg_id is not None:
            try:
                msg_ids.add(int(msg_id))
            except Exception:
                pass
        if message is not None:
            msg_ids.update(self._message_ids_from_obj(message))

        for mid in msg_ids:
            if did is not None:
                key = (did, mid)
                record = self._pop_undo_cache_key(key)
                if record is not None:
                    return key, record
            for cache_key in list(self._undo_cache_order):
                if cache_key[1] == mid:
                    record = self._pop_undo_cache_key(cache_key)
                    if record is not None:
                        log(f"[{__id__}] undo fallback by msg_id: wanted={(did, mid)}, found={cache_key}")
                        return cache_key, record

        if did is not None:
            for cache_key in reversed(self._undo_cache_order):
                if cache_key[0] == did:
                    record = self._pop_undo_cache_key(cache_key)
                    if record is not None:
                        log(f"[{__id__}] undo fallback latest for dialog: {did}, key={cache_key}")
                        return cache_key, record

        for cache_key in reversed(self._undo_cache_order):
            record = self._pop_undo_cache_key(cache_key)
            if record is not None:
                log(f"[{__id__}] undo fallback latest global: key={cache_key}")
                return cache_key, record

        log(f"[{__id__}] undo miss: dialog_id={did}, msg_ids={sorted(msg_ids)}, cache={list(self._undo_cache.keys())}")
        return None, None

    def _dialog_id_from_fragment(self):
        try:
            fragment = get_last_fragment()
            if fragment is not None and hasattr(fragment, "getDialogId"):
                return int(fragment.getDialogId())
        except Exception:
            pass
        return None

    def _get_chat_list_menu_icon(self, dialog_id=None):
        mode = self._get_chat_filter_mode()
        if mode == 2:
            return "msg_block"
        return "msg_favorite"

    def _get_chat_list_menu_text(self, dialog_id=None):
        mode = self._get_chat_filter_mode()
        if mode == 0:
            return locali.get_string("CHAT_WHITELIST_ADD_BTN")
        if mode == 1:
            in_list = dialog_id is not None and int(dialog_id) in self._get_chat_list("chat_whitelist")
            key = "CHAT_WHITELIST_REMOVE_BTN" if in_list else "CHAT_WHITELIST_ADD_BTN"
        else:
            in_list = dialog_id is not None and int(dialog_id) in self._get_chat_list("chat_blacklist")
            key = "CHAT_BLACKLIST_REMOVE_BTN" if in_list else "CHAT_BLACKLIST_ADD_BTN"
        return locali.get_string(key)

    def _update_chat_list_menu_text(self, dialog_id=None):
        def _do_update():
            try:
                if dialog_id is None:
                    resolved_id = self._dialog_id_from_fragment()
                else:
                    resolved_id = dialog_id
                if resolved_id is not None:
                    resolved_id = int(resolved_id)
                text = self._get_chat_list_menu_text(resolved_id)
                icon = self._get_chat_list_menu_icon(resolved_id)
                if (
                    text == self._chat_list_menu_text
                    and icon == self._chat_list_menu_icon
                    and resolved_id == self._chat_list_menu_dialog_id
                    and self._chat_list_menu_item
                ):
                    return
                if self._chat_list_menu_item:
                    self.remove_menu_item(self._chat_list_menu_item)
                    self._chat_list_menu_item = None
                self._chat_list_menu_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.CHAT_ACTION_MENU,
                        text=text,
                        icon=icon,
                        item_id=f"{__id__}_chat_list",
                        priority=4,
                        on_click=self._on_chat_list_toggle_click,
                    )
                )
                self._chat_list_menu_text = text
                self._chat_list_menu_icon = icon
                self._chat_list_menu_dialog_id = resolved_id
            except Exception as e:
                log(f"[{__id__}] Failed updating chat list menu text: {e}\n{traceback.format_exc()}")

        run_on_ui_thread(_do_update)

    def _install_chat_dialog_hook(self):
        try:
            ca_cls = find_class("org.telegram.ui.ChatActivity")
            if not ca_cls:
                return

            plugin = self

            class _ChatDialogHook(MethodHook):
                def after_hooked_method(self, param):
                    try:
                        chat = param.thisObject
                        if chat is not None and hasattr(chat, "getDialogId"):
                            plugin._update_chat_list_menu_text(int(chat.getDialogId()))
                    except Exception:
                        pass

            refs = self.hook_all_methods(ca_cls, "onTransitionAnimationEnd", _ChatDialogHook())
            if refs:
                self._chat_dialog_hooks.extend(refs)
        except Exception as e:
            log(f"[{__id__}] chat dialog hook failed: {e}\n{traceback.format_exc()}")

    def _uninstall_chat_dialog_hook(self):
        for ref in self._chat_dialog_hooks:
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._chat_dialog_hooks = []

    def _add_chat_action_items(self):
        if self._chat_list_menu_item:
            self._update_chat_list_menu_text()
            return
        self._update_chat_list_menu_text()

    def _remove_chat_action_items(self):
        try:
            if self._chat_list_menu_item:
                self.remove_menu_item(self._chat_list_menu_item)
                self._chat_list_menu_item = None
                self._chat_list_menu_text = None
                self._chat_list_menu_icon = None
                self._chat_list_menu_dialog_id = None
        except Exception as e:
            log(f"[{__id__}] Failed removing chat action items: {e}")

    def _add_undo_menu_item(self):
        try:
            if not self._undo_menu_item:
                self._undo_menu_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                        text=locali.get_string("UNDO_RESTORE"),
                        subtext=locali.get_string("UNDO_RESTORE_SUB"),
                        icon="msg_edit",
                        priority=10,
                        on_click=self._on_undo_restore_click,
                    )
                )
        except Exception as e:
            log(f"[{__id__}] Failed adding undo menu item: {e}")

    def _remove_undo_menu_item(self):
        try:
            if self._undo_menu_item:
                self.remove_menu_item(self._undo_menu_item)
                self._undo_menu_item = None
        except Exception as e:
            log(f"[{__id__}] Failed removing undo menu item: {e}")

    def _dialog_id_from_ctx(self, context):
        for key in ("dialog_id", "chatId", "chat_id", "peer"):
            val = self._ctx_get(context, key)
            if val is not None:
                try:
                    return int(val)
                except Exception:
                    return val

        user_id = self._ctx_get(context, "userId")
        if user_id is not None:
            try:
                return int(user_id)
            except Exception:
                pass

        fragment = self._ctx_get(context, "fragment")
        if fragment is not None and hasattr(fragment, "getDialogId"):
            try:
                return int(fragment.getDialogId())
            except Exception:
                pass

        nested = self._ctx_get(context, "context")
        if nested is not None and nested is not context:
            nested_id = self._dialog_id_from_ctx(nested)
            if nested_id is not None:
                return nested_id

        return None

    def _on_chat_list_toggle_click(self, context):
        try:
            mode = self._get_chat_filter_mode()
            if mode == 0:
                self._show_bulletin(locali.get_string("CHAT_LIST_TOGGLE_NO_MODE"))
                return
            dialog_id = self._dialog_id_from_ctx(context)
            if dialog_id is None:
                dialog_id = self._dialog_id_from_fragment()
            if dialog_id is None:
                log(
                    f"[{__id__}] toggle list: no dialog_id, keys={list(context.keys()) if isinstance(context, dict) else type(context)}"
                )
                self._show_bulletin(locali.get_string("CHAT_DIALOG_ID_ERROR"))
                return
            dialog_id = int(dialog_id)
            list_key = "chat_whitelist" if mode == 1 else "chat_blacklist"
            added = self._toggle_chat_in_list(list_key, dialog_id)
            if added is None:
                return
            if mode == 1:
                msg = locali.get_string("CHAT_WHITELIST_ADDED" if added else "CHAT_WHITELIST_REMOVED")
            else:
                msg = locali.get_string("CHAT_BLACKLIST_ADDED" if added else "CHAT_BLACKLIST_REMOVED")
            self._show_bulletin(msg)
            self._update_chat_list_menu_text(dialog_id)
        except Exception as e:
            log(f"[{__id__}] toggle chat list failed: {e}\n{traceback.format_exc()}")

    def _on_undo_restore_click(self, context):
        try:
            message = self._ctx_get(context, "message")
            dialog_id = self._dialog_id_from_ctx(context)
            if dialog_id is None and message is not None:
                try:
                    dialog_id = int(message.getDialogId())
                except Exception:
                    pass
            msg_id = self._message_id_from_ctx(context)
            key, record = self._find_undo_record(dialog_id, msg_id, message=message)
            if record is None:
                self._show_bulletin(locali.get_string("UNDO_NOTHING"))
                return

            def _do_edit():
                try:
                    text = record.get("text", "")
                    html = record.get("html")
                    log(
                        f"[{__id__}] undo edit: key={key}, msg_id={msg_id}, "
                        f"text_len={len(text)}, html={'yes' if html else 'no'}"
                    )
                    if html:
                        try:
                            edit_message(message, text=html, parse_mode="html")
                        except Exception:
                            try:
                                edit_message(message, text=html, parse_mode="HTML")
                            except Exception:
                                edit_message(message, text=text)
                    else:
                        edit_message(message, text=text)
                    BulletinHelper.show_info(locali.get_string("UNDO_RESTORED"))
                except Exception:
                    log(f"[{__id__}] edit_message failed:\n{traceback.format_exc()}")
                    BulletinHelper.show_info(locali.get_string("UNDO_NOTHING"))

            run_on_ui_thread(_do_edit)
        except Exception as e:
            log(f"[{__id__}] undo restore failed: {e}\n{traceback.format_exc()}")

    def _is_cyrillic(self, text):
        return bool(re.search("[Р°-СҸРҗ-РҜ]", text))

    def _get_chat_list(self, key):
        raw = self.get_setting(key, "[]")
        try:
            data = json.loads(raw) if isinstance(raw, str) else raw
            if isinstance(data, list):
                return [int(x) for x in data if x is not None]
        except Exception:
            log(f"[{__id__}] {key} parse error: {traceback.format_exc()}")
        return []

    def _set_chat_list(self, key, ids, reload_settings=True):
        self.set_setting(key, json.dumps([int(i) for i in ids]), reload_settings=reload_settings)
        if self._chat_list_menu_item and key == self._active_chat_list_key():
            self._update_chat_list_menu_text()

    def _active_chat_list_key(self):
        mode = self._get_chat_filter_mode()
        if mode == 1:
            return "chat_whitelist"
        if mode == 2:
            return "chat_blacklist"
        return None

    def _get_dialog_title(self, dialog_id):
        try:
            mc = get_messages_controller()
            dialog_id = int(dialog_id)
            if DialogObject.isUserDialog(dialog_id):
                user = mc.getUser(dialog_id)
                if user is not None:
                    name = UserObject.getUserName(user)
                    if name:
                        return str(name)
            else:
                chat_id = -dialog_id
                if chat_id > 1000000000000:
                    chat_id -= 1000000000000
                chat = mc.getChat(int(chat_id))
                if chat is not None:
                    title = ChatObject.getTitle(chat)
                    if title:
                        return str(title)
        except Exception:
            log(f"[{__id__}] get dialog title failed: {traceback.format_exc()}")
        return str(dialog_id)

    def _remove_chat_from_list(self, dialog_id):
        key = self._active_chat_list_key()
        if not key:
            return
        dialog_id = int(dialog_id)
        ids = self._get_chat_list(key)
        if dialog_id in ids:
            ids.remove(dialog_id)
            self._set_chat_list(key, ids, reload_settings=True)

    def _on_chat_filter_mode_change(self, new_index):
        try:
            mode = int(new_index)
        except (TypeError, ValueError):
            mode = 0
        self.set_setting("chat_filter_mode", mode, reload_settings=True)
        self._update_chat_list_menu_text()

    def _build_chat_filter_settings(self):
        mode = self._get_chat_filter_mode()
        if mode == 0:
            return [Divider(text=locali.get_string("CHAT_FILTER_HINT"))]

        key = self._active_chat_list_key()
        header_key = "CHAT_LIST_HEADER_WHITELIST" if mode == 1 else "CHAT_LIST_HEADER_BLACKLIST"
        items = [Header(text=locali.get_string(header_key))]
        chat_ids = self._get_chat_list(key)
        if not chat_ids:
            items.append(Text(text=locali.get_string("CHAT_LIST_EMPTY")))
        else:
            for dialog_id in chat_ids:
                title = self._get_dialog_title(dialog_id)

                def _make_remove(did):
                    def _on_remove(view):
                        self._remove_chat_from_list(did)

                    return _on_remove

                items.append(
                    Text(
                        text=title,
                        subtext=locali.get_string("CHAT_LIST_REMOVE"),
                        on_click=_make_remove(dialog_id),
                    )
                )
        items.append(Divider(text=locali.get_string("CHAT_FILTER_HINT")))
        return items

    def _toggle_chat_in_list(self, key, peer):
        if peer is None:
            return None
        peer = int(peer)
        ids = self._get_chat_list(key)
        if peer in ids:
            ids.remove(peer)
            self._set_chat_list(key, ids)
            return False
        ids.append(peer)
        self._set_chat_list(key, ids)
        return True

    def _should_apply_in_chat(self, peer):
        if peer is None:
            return True
        peer = int(peer)
        mode = self._get_chat_filter_mode()
        if mode == 1:
            return peer in self._get_chat_list("chat_whitelist")
        if mode == 2:
            return peer not in self._get_chat_list("chat_blacklist")
        return True

