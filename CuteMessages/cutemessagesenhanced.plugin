    def _export_preset_link(self):
        try:
            settings = self.export_settings() or {}
            if not self.get_setting("include_lists_export", False):
                for key in ("chat_whitelist", "chat_blacklist", "topic_whitelist"):
                    settings.pop(key, None)
            payload = {"v": PRESET_SCHEMA_VERSION, "plugin": __id__, "settings": settings}
            encoded = (
                base64.urlsafe_b64encode(json.dumps(payload, separators=(",", ":")).encode("utf-8"))
                .decode("ascii")
                .rstrip("=")
            )
            link = f"{DEEPLINK_SCHEME}?data={encoded}"
            if AndroidUtilities.addToClipboard(link):
                BulletinHelper.show_info(locali.get_string("PRESET_COPIED"))
        except Exception as e:
            log(f"[{__id__}] export preset failed: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))

    def _import_preset_from_clipboard(self):
        try:
            fragment = get_last_fragment()
            activity = fragment.getParentActivity() if fragment else None
            if activity is None:
                BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))
                return
            Context = find_class("android.content.Context")
            clipboard = activity.getSystemService(Context.CLIPBOARD_SERVICE)
            if clipboard is None:
                BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))
                return
            clip = clipboard.getPrimaryClip()
            if clip is None or clip.getItemCount() == 0:
                BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))
                return
            text = str(clip.getItemAt(0).getText() or "").strip()
            self._apply_preset_link(text)
        except Exception as e:
            log(f"[{__id__}] import preset clipboard failed: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))

    def _apply_preset_link(self, url):
        try:
            if not url or DEEPLINK_SCHEME not in url:
                BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))
                return
            data_part = url.split("data=", 1)[-1]
            padding = "=" * (-len(data_part) % 4)
            raw = base64.urlsafe_b64decode((data_part + padding).encode("ascii"))
            payload = json.loads(raw.decode("utf-8"))
            if payload.get("plugin") != __id__:
                BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))
                return
            settings = payload.get("settings")
            if not isinstance(settings, dict):
                BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))
                return
            self.import_settings(settings, reload_settings=True)
            self._apply_language_from_settings()
            self._update_chat_list_menu_text()
            self._update_topic_menu_text()
            BulletinHelper.show_info(locali.get_string("PRESET_APPLIED"))
        except Exception as e:
            log(f"[{__id__}] apply preset failed: {e}\n{traceback.format_exc()}")
            BulletinHelper.show_info(locali.get_string("PRESET_ERROR"))

    def _install_deeplink_hook(self):
        try:
            Uri = find_class("android.net.Uri")
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            if not LaunchActivity or not Uri:
                return
            plugin = self

            class _DeeplinkHook(MethodHook):
                def before_hooked_method(self, param):
                    try:
                        if len(param.args) < 1:
                            return
                        intent = param.args[0]
                        if not intent or intent.getAction() != "android.intent.action.VIEW":
                            return
                        data = intent.getData()
                        if not data:
                            return
                        url = str(data)
                        if url.startswith(DEEPLINK_SCHEME):
                            encoded = Uri.parse(url).getQueryParameter("data")
                            if encoded:
                                run_on_queue(lambda: plugin._apply_preset_link(f"{DEEPLINK_SCHEME}?data={encoded}"))
                            param.setResult(None)
                    except Exception as e:
                        log(f"[{__id__}] deeplink hook error: {e}")

            method = LaunchActivity.getClass().getDeclaredMethod(
                "handleIntent",
                find_class("android.content.Intent").getClass(),
                find_class("java.lang.Boolean").TYPE,
                find_class("java.lang.Boolean").TYPE,
                find_class("java.lang.Boolean").TYPE,
                find_class("org.telegram.messenger.browser.Browser$Progress").getClass(),
                find_class("java.lang.Boolean").TYPE,
                find_class("java.lang.Boolean").TYPE,
            )
            method.setAccessible(True)
            self._deeplink_hook_ref = self.hook_method(method, _DeeplinkHook())
        except Exception as e:
            log(f"[{__id__}] deeplink hook install failed: {e}\n{traceback.format_exc()}")

    def _uninstall_deeplink_hook(self):
        if self._deeplink_hook_ref:
            try:
                self.unhook_method(self._deeplink_hook_ref)
            except Exception:
                pass
            self._deeplink_hook_ref = None

    def _queue_auto_reaction(self, dialog_id, emoji):
        if not emoji:
            return
        self._pending_reactions.append({"dialog_id": int(dialog_id), "emoji": str(emoji)})

    def _send_auto_reaction(self, dialog_id, msg_id, emoji):
        try:
            req = TLRPC.TL_messages_sendReaction()
            req.peer = get_messages_controller().getInputPeer(int(dialog_id))
            req.msg_id = int(msg_id)
            req.big = False
            req.add_to_recent = False
            reaction = TLRPC.TL_reactionEmoji()
            reaction.emoticon = str(emoji)
            req.reaction = ArrayList()
            req.reaction.add(reaction)
            send_request(req, lambda resp, err: None)
        except Exception as e:
            log(f"[{__id__}] send reaction failed: {e}\n{traceback.format_exc()}")

    def _process_pending_reactions(self, msg_ids, dialog_id):
        if not self._pending_reactions or not msg_ids:
            return
        remaining = []
        sent = False
        for item in self._pending_reactions:
            if sent:
                remaining.append(item)
                continue
            if int(item["dialog_id"]) == int(dialog_id):
                mid = sorted(int(x) for x in msg_ids)[0]
                self._send_auto_reaction(item["dialog_id"], mid, item["emoji"])
                sent = True
            else:
                remaining.append(item)
        self._pending_reactions = remaining

    def _show_stop_word_dialog(self, dialog_id, sender_name):
        if dialog_id in self._stop_word_prompted:
            return
        self._stop_word_prompted.add(dialog_id)

        def _show():
            try:
                fragment = get_last_fragment()
                activity = fragment.getParentActivity() if fragment else None
                if activity is None:
                    return
                builder = AlertDialogBuilder(activity)
                builder.set_title(locali.get_string("STOP_WORD_CONFIRM_TITLE"))
                builder.set_message(
                    locali.get_string("STOP_WORD_CONFIRM_MSG").replace("{name}", sender_name or str(dialog_id))
                )
                builder.set_positive_button(
                    locali.get_string("ADD"), lambda b, w: self._confirm_stop_word_blacklist(dialog_id)
                )
                builder.set_negative_button(locali.get_string("CANCEL"), lambda b, w: None)
                builder.show()
            except Exception as e:
                log(f"[{__id__}] stop word dialog failed: {e}\n{traceback.format_exc()}")

        run_on_ui_thread(_show)

    def _confirm_stop_word_blacklist(self, dialog_id):
        try:
            dialog_id = int(dialog_id)
            ids = self._get_chat_list("chat_blacklist")
            if dialog_id not in ids:
                ids.append(dialog_id)
                self._set_chat_list("chat_blacklist", ids, reload_settings=True)
            if self._get_chat_filter_mode() == 0:
                self.set_setting("chat_filter_mode", 2, reload_settings=True)
            self._show_bulletin(locali.get_string("STOP_WORD_ADDED"))
            self._update_chat_list_menu_text(dialog_id)
        except Exception as e:
            log(f"[{__id__}] confirm stop word failed: {e}\n{traceback.format_exc()}")

    def _check_incoming_stop_word(self, message):
        if not self.get_setting("stop_word_enabled", False):
            return
        stop_word = str(self.get_setting("stop_word", "") or "").strip()
        if not stop_word:
            return
        if message is None:
            return
        try:
            if bool(getattr(message, "out", False)):
                return
        except Exception:
            pass
        text = str(getattr(message, "message", "") or "")
        if stop_word.lower() not in text.lower():
            return
        dialog_id = self._normalize_dialog_id(getattr(message, "peer_id", None))
        if not dialog_id:
            return
        if dialog_id in self._get_chat_list("chat_blacklist"):
            return
        sender = ""
        try:
            peer = getattr(message, "from_id", None)
            if peer is not None and hasattr(peer, "user_id"):
                user = get_messages_controller().getUser(int(peer.user_id))
                if user is not None:
                    sender = str(UserObject.getUserName(user))
        except Exception:
            pass
        self._show_stop_word_dialog(dialog_id, sender)

    def _pick_premium_emoji(self, emoji_char):
        if not self.get_setting("use_premium_emoji", False):
            return emoji_char, None
        doc_id = self._premium_replace_map().get(emoji_char)
        if not doc_id:
            return emoji_char, None
        return emoji_char, doc_id

    def _append_premium_emoji_entity(self, entities_list, text, py_start, py_end, document_id):
        try:
            utf16_start = _py_to_utf16_offset(text, py_start)
            utf16_length = _py_to_utf16_offset(text, py_end) - utf16_start
            ent = TLRPC.TL_messageEntityCustomEmoji()
            ent.offset = int(utf16_start)
            ent.length = int(utf16_length)
            ent.document_id = int(document_id)
            entities_list.append(
                {
                    "offset": int(utf16_start),
                    "length": int(utf16_length),
                    "type": "MessageEntityCustomEmoji",
                    "url": None,
                    "language": None,
                    "document_id": int(document_id),
                    "java": ent,
                    "new_offset": int(utf16_start),
                    "new_length": int(utf16_length),
                }
            )
        except Exception as e:
            log(f"[{__id__}] premium emoji entity failed: {e}")

    def _is_nature_theme(self):
        return int(self.get_setting("theme_selector", 0) or 0) == 3

    def _shift_entity_offsets(self, entities_list, delta, start_index=0, end_index=None):
        if not delta or not entities_list:
            return
        end = len(entities_list) if end_index is None else end_index
        for rec in entities_list[start_index:end]:
            for key in ("offset", "new_offset"):
                if key in rec:
                    rec[key] = int(rec[key]) + int(delta)
            java_ent = rec.get("java")
            if java_ent is not None:
                try:
                    java_ent.offset = int(rec.get("new_offset", rec.get("offset", 0)))
                except Exception:
                    pass

    def _build_premium_block_text(self, item):
        slot_rows = self._premium_slot_rows(item)
        layout = item.get("layout", "horizontal")
        if layout == "grid" or len(slot_rows) > 1:
            return "\n".join("".join(row) for row in slot_rows)
        return "".join(slot_rows[0])

    def _append_premium_block_entities(self, entities_list, text, py_base_offset, item, used_doc_ids=None):
        if used_doc_ids is None:
            used_doc_ids = set()
        slot_rows = self._premium_slot_rows(item)
        pos = int(py_base_offset)
        layout = item.get("layout", "horizontal")
        rows = item.get("rows")
        if layout == "grid" and rows:
            for row_index, row in enumerate(rows):
                slot_row = slot_rows[row_index]
                for col_index, doc_id in enumerate(row):
                    if int(doc_id) in used_doc_ids:
                        slot = slot_row[col_index]
                        pos += len(slot)
                        continue
                    slot = slot_row[col_index]
                    slot_len = len(slot)
                    self._append_premium_emoji_entity(entities_list, text, pos, pos + slot_len, doc_id)
                    used_doc_ids.add(int(doc_id))
                    pos += slot_len
                if row_index < len(rows) - 1:
                    pos += 1
            return
        doc_ids = item.get("ids") or []
        slots = slot_rows[0]
        for idx, doc_id in enumerate(doc_ids):
            slot = slots[idx] if idx < len(slots) else _PREMIUM_SLOT_DEFAULT
            slot_len = len(slot)
            if int(doc_id) in used_doc_ids:
                pos += slot_len
                continue
            self._append_premium_emoji_entity(entities_list, text, pos, pos + slot_len, doc_id)
            used_doc_ids.add(int(doc_id))
            pos += slot_len

    def _is_large_premium_block(self, item):
        if item.get("block_line"):
            return True
        if item.get("layout") == "grid" or item.get("rows"):
            return True
        ids = item.get("ids") or []
        return len(ids) >= 4

    def _premium_block_pick_weight(self, item):
        weight = max(1, int(item.get("weight", 1)))
        if self._is_large_premium_block(item):
            return weight * 4
        return weight

    def _inject_premium_block_pool(self, text, entities_list, blocks, chance):
        if not blocks or random.random() > chance:
            return text, entities_list, False

        used_doc_ids = self._premium_doc_ids_in_entities(entities_list)
        candidates = [b for b in blocks if not self._premium_block_conflicts(b, used_doc_ids)]
        if not candidates:
            return text, entities_list, False

        weights = [self._premium_block_pick_weight(b) for b in candidates]
        block = random.choices(candidates, weights=weights, k=1)[0]
        block_text = self._build_premium_block_text(block)
        if not block_text:
            return text, entities_list, False

        force_new_line = bool(block.get("block_line"))
        position = random.choice(["top", "bottom"])

        if position == "top":
            sep = "\n" if text else ""
            prefix = block_text + sep
            self._shift_entity_offsets(entities_list, _utf16_len(prefix))
            text = prefix + text
            self._append_premium_block_entities(entities_list, text, 0, block, used_doc_ids)
        else:
            sep = "\n" if force_new_line and text and not text.endswith("\n") else ""
            if force_new_line and text and not text.endswith("\n"):
                sep = "\n"
            elif not force_new_line and text and not text.endswith((" ", "\n", "\t")):
                sep = " "
            else:
                sep = sep or ""
            py_offset = len(text) + len(sep)
            text = text + sep + block_text
            self._append_premium_block_entities(entities_list, text, py_offset, block, used_doc_ids)
        return text, entities_list, True

    def _inject_theme_premium_blocks(self, text, entities_list):
        if not self.get_setting("use_premium_emoji", False):
            return text, entities_list
        is_nature = self._is_nature_theme()
        if is_nature:
            blocks = self._premium_nature_blocks() + self._premium_decoration_blocks()
            chance = self._get_premium_emoji_chance(1.15)
        else:
            blocks = self._premium_decoration_blocks()
            chance = self._get_premium_emoji_chance()
        large_blocks = [b for b in blocks if self._is_large_premium_block(b)]
        small_blocks = [b for b in blocks if not self._is_large_premium_block(b)]
        large_chance = min(1.0, chance * 0.65)
        text, entities_list, injected = self._inject_premium_block_pool(text, entities_list, large_blocks, large_chance)
        if injected:
            return text, entities_list
        text, entities_list, _ = self._inject_premium_block_pool(text, entities_list, small_blocks, chance)
        return text, entities_list

    def _inject_mur_premium_bands(self, text, entities_list):
        if not self.get_setting("use_premium_emoji", False):
            return text, entities_list
        if not self.get_setting("enable_uwu_speak", False):
            return text, entities_list
        text, entities_list, _ = self._inject_premium_block_pool(
            text, entities_list, self._premium_mur_bands(), self._get_premium_emoji_chance(0.85)
        )
        return text, entities_list

