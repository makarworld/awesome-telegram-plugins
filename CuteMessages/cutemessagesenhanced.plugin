# Custom emoji: список записей с document_id.
# replace — подмена unicode (use_premium_emoji).
# nature — составной блок при природной теме (ids всегда вместе).
# decoration — составной блок при любой теме (use_premium_emoji).
# mur — горизонтальная полоса adapemoji при UwU/мур-стиле (пак не в общем декоре).
# block_line — крупный блок на отдельной строке сверху/снизу.
# Источник: .tools/emoji-pack-semantic/output/*/agent_index.json
# slot — unicode-fallback в тексте (виден на Desktop без пака; exteraGram рисует premium поверх).
