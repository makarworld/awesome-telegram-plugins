    def _copy_to_clipboard(self, label, text):
        if AndroidUtilities.addToClipboard(text):
            BulletinHelper.show_info(f"Copied {label} to clipboard")

    def _open_telegram_username(self, username):
        name = str(username or "").lstrip("@")
        if not name:
            return
        try:
            get_messages_controller().openByUserName(name, get_last_fragment(), 1)
        except Exception:
            log(f"[{__id__}] openByUserName failed: {name}\n{traceback.format_exc()}")

    def _credit_link(self, username, text_key, subtext_key):
        return Text(
            text=locali.get_string(text_key),
            subtext=locali.get_string(subtext_key),
            icon="msg_link",
            accent=True,
            on_click=lambda view, u=username: run_on_ui_thread(lambda: self._open_telegram_username(u)),
        )

    def _settings_credits(self):
        return [
            Header(text=locali.get_string("CREDITS_HEADER")),
            Divider(text=locali.get_string("CREDITS_ORIGINAL_HEADER")),
            self._credit_link("mihailkotovski", "CREDITS_MAIN_AUTHOR", "CREDITS_MAIN_AUTHOR_SUB"),
            self._credit_link("mishabotov", "CREDITS_COAUTHOR", "CREDITS_COAUTHOR_SUB"),
            self._credit_link("bleizix", "CREDITS_IDEA", "CREDITS_IDEA_SUB"),
            Divider(text=locali.get_string("CREDITS_MAINTAINER_HEADER")),
            self._credit_link("abuztrade", "CREDITS_MAINTAINER", "CREDITS_MAINTAINER_SUB"),
            self._credit_link("AwesomeTelegramPlugins", "CREDITS_CHANNEL", "CREDITS_CHANNEL_SUB"),
        ]

    def _get_frequency_prob_for_new_effects(self, setting_key, default_index=2):
        frequency_idx = self.get_setting(setting_key, default_index)
        if frequency_idx == 0:
            return 0.10
        if frequency_idx == 1:
            return 0.25
        if frequency_idx == 3:
            return 0.75
        if frequency_idx == 4:
            return 1.00
        return 0.5

    def _get_premium_emoji_chance(self, scale=1.0):
        prob = self._get_frequency_prob_for_new_effects("premium_emoji_frequency", 3)
        return min(1.0, prob * scale)

    def _open_plugin_settings(self, java_plugin):
        try:
            get_last_fragment().presentFragment(PluginSettingsActivity(java_plugin))
        except Exception as e:
            log(f"[{__id__}] Error opening plugin settings: {e}")

    def _add_settings_menu_items(self):
        try:
            if not self._drawer_settings_item:
                self._drawer_settings_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.DRAWER_MENU,
                        text=locali.get_string("SETTINGS_HEADER"),
                        icon="menu_premium_effects",
                        priority=5,
                        on_click=lambda ctx: run_on_ui_thread(
                            lambda: self._open_plugin_settings(PluginsController.getInstance().plugins.get(self.id))
                        ),
                    )
                )
            if not self._chat_settings_item:
                self._chat_settings_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.CHAT_ACTION_MENU,
                        text=locali.get_string("SETTINGS_HEADER"),
                        icon="menu_premium_effects",
                        priority=5,
                        on_click=lambda ctx: run_on_ui_thread(
                            lambda: self._open_plugin_settings(PluginsController.getInstance().plugins.get(self.id))
                        ),
                    )
                )
        except Exception as e:
            log(f"[{__id__}] Failed to add settings menu items: {e}")

    def _remove_settings_menu_items(self):
        try:
            if self._drawer_settings_item:
                self.remove_menu_item(self._drawer_settings_item)
                self._drawer_settings_item = None
            if self._chat_settings_item:
                self.remove_menu_item(self._chat_settings_item)
                self._chat_settings_item = None
        except Exception as e:
            log(f"[{__id__}] Failed to remove settings menu items: {e}")

    def _on_show_settings_buttons_change(self, enabled: bool):
        def _toggle():
            try:
                if enabled:
                    self._add_settings_menu_items()
                else:
                    self._remove_settings_menu_items()
            except Exception as e:
                log(f"[{__id__}] Failed toggling settings buttons: {e}")

        run_on_ui_thread(_toggle)

    def _show_bulletin(self, message):
        run_on_ui_thread(lambda: BulletinHelper.show_info(message))

    def _ctx_get(self, context, key):
        if context is None:
            return None
        if isinstance(context, dict):
            return context.get(key)
        if hasattr(context, "get"):
            try:
                return context.get(key)
            except Exception:
                pass
        return None

    def _get_chat_filter_mode(self):
        try:
            return int(self.get_setting("chat_filter_mode", 0) or 0)
        except (TypeError, ValueError):
            return 0

    def _reload_plugin_settings(self):
        try:
            self.set_setting("chat_filter_mode", self._get_chat_filter_mode(), reload_settings=True)
        except Exception as e:
            log(f"[{__id__}] reload plugin settings failed: {e}")

    def _normalize_dialog_id(self, peer):
        if peer is None:
            return 0
        try:
            if hasattr(peer, "getClass"):
                return int(DialogObject.getPeerDialogId(peer))
            return int(peer)
        except Exception:
            try:
                return int(peer)
            except Exception:
                return 0

    def _message_ids_from_obj(self, message):
        ids = set()
        if message is None:
            return ids
        for getter in ("getId", "getRealId", "getStableId"):
            if hasattr(message, getter):
                try:
                    mid = int(getattr(message, getter)())
                    ids.add(mid)
                except Exception:
                    pass
        owner = getattr(message, "messageOwner", None)
        if owner is not None:
            try:
                ids.add(int(getattr(owner, "id", 0)))
            except Exception:
                pass
        return ids

    def _message_id_from_obj(self, message):
        ids = self._message_ids_from_obj(message)
        return next(iter(ids), None)

    def _message_id_from_ctx(self, context):
        for key in ("message_id", "msg_id", "messageId"):
            val = self._ctx_get(context, key)
            if val is not None:
                try:
                    return int(val)
                except Exception:
                    pass
        return self._message_id_from_obj(self._ctx_get(context, "message"))

    def _get_undo_cache_key(self, key):
        return self._undo_cache.get(key)

    def _pop_undo_cache_key(self, key):
        record = self._undo_cache.pop(key, None)
        if record is None:
            return None
        try:
            self._undo_cache_order.remove(key)
        except ValueError:
            pass
        for alias_key in list(self._undo_cache.keys()):
            if self._undo_cache.get(alias_key) is record:
                self._undo_cache.pop(alias_key, None)
                try:
                    self._undo_cache_order.remove(alias_key)
                except ValueError:
                    pass
        return record

    def _dialog_id_aliases(self, dialog_id):
        if dialog_id is None:
            return []
        try:
            did = int(dialog_id)
        except Exception:
            return []
        aliases = {did, abs(did)}
        if did > 0:
            aliases.add(-did)
        if did != 0:
            aliases.add(0)
        return list(aliases)

    def _collect_undo_msg_ids(self, msg_id, message=None):
        msg_ids = set()
        if msg_id is not None:
            try:
                msg_ids.add(int(msg_id))
            except Exception:
                pass
        if message is not None:
            msg_ids.update(self._message_ids_from_obj(message))
        return msg_ids

    def _undo_record_matches_text(self, record, text):
        if record is None or text is None:
            return False
        versions = record.get("versions", [])
        if not versions:
            return False
        index = int(record.get("index", len(versions) - 1))
        if 0 <= index < len(versions) and versions[index].get("text") == text:
            return True
        return any(version.get("text") == text for version in versions)

    def _find_undo_record(self, dialog_id, msg_id, message=None, text=None):
        did = int(dialog_id) if dialog_id is not None else None
        if did is None and message is not None:
            try:
                did = int(message.getDialogId())
            except Exception:
                pass

        msg_ids = self._collect_undo_msg_ids(msg_id, message)
        dialog_candidates = self._dialog_id_aliases(did) if did is not None else []

        for candidate_did in dialog_candidates:
            for mid in msg_ids:
                record = self._get_undo_cache_key((candidate_did, mid))
                if record is not None:
                    return (candidate_did, mid), record

        for cache_key, record in list(self._undo_cache.items()):
            if len(cache_key) == 2 and cache_key[1] in msg_ids:
                return cache_key, record

        if text:
            for cache_key, record in list(self._undo_cache.items()):
                if self._undo_record_matches_text(record, text):
                    return cache_key, record

        log(f"[{__id__}] undo miss: dialog_id={did}, msg_ids={sorted(msg_ids)}, cache={list(self._undo_cache.keys())}")
        return None, None

    def _make_version(self, text, entities_list):
        return {
            "text": text,
            "html": self._entities_to_html(text, entities_list),
            "entities": list(entities_list or []),
        }

    def _undo_record_size(self, record):
        total = 0
        for version in record.get("versions", []):
            total += len(version.get("text", "") or "")
            html = version.get("html")
            if html:
                total += len(html)
        return total

    def _undo_cache_total_chars(self):
        seen = set()
        total = 0
        for key in self._undo_cache_order:
            record = self._undo_cache.get(key)
            if record is None:
                continue
            record_id = id(record)
            if record_id in seen:
                continue
            seen.add(record_id)
            total += self._undo_record_size(record)
        return total

    def _evict_undo_cache_if_needed(self):
        while self._undo_cache_order and self._undo_cache_total_chars() > self._UNDO_CHAR_LIMIT:
            oldest = self._undo_cache_order.pop(0)
            self._pop_undo_cache_key(oldest)

    def _touch_undo_primary(self, primary):
        if primary in self._undo_cache_order:
            self._undo_cache_order.remove(primary)
        self._undo_cache_order.append(primary)

    def _touch_undo_record(self, record):
        for cache_key in self._undo_cache_order:
            if self._undo_cache.get(cache_key) is record:
                self._touch_undo_primary(cache_key)
                return

    def _build_undo_record(self, original_text, original_entities, modified_text, modified_entities):
        return {
            "versions": [
                self._make_version(original_text, original_entities),
                self._make_version(modified_text, modified_entities),
            ],
            "index": 1,
            "ts": time.time(),
        }

    def _append_cute_version(self, record, text, entities_list):
        modified_text, new_entities = self._transform_with_entities(
            text,
            entities_list,
            self.get_classic_effects_probability(),
            self.get_setting("text_style", 0),
        )
        versions = record["versions"]
        index = int(record.get("index", len(versions) - 1))
        if index == 0 and len(versions) > 1:
            versions = [versions[0], self._make_version(modified_text, new_entities)]
            index = 1
        else:
            versions = versions[: index + 1] + [self._make_version(modified_text, new_entities)]
            index = len(versions) - 1
        record["versions"] = versions
        record["index"] = index
        record["ts"] = time.time()
        return modified_text, new_entities

    def _undo_step_version(self, record):
        versions = record.get("versions", [])
        if len(versions) < 2:
            return None, None
        index = int(record.get("index", len(versions) - 1))
        if index > 1:
            record["index"] = index - 1
            return versions[index - 1], locali.get_string("UNDO_PREVIOUS")
        if index == 1:
            record["index"] = 0
            return versions[0], locali.get_string("UNDO_RESTORED")
        record["index"] = 1
        return versions[1], locali.get_string("UNDO_TO_CUTE")

    def _build_java_entities_array(self, entities_list):
        java_list = ArrayList()
        if not entities_list:
            return java_list
        for rec in entities_list:
            java_ent = rec.get("java")
            if java_ent is None:
                continue
            off = int(rec.get("new_offset", rec.get("offset", 0)))
            ln = int(rec.get("new_length", rec.get("length", 0)))
            try:
                java_ent.offset = off
                java_ent.length = ln
            except Exception:
                pass
            java_list.add(java_ent)
        return java_list

    def _edit_message_schedule_params(self, message):
        schedule_date = 0
        schedule_repeat = 0
        try:
            if getattr(message, "scheduled", False):
                owner = getattr(message, "messageOwner", None)
                if owner is not None:
                    schedule_date = int(getattr(owner, "date", 0) or 0)
                    schedule_repeat = int(getattr(owner, "schedule_repeat_period", 0) or 0)
        except Exception:
            pass
        return schedule_date, schedule_repeat

    def _edit_message_content(self, message, text, html=None, entities_list=None):
        if entities_list:
            try:
                fragment = get_last_fragment()
                if fragment is not None:
                    schedule_date, schedule_repeat = self._edit_message_schedule_params(message)
                    java_entities = self._build_java_entities_array(entities_list)
                    get_send_messages_helper().editMessage(
                        message,
                        text,
                        True,
                        fragment,
                        java_entities,
                        schedule_date,
                        schedule_repeat,
                    )
                    return
            except Exception:
                log(f"[{__id__}] editMessage with entities failed:\n{traceback.format_exc()}")
        if html:
            try:
                edit_message(message, text=html, parse_mode="html")
                return
            except Exception:
                try:
                    edit_message(message, text=html, parse_mode="HTML")
                    return
                except Exception:
                    pass
        edit_message(message, text=text)

    def _is_outgoing_message(self, message):
        if message is None:
            return False
        if hasattr(message, "isOut"):
            try:
                return bool(message.isOut())
            except Exception:
                pass
        owner = getattr(message, "messageOwner", None)
        if owner is not None:
            try:
                return bool(getattr(owner, "out", False))
            except Exception:
                pass
        return False

    def _message_content_from_obj(self, message):
        text = ""
        entities = None
        owner = getattr(message, "messageOwner", None)
        if owner is not None:
            text = str(getattr(owner, "message", "") or "")
            entities = getattr(owner, "entities", None)
        elif hasattr(message, "getMessageText"):
            try:
                text = str(message.getMessageText() or "")
            except Exception:
                pass
        return text, self._snapshot_entities(entities)

    def _dialog_id_from_message(self, message, context=None):
        if message is not None:
            try:
                return int(message.getDialogId())
            except Exception:
                pass
        if context is not None:
            return self._dialog_id_from_ctx(context)
        return None

    def _dialog_id_from_fragment(self):
        try:
            fragment = get_last_fragment()
            if fragment is not None and hasattr(fragment, "getDialogId"):
                return int(fragment.getDialogId())
        except Exception:
            pass
        return None

    def _get_chat_list_menu_icon(self, dialog_id=None):
        mode = self._get_chat_filter_mode()
        if mode == 2:
            return "msg_block"
        return "msg_favorite"

    def _get_chat_list_menu_text(self, dialog_id=None):
        mode = self._get_chat_filter_mode()
        if mode == 0:
            return locali.get_string("CHAT_FILTER_BTN_NEUTRAL")
        if mode == 1:
            in_list = dialog_id is not None and int(dialog_id) in self._get_chat_list("chat_whitelist")
            key = "CHAT_WHITELIST_REMOVE_BTN" if in_list else "CHAT_WHITELIST_ADD_BTN"
        else:
            in_list = dialog_id is not None and int(dialog_id) in self._get_chat_list("chat_blacklist")
            key = "CHAT_BLACKLIST_REMOVE_BTN" if in_list else "CHAT_BLACKLIST_ADD_BTN"
        return locali.get_string(key)

    def _update_chat_list_menu_text(self, dialog_id=None):
        def _do_update():
            try:
                if dialog_id is None:
                    resolved_id = self._dialog_id_from_fragment()
                else:
                    resolved_id = dialog_id
                if resolved_id is not None:
                    resolved_id = int(resolved_id)
                text = self._get_chat_list_menu_text(resolved_id)
                icon = self._get_chat_list_menu_icon(resolved_id)
                if (
                    text == self._chat_list_menu_text
                    and icon == self._chat_list_menu_icon
                    and resolved_id == self._chat_list_menu_dialog_id
                    and self._chat_list_menu_item
                ):
                    return
                if self._chat_list_menu_item:
                    self.remove_menu_item(self._chat_list_menu_item)
                    self._chat_list_menu_item = None
                self._chat_list_menu_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.CHAT_ACTION_MENU,
                        text=text,
                        icon=icon,
                        item_id=f"{__id__}_chat_list",
                        priority=4,
                        on_click=self._on_chat_list_toggle_click,
                    )
                )
                self._chat_list_menu_text = text
                self._chat_list_menu_icon = icon
                self._chat_list_menu_dialog_id = resolved_id
            except Exception as e:
                log(f"[{__id__}] Failed updating chat list menu text: {e}\n{traceback.format_exc()}")

        run_on_ui_thread(_do_update)

    def _install_chat_dialog_hook(self):
        try:
            ca_cls = find_class("org.telegram.ui.ChatActivity")
            if not ca_cls:
                return

            plugin = self

            class _ChatDialogHook(MethodHook):
                def after_hooked_method(self, param):
                    try:
                        chat = param.thisObject
                        if chat is not None and hasattr(chat, "getDialogId"):
                            did = int(chat.getDialogId())
                            plugin._update_chat_list_menu_text(did)
                            plugin._update_topic_menu_text(did)
                    except Exception:
                        pass

            refs = self.hook_all_methods(ca_cls, "onTransitionAnimationEnd", _ChatDialogHook())
            if refs:
                self._chat_dialog_hooks.extend(refs)
        except Exception as e:
            log(f"[{__id__}] chat dialog hook failed: {e}\n{traceback.format_exc()}")

    def _uninstall_chat_dialog_hook(self):
        for ref in self._chat_dialog_hooks:
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._chat_dialog_hooks = []

    def _add_chat_action_items(self):
        self._update_chat_list_menu_text()
        self._update_topic_menu_text()

    def _remove_chat_action_items(self):
        try:
            if self._chat_list_menu_item:
                self.remove_menu_item(self._chat_list_menu_item)
                self._chat_list_menu_item = None
                self._chat_list_menu_text = None
                self._chat_list_menu_icon = None
                self._chat_list_menu_dialog_id = None
        except Exception as e:
            log(f"[{__id__}] Failed removing chat action items: {e}")

    def _add_undo_menu_item(self):
        try:
            if not self._undo_menu_item:
                self._undo_menu_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                        text=locali.get_string("UNDO_RESTORE"),
                        subtext=locali.get_string("UNDO_RESTORE_SUB"),
                        icon="chats_undo",
                        priority=10,
                        on_click=self._on_undo_restore_click,
                    )
                )
        except Exception as e:
            log(f"[{__id__}] Failed adding undo menu item: {e}")

    def _remove_undo_menu_item(self):
        try:
            if self._undo_menu_item:
                self.remove_menu_item(self._undo_menu_item)
                self._undo_menu_item = None
        except Exception as e:
            log(f"[{__id__}] Failed removing undo menu item: {e}")

    def _add_cutify_menu_item(self):
        try:
            if not self._cutify_menu_item:
                self._cutify_menu_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                        text=locali.get_string("CUTIFY"),
                        subtext=locali.get_string("CUTIFY_SUB"),
                        icon="menu_premium_effects",
                        priority=9,
                        on_click=self._on_cutify_click,
                    )
                )
        except Exception as e:
            log(f"[{__id__}] Failed adding cutify menu item: {e}")

    def _remove_cutify_menu_item(self):
        try:
            if self._cutify_menu_item:
                self.remove_menu_item(self._cutify_menu_item)
                self._cutify_menu_item = None
        except Exception as e:
            log(f"[{__id__}] Failed removing cutify menu item: {e}")

    def _dialog_id_from_ctx(self, context):
        for key in ("dialog_id", "chatId", "chat_id", "peer"):
            val = self._ctx_get(context, key)
            if val is not None:
                try:
                    return int(val)
                except Exception:
                    return val

        user_id = self._ctx_get(context, "userId")
        if user_id is not None:
            try:
                return int(user_id)
            except Exception:
                pass

        fragment = self._ctx_get(context, "fragment")
        if fragment is not None and hasattr(fragment, "getDialogId"):
            try:
                return int(fragment.getDialogId())
            except Exception:
                pass

        nested = self._ctx_get(context, "context")
        if nested is not None and nested is not context:
            nested_id = self._dialog_id_from_ctx(nested)
            if nested_id is not None:
                return nested_id

        return None

    def _on_chat_list_toggle_click(self, context):
        try:
            mode = self._get_chat_filter_mode()
            if mode == 0:
                self._show_bulletin(locali.get_string("CHAT_LIST_TOGGLE_NO_MODE"))
                return
            dialog_id = self._dialog_id_from_ctx(context)
            if dialog_id is None:
                dialog_id = self._dialog_id_from_fragment()
            if dialog_id is None:
                log(
                    f"[{__id__}] toggle list: no dialog_id, keys={list(context.keys()) if isinstance(context, dict) else type(context)}"
                )
                self._show_bulletin(locali.get_string("CHAT_DIALOG_ID_ERROR"))
                return
            dialog_id = int(dialog_id)
            list_key = "chat_whitelist" if mode == 1 else "chat_blacklist"
            added = self._toggle_chat_in_list(list_key, dialog_id)
            if added is None:
                return
            if mode == 1:
                msg = locali.get_string("CHAT_WHITELIST_ADDED" if added else "CHAT_WHITELIST_REMOVED")
            else:
                msg = locali.get_string("CHAT_BLACKLIST_ADDED" if added else "CHAT_BLACKLIST_REMOVED")
            self._show_bulletin(msg)
            self._update_chat_list_menu_text(dialog_id)
        except Exception as e:
            log(f"[{__id__}] toggle chat list failed: {e}\n{traceback.format_exc()}")

    def _on_undo_restore_click(self, context):
        try:
            message = self._ctx_get(context, "message")
            if not self._is_outgoing_message(message):
                self._show_bulletin(locali.get_string("UNDO_NOTHING"))
                return
            dialog_id = self._dialog_id_from_message(message, context)
            msg_id = self._message_id_from_ctx(context)
            key, record = self._find_undo_record(dialog_id, msg_id, message=message)
            if record is None:
                self._show_bulletin(locali.get_string("UNDO_NOTHING"))
                return

            version, bulletin = self._undo_step_version(record)
            if version is None:
                self._show_bulletin(locali.get_string("UNDO_NOTHING"))
                return

            def _do_edit():
                try:
                    log(
                        f"[{__id__}] undo step: key={key}, msg_id={msg_id}, "
                        f"index={record.get('index')}/{len(record.get('versions', [])) - 1}"
                    )
                    self._edit_message_content(
                        message,
                        version.get("text", ""),
                        version.get("html"),
                        version.get("entities"),
                    )
                    BulletinHelper.show_info(bulletin)
                except Exception:
                    log(f"[{__id__}] edit_message failed:\n{traceback.format_exc()}")
                    BulletinHelper.show_info(locali.get_string("UNDO_NOTHING"))

            run_on_ui_thread(_do_edit)
        except Exception as e:
            log(f"[{__id__}] undo restore failed: {e}\n{traceback.format_exc()}")

    def _on_cutify_click(self, context):
        try:
            message = self._ctx_get(context, "message")
            if not self._is_outgoing_message(message):
                self._show_bulletin(locali.get_string("CUTIFY_NOT_OWN"))
                return
            text, entities_list = self._message_content_from_obj(message)
            if self._should_skip_text(text):
                return

            dialog_id = self._dialog_id_from_message(message, context)
            msg_ids = self._message_ids_from_obj(message)
            msg_id = self._message_id_from_ctx(context)
            if msg_id is not None:
                msg_ids.add(int(msg_id))

            key, existing = self._find_undo_record(dialog_id, msg_id, message=message, text=text)
            if existing:
                record = existing
                modified_text, new_entities = self._append_cute_version(record, text, entities_list)
                self._touch_undo_record(record)
                self._evict_undo_cache_if_needed()
            else:
                classic_effects_prob = self.get_classic_effects_probability()
                text_style_setting = self.get_setting("text_style", 0)
                modified_text, new_entities = self._transform_with_entities(
                    text, entities_list, classic_effects_prob, text_style_setting
                )
                record = self._build_undo_record(text, entities_list, modified_text, new_entities)
                if dialog_id is not None and msg_ids:
                    self._store_undo_record(dialog_id, msg_ids, record)

            version = record["versions"][record["index"]]

            def _do_edit():
                try:
                    self._edit_message_content(
                        message,
                        version.get("text", modified_text),
                        version.get("html"),
                        version.get("entities"),
                    )
                    BulletinHelper.show_info(locali.get_string("CUTIFY_DONE"))
                except Exception:
                    log(f"[{__id__}] cutify edit_message failed:\n{traceback.format_exc()}")
                    BulletinHelper.show_info(locali.get_string("UNDO_NOTHING"))

            run_on_ui_thread(_do_edit)
        except Exception as e:
            log(f"[{__id__}] cutify failed: {e}\n{traceback.format_exc()}")

    def _is_cyrillic(self, text):
        return bool(re.search("[а-яА-Я]", text))

    def _get_chat_list(self, key):
        raw = self.get_setting(key, "[]")
        try:
            data = json.loads(raw) if isinstance(raw, str) else raw
            if isinstance(data, list):
                return [int(x) for x in data if x is not None]
        except Exception:
            log(f"[{__id__}] {key} parse error: {traceback.format_exc()}")
        return []

    def _set_chat_list(self, key, ids, reload_settings=True):
        self.set_setting(key, json.dumps([int(i) for i in ids]), reload_settings=reload_settings)
        if self._chat_list_menu_item and key == self._active_chat_list_key():
            self._update_chat_list_menu_text()

    def _active_chat_list_key(self):
        mode = self._get_chat_filter_mode()
        if mode == 1:
            return "chat_whitelist"
        if mode == 2:
            return "chat_blacklist"
        return None

    def _get_dialog_title(self, dialog_id):
        try:
            mc = get_messages_controller()
            dialog_id = int(dialog_id)
            if DialogObject.isUserDialog(dialog_id):
                user = mc.getUser(dialog_id)
                if user is not None:
                    name = UserObject.getUserName(user)
                    if name:
                        return str(name)
            else:
                chat_id = -dialog_id
                if chat_id > 1000000000000:
                    chat_id -= 1000000000000
                chat = mc.getChat(int(chat_id))
                if chat is not None:
                    title = ChatObject.getTitle(chat)
                    if title:
                        return str(title)
        except Exception:
            log(f"[{__id__}] get dialog title failed: {traceback.format_exc()}")
        return str(dialog_id)

    def _remove_chat_from_list(self, dialog_id):
        key = self._active_chat_list_key()
        if not key:
            return
        dialog_id = int(dialog_id)
        ids = self._get_chat_list(key)
        if dialog_id in ids:
            ids.remove(dialog_id)
            self._set_chat_list(key, ids, reload_settings=True)

    def _on_chat_filter_mode_change(self, new_index):
        try:
            mode = int(new_index)
        except (TypeError, ValueError):
            mode = 0
        self.set_setting("chat_filter_mode", mode, reload_settings=True)
        self._update_chat_list_menu_text()
        self._update_topic_menu_text()

    def _build_chat_filter_settings(self):
        mode = self._get_chat_filter_mode()
        if mode == 0:
            return [Divider(text=locali.get_string("CHAT_FILTER_HINT"))]

        key = self._active_chat_list_key()
        header_key = "CHAT_LIST_HEADER_WHITELIST" if mode == 1 else "CHAT_LIST_HEADER_BLACKLIST"
        items = [Header(text=locali.get_string(header_key))]
        chat_ids = self._get_chat_list(key)
        if not chat_ids:
            items.append(Text(text=locali.get_string("CHAT_LIST_EMPTY")))
        else:
            for dialog_id in chat_ids:
                title = self._get_dialog_title(dialog_id)

                def _make_remove(did):
                    def _on_remove(view):
                        self._remove_chat_from_list(did)

                    return _on_remove

                items.append(
                    Text(
                        text=title,
                        subtext=locali.get_string("CHAT_LIST_REMOVE"),
                        on_click=_make_remove(dialog_id),
                    )
                )
        items.append(Divider(text=locali.get_string("CHAT_FILTER_HINT")))
        return items

    def _toggle_chat_in_list(self, key, peer):
        if peer is None:
            return None
        peer = int(peer)
        ids = self._get_chat_list(key)
        if peer in ids:
            ids.remove(peer)
            self._set_chat_list(key, ids)
            return False
        ids.append(peer)
        self._set_chat_list(key, ids)
        return True

    def _should_apply_in_chat(self, peer, topic_id=None):
        if peer is None:
            return True
        peer = int(peer)
        mode = self._get_chat_filter_mode()
        if mode == 1:
            if peer in self._get_chat_list("chat_whitelist"):
                return True
            if topic_id is not None:
                topics = self._get_topic_whitelist(peer)
                return int(topic_id) in topics
            return False
        if mode == 2:
            return peer not in self._get_chat_list("chat_blacklist")
        return True

    def _apply_language_from_settings(self):
        locali.apply_override(int(self.get_setting("message_language", 0) or 0))

    def _on_message_language_change(self, new_index):
        try:
            idx = int(new_index)
        except (TypeError, ValueError):
            idx = 0
        self.set_setting("message_language", idx, reload_settings=False)
        locali.apply_override(idx)
        self.set_setting("message_language", idx, reload_settings=True)

    def _is_emoji_only_message(self, text):
        if not text:
            return False
        stripped = text.strip()
        if not stripped:
            return False
        if not _EMOJI_ONLY_MSG_RE.fullmatch(stripped):
            return False
        parts = [p for p in re.split(r"\s+", stripped) if p]
        return len(parts) in (1, 3)

    def _is_private_chat_peer(self, peer):
        try:
            dialog_id = self._normalize_dialog_id(peer)
            if not dialog_id:
                return False
            return DialogObject.isUserDialog(int(dialog_id))
        except Exception:
            return False

    def _apply_send_message_effect(self, params, peer, effect_id):
        if not effect_id or not self._is_private_chat_peer(peer):
            return
        if not hasattr(params, "effect_id"):
            return
        try:
            params.effect_id = int(effect_id)
        except Exception:
            pass

    def _slot_for_doc_id(self, doc_id):
        doc_id = int(doc_id)
        for item in CUSTOM_EMOJI:
            rep = item.get("replace")
            ids = item.get("ids") or []
            if rep and len(ids) == 1 and int(ids[0]) == doc_id:
                return rep
        return _PREMIUM_SLOT_BY_ID.get(doc_id, _PREMIUM_SLOT_DEFAULT)

    def _premium_slot_rows(self, item):
        if item.get("slot_rows"):
            return [list(row) for row in item["slot_rows"]]
        rows = item.get("rows")
        if rows:
            slots = item.get("slots")
            if slots and len(slots) == sum(len(row) for row in rows):
                it = iter(slots)
                return [[next(it) for _ in row] for row in rows]
            return [[self._slot_for_doc_id(doc_id) for doc_id in row] for row in rows]
        ids = item.get("ids") or []
        slots = item.get("slots")
        if slots and len(slots) == len(ids):
            return [list(slots)]
        return [[self._slot_for_doc_id(doc_id) for doc_id in ids]]

    def _premium_doc_ids_in_item(self, item):
        ids = set()
        for row in item.get("rows") or []:
            for doc_id in row:
                ids.add(int(doc_id))
        for doc_id in item.get("ids") or []:
            ids.add(int(doc_id))
        return ids

    def _premium_doc_ids_in_entities(self, entities_list):
        used = set()
        for rec in entities_list or []:
            if rec.get("type") != "MessageEntityCustomEmoji":
                continue
            doc_id = rec.get("document_id")
            if doc_id is not None:
                used.add(int(doc_id))
        return used

    def _premium_block_conflicts(self, item, used_ids):
        if not used_ids:
            return False
        return bool(self._premium_doc_ids_in_item(item) & used_ids)

    def _premium_replace_map(self):
        out = {}
        for item in CUSTOM_EMOJI:
            rep = item.get("replace")
            ids = item.get("ids") or []
            if rep and len(ids) == 1:
                out[rep] = ids[0]
        return out

    def _premium_nature_blocks(self):
        return [item for item in CUSTOM_EMOJI if item.get("nature")]

    def _premium_decoration_blocks(self):
        return [item for item in CUSTOM_EMOJI if item.get("decoration")]

    def _premium_mur_bands(self):
        return [item for item in CUSTOM_EMOJI if item.get("mur")]

    def _inject_premium_emoji_entities(self, text, entities_list):
        if not self.get_setting("use_premium_emoji", False):
            return text, entities_list
        if entities_list is None:
            entities_list = []
        replace_map = self._premium_replace_map()
        if not replace_map:
            return text, entities_list
        replace_prob = self._get_premium_emoji_chance()
        used_doc_ids = self._premium_doc_ids_in_entities(entities_list)
        protected = self._collect_protected_ranges(text, entities_list)
        offset = 0
        while offset < len(text):
            matched = False
            for emoji_char, doc_id in sorted(replace_map.items(), key=lambda x: -len(x[0])):
                if text[offset : offset + len(emoji_char)] != emoji_char:
                    continue
                start, end = offset, offset + len(emoji_char)
                if any(p_start <= start and end <= p_end for p_start, p_end in protected):
                    offset = end
                    matched = True
                    break
                overlaps = False
                for rec in entities_list:
                    e_start, e_end = _utf16_to_py_range(
                        text,
                        rec.get("new_offset", rec.get("offset", 0)),
                        rec.get("new_length", rec.get("length", 0)),
                    )
                    if start < e_end and end > e_start:
                        overlaps = True
                        break
                if not overlaps and int(doc_id) not in used_doc_ids and random.random() < replace_prob:
                    self._append_premium_emoji_entity(entities_list, text, start, end, doc_id)
                    used_doc_ids.add(int(doc_id))
                offset = end
                matched = True
                break
            if not matched:
                offset += 1
        return text, entities_list

    def _get_topic_id_from_params(self, params):
        for attr in ("replyToTopMsg", "reply_to_top_msg", "replyToTopMessage"):
            obj = getattr(params, attr, None)
            if obj is None:
                continue
            for getter in ("getId", "getRealId"):
                if hasattr(obj, getter):
                    try:
                        tid = int(getattr(obj, getter)())
                        if tid:
                            return tid
                    except Exception:
                        pass
            try:
                owner = getattr(obj, "messageOwner", None)
                if owner is not None:
                    tid = int(getattr(owner, "id", 0))
                    if tid:
                        return tid
            except Exception:
                pass
        for attr in ("reply_to_top_id", "topMsgId", "topicId"):
            val = getattr(params, attr, None)
            if val is not None:
                try:
                    tid = int(val)
                    if tid:
                        return tid
                except Exception:
                    pass
        return None

    def _get_topic_id_from_fragment(self):
        try:
            fragment = get_last_fragment()
            if fragment is None:
                return None
            for getter in ("getThreadMessageId", "getTopicId"):
                if hasattr(fragment, getter):
                    try:
                        tid = int(getattr(fragment, getter)())
                        if tid:
                            return tid
                    except Exception:
                        pass
        except Exception:
            pass
        return None

    def _get_topic_whitelist_map(self):
        raw = self.get_setting("topic_whitelist", "{}")
        try:
            data = json.loads(raw) if isinstance(raw, str) else raw
            if isinstance(data, dict):
                return {str(k): [int(x) for x in v if x is not None] for k, v in data.items() if isinstance(v, list)}
        except Exception:
            log(f"[{__id__}] topic_whitelist parse error: {traceback.format_exc()}")
        return {}

    def _get_topic_whitelist(self, dialog_id):
        return self._get_topic_whitelist_map().get(str(int(dialog_id)), [])

    def _set_topic_whitelist_map(self, data, reload_settings=True):
        self.set_setting("topic_whitelist", json.dumps(data), reload_settings=reload_settings)

    def _toggle_topic_in_whitelist(self, dialog_id, topic_id):
        dialog_id = int(dialog_id)
        topic_id = int(topic_id)
        data = self._get_topic_whitelist_map()
        key = str(dialog_id)
        topics = data.get(key, [])
        if topic_id in topics:
            topics.remove(topic_id)
            if topics:
                data[key] = topics
            else:
                data.pop(key, None)
            self._set_topic_whitelist_map(data)
            return False
        topics.append(topic_id)
        data[key] = topics
        self._set_topic_whitelist_map(data)
        return True

    def _get_topic_title(self, dialog_id, topic_id):
        try:
            mc = get_messages_controller()
            chat_id = -int(dialog_id)
            if chat_id > 1000000000000:
                chat_id -= 1000000000000
            topic = mc.getTopicsController().findTopic(int(chat_id), int(topic_id))
            if topic is not None:
                title = getattr(topic, "title", None) or getattr(topic, "name", None)
                if title:
                    return str(title)
        except Exception:
            pass
        return f"#{topic_id}"

    def _build_topic_whitelist_settings(self):
        data = self._get_topic_whitelist_map()
        if not data:
            return [Text(text=locali.get_string("TOPIC_LIST_EMPTY"))]
        items = []
        for dialog_key, topic_ids in data.items():
            chat_title = self._get_dialog_title(int(dialog_key))
            for topic_id in topic_ids:
                title = self._get_topic_title(int(dialog_key), topic_id)

                def _make_remove(did, tid):
                    def _on_remove(view):
                        self._toggle_topic_in_whitelist(did, tid)
                        self.set_setting(
                            "topic_whitelist", self.get_setting("topic_whitelist", "{}"), reload_settings=True
                        )

                    return _on_remove

                items.append(
                    Text(
                        text=f"{chat_title} / {title}",
                        subtext=locali.get_string("CHAT_LIST_REMOVE"),
                        on_click=_make_remove(int(dialog_key), int(topic_id)),
                    )
                )
        return items

    def _get_topic_menu_text(self, dialog_id=None, topic_id=None):
        if self._get_chat_filter_mode() != 1 or topic_id is None:
            return None
        in_list = dialog_id is not None and int(topic_id) in self._get_topic_whitelist(int(dialog_id))
        key = "TOPIC_WHITELIST_REMOVE_BTN" if in_list else "TOPIC_WHITELIST_ADD_BTN"
        return locali.get_string(key)

    def _update_topic_menu_text(self, dialog_id=None, topic_id=None):
        def _do_update():
            try:
                resolved_id = dialog_id if dialog_id is not None else self._dialog_id_from_fragment()
                resolved_topic = topic_id if topic_id is not None else self._get_topic_id_from_fragment()
                text = self._get_topic_menu_text(resolved_id, resolved_topic)
                if text is None:
                    if self._topic_menu_item:
                        self.remove_menu_item(self._topic_menu_item)
                        self._topic_menu_item = None
                    return
                if (
                    text == self._topic_menu_text
                    and resolved_id == self._topic_menu_dialog_id
                    and resolved_topic == self._topic_menu_topic_id
                    and self._topic_menu_item
                ):
                    return
                if self._topic_menu_item:
                    self.remove_menu_item(self._topic_menu_item)
                    self._topic_menu_item = None
                self._topic_menu_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.CHAT_ACTION_MENU,
                        text=text,
                        icon="msg_topics",
                        item_id=f"{__id__}_topic_list",
                        priority=3,
                        on_click=self._on_topic_list_toggle_click,
                    )
                )
                self._topic_menu_text = text
                self._topic_menu_dialog_id = resolved_id
                self._topic_menu_topic_id = resolved_topic
            except Exception as e:
                log(f"[{__id__}] Failed updating topic menu: {e}\n{traceback.format_exc()}")

        run_on_ui_thread(_do_update)

    def _on_topic_list_toggle_click(self, context):
        try:
            if self._get_chat_filter_mode() != 1:
                self._show_bulletin(locali.get_string("CHAT_LIST_TOGGLE_NO_MODE"))
                return
            dialog_id = self._dialog_id_from_ctx(context)
            if dialog_id is None:
                dialog_id = self._dialog_id_from_fragment()
            topic_id = self._get_topic_id_from_fragment()
            if dialog_id is None or topic_id is None:
                self._show_bulletin(locali.get_string("CHAT_DIALOG_ID_ERROR"))
                return
            added = self._toggle_topic_in_whitelist(int(dialog_id), int(topic_id))
            msg = locali.get_string("TOPIC_WHITELIST_ADDED" if added else "TOPIC_WHITELIST_REMOVED")
            self._show_bulletin(msg)
            self._update_topic_menu_text(int(dialog_id), int(topic_id))
        except Exception as e:
            log(f"[{__id__}] toggle topic list failed: {e}\n{traceback.format_exc()}")

