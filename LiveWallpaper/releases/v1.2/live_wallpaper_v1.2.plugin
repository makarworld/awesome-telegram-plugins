DEX_URL = "https://storage.yandexcloud.net/4plugins/EveryoneAskedForThis/LiveWallpaper.dex"
BUNDLED_DEX_URL = "https://raw.githubusercontent.com/makarworld/awesome-telegram-plugins/refs/heads/main/LiveWallpaper/LiveWallpaper.dex"
MANIFEST_URLS = [
    "https://raw.githubusercontent.com/makarworld/awesome-telegram-plugins/refs/heads/main/plugin-integrity.json",
    "https://storage.yandexcloud.net/awesomeplugins/AwesomePlugins/plugin-integrity.json",
]
